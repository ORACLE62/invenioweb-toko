{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/login",
      "dest": "/server.js"
    },
    {
      "src": "/dashboard",
      "dest": "/server.js"
    },
    {
      "src": "/barang",
      "dest": "/server.js"
    },
    {
      "src": "/barang/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/supplier",
      "dest": "/server.js"
    },
    {
      "src": "/supplier/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/transaksi",
      "dest": "/server.js"
    },
    {
      "src": "/transaksi/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/laporan",
      "dest": "/server.js"
    },
    {
      "src": "/logout",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
