<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cetak Laporan - InvenioWeb</title>
    <link rel="icon" href="/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* CSS khusus biar waktu di-print, sidebar dan tombol download-nya ilang otomatis */
        @media print {
            .no-print { display: none !important; }
            body { background: white !important; color: black !important; }
            .print-card { border: 1px solid #d4d4d8 !important; background: transparent !important; color: black !important; }
            .print-table th { background-color: #f4f4f5 !important; color: black !important; border-bottom: 2px solid #e4e4e7 !important; }
            .print-table td { border-bottom: 1px solid #e4e4e7 !important; color: black !important; }
        }
    </style>
</head>
<body class="bg-zinc-950 text-white font-sans min-h-screen flex flex-col md:flex-row">

    <!-- SIDEBAR: Laptop (Hilang pas diprint) -->
    <div class="no-print hidden md:flex w-64 bg-zinc-900 border-r border-zinc-800 p-6 flex-col justify-between shrink-0">
        <div>
            <div class="flex items-center gap-3 mb-8">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-indigo-500 to-pink-500 flex items-center justify-center font-bold">I</div>
                <span class="font-bold text-lg tracking-wider">InvenioWeb</span>
            </div>
            <nav class="space-y-2">
                <a href="/dashboard" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Dashboard</a>
                <a href="/barang" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Kelola Barang</a>
                <a href="/supplier" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Kelola Supplier</a>
                <a href="/transaksi" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Kelola Transaksi</a>
                <a href="/laporan" class="block px-4 py-2.5 bg-indigo-600 rounded-lg text-sm font-medium transition">Cetak Laporan</a>
            </nav>
        </div>
        <div class="border-t border-zinc-800 pt-4 text-xs text-zinc-500">
            InvenioWeb v1.0.0
        </div>
    </div>

    <!-- NAVBAR: HP (Hilang pas diprint) -->
    <div class="no-print md:hidden bg-zinc-900 border-b border-zinc-800 p-4">
        <div class="flex items-center justify-between mb-4">
            <span class="font-bold text-lg tracking-wider">InvenioWeb</span>
            <a href="/logout" class="text-xs text-red-400 font-medium">Logout</a>
        </div>
        <nav class="flex flex-wrap gap-2">
            <a href="/dashboard" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Dashboard</a>
            <a href="/barang" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Barang</a>
            <a href="/supplier" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Supplier</a>
            <a href="/transaksi" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Transaksi</a>
            <a href="/laporan" class="px-3 py-1.5 bg-indigo-600 text-white rounded-lg text-xs font-medium">Laporan</a>
        </nav>
    </div>

    <!-- MAIN CONTENT -->
    <div class="flex-grow p-4 md:p-10 overflow-y-auto w-full">
        <header class="mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-b border-zinc-800 pb-6 print:border-zinc-300">
            <div>
                <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-white print:text-black">Laporan Mutasi & Stok Gudang</h1>
                <p class="text-zinc-400 text-sm mt-1 print:text-zinc-600">Dokumen resmi sirkulasi inventaris barang InvenioWeb.</p>
            </div>
            <button onclick="window.print()" class="no-print w-full sm:w-auto bg-emerald-600 hover:bg-emerald-500 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition flex items-center justify-center gap-2 shadow-lg shadow-emerald-900/20">
                🖨️ Cetak / Unduh PDF
            </button>
        </header>

        <!-- AREA TABEL LAPORAN RINGKASAN -->
        <div class="print-card bg-zinc-900 border border-zinc-800 rounded-xl overflow-x-auto p-4 md:p-6 mb-6">
            <h2 class="text-lg font-bold mb-4 print:text-black">📋 Status Kumulatif Komoditas</h2>
            <table class="print-table w-full text-left border-collapse min-w-[600px]">
                <thead>
                    <tr class="border-b border-zinc-800 text-zinc-400 text-xs font-semibold uppercase tracking-wider">
                        <th class="pb-3">Nama Produk</th>
                        <th class="pb-3">Mitra Penyuplai</th>
                        <th class="pb-3 text-center">Stok Terkini</th>
                        <th class="pb-3">Harga Satuan</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-zinc-800/60 text-sm text-zinc-300 print:text-black">
                    <% if (barang.length === 0) { %>
                        <tr>
                            <td colspan="4" class="p-4 text-center italic text-zinc-500">Tidak ada komoditas terdaftar.</td>
                        </tr>
                    <% } else { %>
                        <% barang.forEach(b => { %>
                            <tr>
                                <td class="py-3 font-medium text-white print:text-black"><%= b.nama_barang %></td>
                                <td class="py-3 text-zinc-400 print:text-zinc-700"><%= b.nama_supplier || 'Tanpa Supplier' %></td>
                                <td class="py-3 text-center font-bold font-mono"><%= b.stok %> Pcs</td>
                                <td class="py-3 font-mono">Rp <%= b.harga.toLocaleString('id-ID') %></td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>

        <div class="print-card bg-zinc-900 border border-zinc-800 rounded-xl p-4 text-xs text-zinc-500 print:text-zinc-600 flex justify-between">
            <p>Diekstrak secara otomatis oleh sistem.</p>
            <p>Waktu Unduh: <%= new Date().toLocaleString('id-ID') %></p>
        </div>
    </div>
</body>
</html>
