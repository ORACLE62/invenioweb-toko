<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laporan Mutasi & Akumulasi Stok Gudang - InvenioWeb</title>
    <link class="no-print" rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background-color: #0c1017;
            color: #c9d1d9;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
        @media print {
            .no-print { display: none !important; }
            body { background-color: #ffffff !important; color: #000000 !important; }
            .print-card { background-color: transparent !important; border: 1px solid #d1d5db !important; color: #000000 !important; }
            .text-white, .text-slate-200 { color: #000000 !important; }
            .text-slate-400 { color: #4b5563 !important; }
        }
    </style>
</head>
<body class="flex min-h-screen">

    <div class="no-print w-64 bg-[#12161f] flex flex-col justify-between p-4 border-r border-[#1f242e] shrink-0">
        <div>
            <div class="flex items-center gap-3 px-2 py-4 border-b border-[#1f242e] mb-6">
                <div class="w-10 h-10 bg-cyan-500 rounded-lg flex items-center justify-center text-slate-900 font-bold text-xl shadow-md">
                    IW
                </div>
                <div>
                    <h1 class="text-white font-bold tracking-wide text-sm">InvenioWeb</h1>
                    <span class="text-[11px] text-cyan-400 font-semibold tracking-wider uppercase block">Market System</span>
                </div>
            </div>
            
            <nav class="space-y-1">
                <a href="/dashboard" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-chart-pie w-5 text-center"></i> <span>Dashboard</span>
                </a>
                <a href="/barang" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-box w-5 text-center"></i> <span>Kelola Barang</span>
                </a>
                <a href="/supplier" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-truck w-5 text-center"></i> <span>Kelola Supplier</span>
                </a>
                <a href="/transaksi" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-exchange-alt w-5 text-center"></i> <span>Kelola Transaksi</span>
                </a>
                <a href="/laporan" class="flex items-center gap-3 px-4 py-2.5 bg-[#1c212c] text-white border-l-4 border-cyan-500 rounded-r-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-file-invoice-dollar w-5 text-center text-cyan-400"></i> <span>Cetak Laporan</span>
                </a>
                <a href="/barang-terjual" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-receipt w-5 text-center"></i> <span>Barang Terjual</span>
                </a>
                <% if (user.role === 'admin') { %>
                <a href="/admin/users" class="flex items-center gap-3 px-4 py-2.5 text-red-400 hover:bg-red-950/20 hover:text-red-300 rounded-lg text-sm font-medium transition duration-150 mt-4">
                    <i class="fa-solid fa-users-cog w-5 text-center"></i> <span>Kelola User</span>
                </a>
                <% } %>
            </nav>
        </div>

        <div class="bg-[#171b26] p-3 rounded-xl border border-[#222834] flex items-center justify-between">
            <div class="flex items-center gap-2.5">
                <div class="w-8 h-8 bg-purple-600 rounded-full flex items-center justify-center text-white text-xs font-bold uppercase">
                    <%= user.nama.substring(0,2) %>
                </div>
                <div class="leading-tight">
                    <p class="text-white text-xs font-semibold truncate max-w-[100px]"><%= user.nama %></p>
                    <span class="text-[10px] text-purple-400 font-medium capitalize"><%= user.role %></span>
                </div>
            </div>
            <a href="/logout" class="text-slate-500 hover:text-red-400 text-xs transition-colors" title="Log Out">
                <i class="fa-solid fa-sign-out-alt"></i>
            </a>
        </div>
    </div>

    <main class="flex-1 p-8 overflow-y-auto space-y-6">
        
        <div class="flex justify-between items-center">
            <div>
                <h2 class="text-2xl font-bold text-white tracking-wide">Laporan Mutasi & Akumulasi Stok Gudang</h2>
                <p class="text-xs text-slate-400 mt-1">Sistem rekapitulasi data komoditas internal logistik gudang.</p>
            </div>
            <button onclick="window.print()" class="no-print bg-cyan-600 hover:bg-cyan-700 text-white font-semibold text-xs px-4 py-2.5 rounded-lg flex items-center gap-2 shadow transition-all">
                <i class="fa-solid fa-print"></i> Cetak Laporan Gudang
            </button>
        </div>

        <div class="print-card bg-[#161b22] rounded-xl border border-[#30363d] shadow-md overflow-hidden">
            <div class="p-4 bg-[#1f242e]/50 border-b border-[#30363d] flex items-center gap-2">
                <h3 class="text-xs font-bold text-cyan-400 uppercase tracking-wider">📊 Laporan Akumulasi Komoditas Gudang</h3>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left text-xs border-collapse">
                    <thead>
                        <tr class="bg-[#12161f]/50 text-slate-400 uppercase tracking-wider border-b border-[#30363d] font-semibold">
                            <th class="p-4">Nama Produk</th>
                            <th class="p-4">Mitra Penyuplai (Supplier)</th>
                            <th class="p-4 text-center">Stok Terkini</th>
                            <th class="p-4 text-right">Harga Satuan</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#30363d]/60 text-slate-300">
                        <% if (typeof barang === 'undefined' || barang.length === 0) { %>
                            <tr>
                                <td colspan="4" class="p-8 text-center text-slate-500 italic">
                                    Belum ada data akumulasi barang master.
                                </td>
                            </tr>
                        <% } else { %>
                            <% barang.forEach(b => { %>
                                <tr class="hover:bg-[#1f242e]/30 transition-colors">
                                    <td class="p-4 font-semibold text-white"><%= b.nama_barang %></td>
                                    <td class="p-4 text-slate-400"><%= b.nama_supplier || '-' %></td>
                                    <td class="p-4 text-center text-cyan-400 font-mono font-bold"><%= b.stok %> Pcs</td>
                                    <td class="p-4 text-right font-mono text-slate-300">Rp <%= b.harga.toLocaleString('id-ID') %></td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="pt-2">
            <h3 class="text-sm font-bold text-white flex items-center gap-2">
                <i class="fa-solid fa-history text-slate-400"></i> Riwayat Mutasi Harian
            </h3>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="print-card bg-[#161b22] border border-[#30363d] rounded-xl overflow-hidden shadow-md">
                <div class="p-4 bg-emerald-950/20 border-b border-[#30363d]">
                    <h4 class="text-xs font-bold text-emerald-400 uppercase tracking-wider">📥 Barang Masuk (Inbound)</h4>
                </div>
                <div class="p-4 text-xs space-y-3">
                    <% if (typeof inbound === 'undefined' || inbound.length === 0) { %>
                        <p class="text-slate-500 italic text-center py-4">Tidak ada transaksi masuk hari ini.</p>
                    <% } else { %>
                        <% inbound.forEach(i => { %>
                            <div class="flex justify-between items-center bg-[#12161f]/40 p-3 rounded-lg border border-[#30363d]/50">
                                <div>
                                    <p class="font-semibold text-white"><%= i.nama_barang %></p>
                                    <span class="text-[11px] text-slate-400"><%= i.nama_supplier %></span>
                                </div>
                                <div class="text-right">
                                    <span class="text-emerald-400 font-mono font-bold">+<%= i.jumlah %> Pcs</span>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>

            <div class="print-card bg-[#161b22] border border-[#30363d] rounded-xl overflow-hidden shadow-md">
                <div class="p-4 bg-rose-950/20 border-b border-[#30363d]">
                    <h4 class="text-xs font-bold text-rose-400 uppercase tracking-wider">📤 Barang Keluar (Outbound)</h4>
                </div>
                <div class="p-4 text-xs space-y-3">
                    <% if (typeof outbound === 'undefined' || outbound.length === 0) { %>
                        <p class="text-slate-500 italic text-center py-4">Tidak ada transaksi keluar hari ini.</p>
                    <% } else { %>
                        <% outbound.forEach(o => { %>
                            <div class="flex justify-between items-center bg-[#12161f]/40 p-3 rounded-lg border border-[#30363d]/50">
                                <div>
                                    <p class="font-semibold text-white"><%= o.nama_barang %></p>
                                    <span class="text-[11px] text-slate-400">Pembeli: <%= o.nama_pembeli || 'Pelanggan' %></span>
                                </div>
                                <div class="text-right">
                                    <span class="text-rose-400 font-mono font-bold">-${o.jumlah} Pcs</span>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>

    </main>
</body>
</html>
