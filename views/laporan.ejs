<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laporan Gudang - InvenioWeb</title>
    <link class="no-print" rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0c1017; /* Warna background utama gelap dashboard */
        }
        input[type="number"] {
            appearance: textfield;
            -moz-appearance: textfield;
        }
        input[type="number"]::-webkit-outer-spin-button,
        input[type="number"]::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        
        /* === PERBAIKAN UTUK CETAK / PRINT MODE === */
        @media print {
            .no-print {
                display: none !important;
            }
            body {
                background-color: #ffffff !important;
                color: #111827 !important;
            }
            .print-card {
                background-color: #ffffff !important;
                border: 1px solid #d1d5db !important;
                box-shadow: none !important;
                color: #111827 !important;
                page-break-inside: avoid; /* Mencegah card terpotong di tengah halaman */
                margin-bottom: 1.5rem;
            }
            .text-white, .text-slate-200, .text-slate-300 { 
                color: #111827 !important; 
            }
            .text-slate-400, .text-slate-500 { 
                color: #4b5563 !important; 
            }
            
            /* Optimasi Kontras Warna Khusus Teks Mutasi Saat Di-print */
            .text-amber-500 {
                color: #b45309 !important; /* Kuning cerah jadi Cokelat/Oranye Tua */
            }
            .text-rose-400, .text-rose-500 {
                color: #9f1239 !important; /* Merah muda jadi Merah Marun Tua */
            }
            .text-cyan-400 {
                color: #0369a1 !important; /* Cyan cerah jadi Biru Tua */
            }
            
            /* Reset Background Utility Tailwind */
            [class*="bg-"] { 
                background-color: transparent !important; 
            }
            [class*="border-"] { 
                border-color: #e5e7eb !important; 
            }

            /* Struktur Tabel Formal */
            thead tr {
                background-color: #f3f4f6 !important;
                border-bottom: 2px solid #d1d5db !important;
            }
            th {
                color: #111827 !important;
                font-weight: 700 !important;
            }
            td {
                border-bottom: 1px solid #e5e7eb !important;
            }
        }
    </style>
</head>
<body class="text-slate-300 min-h-screen flex flex-col md:flex-row antialiased">

    <div class="no-print hidden md:flex w-64 bg-[#12161f] border-r border-[#1f242e] p-4 flex-col justify-between shrink-0 min-h-screen sticky top-0">
        <div>
            <div class="flex items-center gap-3 px-2 py-4 border-b border-[#1f242e] mb-6">
                <div class="w-10 h-10 bg-cyan-500 rounded-lg flex items-center justify-center text-slate-900 font-bold text-xl shadow-md">
                    IW
                </div>
                <div>
                    <h1 class="text-white font-bold tracking-wide text-sm">InvenioWeb</h1>
                    <span class="text-[11px] text-cyan-400 font-semibold tracking-wider uppercase block">Market System</span>
                </div>
            </div>
            
            <nav class="space-y-1">
                <a href="/dashboard" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-chart-pie w-5 text-center"></i> <span>Dashboard</span>
                </a>
                <a href="/barang" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-box w-5 text-center"></i> <span>Kelola Barang</span>
                </a>
                <a href="/supplier" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-truck w-5 text-center"></i> <span>Kelola Supplier</span>
                </a>
                <a href="/transaksi" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-exchange-alt w-5 text-center"></i> <span>Kelola Transaksi</span>
                </a>
                <a href="/laporan" class="flex items-center gap-3 px-4 py-2.5 bg-[#1c212c] text-white border-l-4 border-cyan-500 rounded-r-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-file-invoice-dollar w-5 text-center text-cyan-400"></i> <span>Cetak Laporan</span>
                </a>
                <a href="/barang-terjual" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-receipt w-5 text-center"></i> <span>Barang Terjual</span>
                </a>
                <% if (user.role === 'admin') { %>
                <a href="/admin/users" class="flex items-center gap-3 px-4 py-2.5 text-red-400 hover:bg-red-950/20 hover:text-red-300 rounded-lg text-sm font-medium transition duration-150 mt-4">
                    <i class="fa-solid fa-users-cog w-5 text-center"></i> <span>Kelola User</span>
                </a>
                <% } %>
            </nav>
        </div>
        
        <div class="bg-[#171b26] p-3 rounded-xl border border-[#222834] flex items-center justify-between">
            <div class="flex items-center gap-2.5">
                <div class="w-8 h-8 bg-purple-600 rounded-full flex items-center justify-center text-white text-xs font-bold uppercase">
                    <%= user.nama.substring(0,2) %>
                </div>
                <div class="leading-tight">
                    <p class="text-white text-xs font-semibold truncate max-w-[100px]"><%= user.nama %></p>
                    <span class="text-[10px] text-purple-400 font-medium capitalize"><%= user.role %></span>
                </div>
            </div>
            <a href="/logout" class="text-slate-500 hover:text-red-400 text-xs transition-colors" title="Log Out">
                <i class="fa-solid fa-sign-out-alt"></i>
            </a>
        </div>
    </div>

    <div class="no-print md:hidden bg-[#12161f] border-b border-[#1f242e] p-4 w-full">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-2">
                <div class="bg-cyan-500 rounded-lg p-1 w-8 h-8 flex items-center justify-center text-slate-900 font-bold text-sm">
                    IW
                </div>
                <span class="font-bold text-sm tracking-tight text-white">InvenioWeb</span>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-xs text-slate-400 font-medium"><%= user.nama %></span>
                <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition"><i class="fa-solid fa-sign-out-alt"></i></a>
            </div>
        </div>
        <nav class="flex flex-wrap gap-1.5">
            <a href="/dashboard" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Dashboard</a>
            <a href="/barang" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Barang</a>
            <a href="/supplier" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Supplier</a>
            <a href="/transaksi" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Transaksi</a>
            <a href="/laporan" class="px-3 py-1.5 bg-sky-500/20 text-sky-400 border border-sky-500/30 rounded-md text-xs font-medium">Laporan</a>
            <a href="/barang-terjual" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Barang Terjual</a>
        </nav>
    </div>

    <main class="flex-1 p-6 md:p-8 overflow-y-auto w-full space-y-6">
        
        <header class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <h1 class="text-xl md:text-2xl font-bold tracking-tight text-white">Laporan Mutasi & Akumulasi Stok Gudang</h1>
                <p class="text-slate-400 text-xs mt-1">Sistem rekapitulasi data komoditas internal logistik gudang.</p>
            </div>
            <button onclick="window.print()" class="no-print bg-[#0ea5e9] hover:bg-[#0284c7] text-white font-semibold text-xs px-4 py-2.5 rounded-lg flex items-center gap-2 transition duration-150 shrink-0 shadow-md">
                <i class="fa-solid fa-print"></i> Cetak Laporan Gudang
            </button>
        </header>

        <div class="print-card bg-[#161b22] border border-[#30363d] rounded-xl overflow-hidden shadow-md">
            <div class="flex items-center gap-2 p-4 border-b border-[#30363d] bg-[#1f242e]/30">
                <h2 class="text-xs font-bold text-cyan-400 uppercase tracking-wider">📊 Laporan Akumulasi Komoditas Gudang (Tahunan)</h2>
            </div>
            <div class="overflow-x-auto w-full">
                <table class="w-full text-left border-collapse text-xs">
                    <thead>
                        <tr class="bg-[#12161f]/50 text-slate-400 uppercase tracking-wider border-b border-[#30363d] font-semibold">
                            <th class="p-4">Nama Produk</th>
                            <th class="p-4">Mitra Penyuplai (Supplier)</th>
                            <th class="p-4 text-center">Stok Terkini</th>
                            <th class="p-4 text-right">Harga Satuan</th>
                            <th class="p-4 text-center no-print">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#30363d]/60 text-slate-300">
                        <% if (typeof rawBarang === 'undefined' || rawBarang.length === 0) { %>
                            <tr>
                                <td colspan="5" class="p-8 text-center text-slate-500 italic">Belum ada data akumulasi barang master.</td>
                            </tr>
                        <% } else { %>
                            <% rawBarang.forEach(g => { %>
                                <tr class="hover:bg-[#1f242e]/20 transition duration-150">
                                    <td class="p-4 font-semibold text-white"><%= g.nama_barang %></td>
                                    <td class="p-4 text-slate-400"><%= g.nama_supplier %></td>
                                    <td class="p-4 text-center font-bold font-mono text-slate-200"><%= g.stok %> Pcs</td>
                                    <td class="p-4 text-right font-mono text-slate-300">Rp <%= g.harga.toLocaleString('id-ID') %></td>
                                    <td class="p-4 text-center space-x-3 no-print">
                                        <button onclick="openModalBarang('<%= g.id_barang %>', '<%= g.nama_barang %>', '<%= g.stok %>', '<%= g.harga %>')" class="text-cyan-400 hover:text-cyan-300 font-medium transition">✏️ Edit</button>
                                        <a href="/laporan/barang/hapus/<%= g.id_barang %>" onclick="return confirm('⚠️ HAPUS BARANG MASTER?\nSeluruh riwayat transaksi barang ini juga akan ikut dihapus secara permanen!')" class="text-rose-400 hover:text-rose-300 font-medium transition">🗑️ Hapus</a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="space-y-4">
            <h2 class="text-xs font-bold text-slate-400 border-b border-[#30363d] pb-2 flex items-center gap-2 uppercase tracking-wider">📋 Riwayat Mutasi Harian</h2>
            
            <% if (typeof laporanPerHari === 'undefined' || Object.keys(laporanPerHari).length === 0) { %>
                <div class="bg-[#161b22] border border-[#30363d] p-6 text-center text-slate-500 italic rounded-xl">
                    Belum ada riwayat aktivitas transaksi masuk atau keluar di dalam sistem.
                </div>
            <% } else { %>
                <% Object.keys(laporanPerHari).forEach(tanggal => { %>
                    <div class="print-card bg-[#161b22] border border-[#30363d] rounded-xl overflow-hidden shadow-md">
                        
                        <div class="flex items-center justify-between p-3.5 bg-[#1f242e]/50 border-b border-[#30363d]">
                            <h3 class="text-xs font-bold text-slate-200 flex items-center gap-2">
                                🗓️ Laporan Hari: <span class="text-cyan-400"><%= new Date(tanggal).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                            </h3>
                            <span class="text-[11px] bg-[#12161f] border border-[#30363d]/60 text-slate-400 px-2 py-0.5 rounded font-mono font-medium"><%= tanggal %></span>
                        </div>

                        <div class="p-4 grid grid-cols-1 lg:grid-cols-2 gap-4 bg-[#161b22]/20">
                            
                            <div class="bg-[#12161f] p-4 rounded-xl border border-[#30363d]/60 overflow-hidden print-card">
                                <div class="flex items-center gap-1.5 mb-3 border-b border-[#30363d]/40 pb-2">
                                    <h4 class="text-[11px] font-bold text-amber-500 uppercase tracking-wider">📥 Barang Masuk (Inbound)</h4>
                                </div>
                                <div class="overflow-x-auto w-full">
                                    <table class="w-full text-xs text-left border-collapse">
                                        <thead>
                                            <tr class="border-b border-[#30363d]/40 text-slate-500 font-semibold uppercase tracking-wider">
                                                <th class="pb-2">Nama Produk</th>
                                                <th class="pb-2">Mitra Penyuplai</th>
                                                <th class="pb-2 text-center">Jumlah</th>
                                                <th class="pb-2 text-center no-print">Aksi</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-[#30363d]/30 text-slate-300">
                                            <% if (laporanPerHari[tanggal].masuk.length === 0) { %>
                                                <tr><td colspan="4" class="py-4 text-center text-slate-600 italic">Tidak ada transaksi masuk.</td></tr>
                                            <% } else { %>
                                                <% laporanPerHari[tanggal].masuk.forEach(bm => { %>
                                                    <tr class="hover:bg-[#1c212c]/30 transition">
                                                        <td class="py-2.5 font-medium text-white"><%= bm.nama_barang %></td>
                                                        <td class="py-2.5 text-slate-400"><%= bm.nama_supplier %></td>
                                                        <td class="py-2.5 text-center text-amber-500 font-bold font-mono">+<%= bm.jumlah %> Pcs</td>
                                                        <td class="py-2.5 text-center space-x-2 font-medium no-print">
                                                            <button onclick="openModalEdit('<%= bm.id_transaksi %>', '<%= bm.jumlah %>', '<%= tanggal %>')" class="text-cyan-400 hover:text-cyan-300 transition">Edit</button>
                                                            <a href="/laporan/hapus/<%= bm.id_transaksi %>" onclick="return confirm('Hapus record ini?')" class="text-rose-400 hover:text-rose-300 transition">Hapus</a>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="bg-[#12161f] p-4 rounded-xl border border-[#30363d]/60 overflow-hidden print-card">
                                <div class="flex items-center gap-1.5 mb-3 border-b border-[#30363d]/40 pb-2">
                                    <h4 class="text-[11px] font-bold text-rose-500 uppercase tracking-wider">📤 Barang Keluar (Outbound)</h4>
                                </div>
                                <div class="overflow-x-auto w-full">
                                    <table class="w-full text-xs text-left border-collapse">
                                        <thead>
                                            <tr class="border-b border-[#30363d]/40 text-slate-500 font-semibold uppercase tracking-wider">
                                                <th class="pb-2">Nama Produk</th>
                                                <th class="pb-2">Mitra Penyuplai</th>
                                                <th class="pb-2 text-center">Jumlah</th>
                                                <th class="pb-2 text-center no-print">Aksi</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-[#30363d]/30 text-slate-300">
                                            <% if (laporanPerHari[tanggal].keluar.length === 0) { %>
                                                <tr><td colspan="4" class="py-4 text-center text-slate-600 italic">Tidak ada transaksi keluar.</td></tr>
                                            <% } else { %>
                                                <% laporanPerHari[tanggal].keluar.forEach(bk => { %>
                                                    <tr class="hover:bg-[#1c212c]/30 transition">
                                                        <td class="py-2.5 font-medium text-white"><%= bk.nama_barang %></td>
                                                        <td class="py-2.5 text-slate-400"><%= bk.nama_supplier %></td>
                                                        <td class="py-2.5 text-center text-rose-400 font-bold font-mono">-<%= bk.jumlah %> Pcs</td>
                                                        <td class="py-2.5 text-center space-x-2 font-medium no-print">
                                                            <button onclick="openModalEdit('<%= bk.id_transaksi %>', '<%= bk.jumlah %>', '<%= tanggal %>')" class="text-cyan-400 hover:text-cyan-300 transition">Edit</button>
                                                            <a href="/laporan/hapus/<%= bk.id_transaksi %>" onclick="return confirm('Hapus record ini?')" class="text-rose-400 hover:text-rose-300 transition">Hapus</a>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>

    </main>

    <div id="modalBarang" class="no-print hidden fixed inset-0 bg-black/70 backdrop-blur-sm flex items-center justify-center p-4 z-50">
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-5 w-full max-w-md shadow-2xl space-y-4">
            <div class="flex items-center gap-2 border-b border-[#30363d] pb-3">
                <h3 class="text-sm font-bold text-white">✏️ Edit Master Barang Gudang</h3>
            </div>
            <form id="formBarang" method="POST" class="space-y-4 text-xs">
                <div>
                    <label class="block text-slate-400 mb-1 font-medium">Nama Barang / Produk</label>
                    <input type="text" id="barangNama" name="nama_barang" class="w-full bg-[#12161f] border border-[#30363d] rounded-lg p-2.5 text-white focus:border-cyan-500 outline-none transition" required>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-slate-400 mb-1 font-medium">Stok Gudang (Pcs)</label>
                        <input type="number" id="barangStok" name="stok" class="w-full bg-[#12161f] border border-[#30363d] rounded-lg p-2.5 text-white focus:border-cyan-500 outline-none transition" required>
                    </div>
                    <div>
                        <label class="block text-slate-400 mb-1 font-medium">Harga Satuan (Rp)</label>
                        <input type="number" id="barangHarga" name="harga" class="w-full bg-[#12161f] border border-[#30363d] rounded-lg p-2.5 text-white focus:border-cyan-500 outline-none transition" required>
                    </div>
                </div>
                <div class="flex justify-end gap-2 pt-2 border-t border-[#30363d]">
                    <button type="button" onclick="closeModalBarang()" class="px-4 py-2 bg-slate-800 text-slate-400 hover:text-white rounded-lg transition font-medium">Batal</button>
                    <button type="submit" class="px-4 py-2 bg-cyan-600 text-white font-semibold rounded-lg hover:bg-cyan-500 transition">Simpan Data</button>
                </div>
            </form>
        </div>
    </div>

    <div id="modalEdit" class="no-print hidden fixed inset-0 bg-black/70 backdrop-blur-sm flex items-center justify-center p-4 z-50">
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-5 w-full max-w-sm shadow-2xl space-y-4">
            <div class="flex items-center gap-2 border-b border-[#30363d] pb-3">
                <h3 class="text-sm font-bold text-white">✏️ Edit Jumlah Kuantitas Transaksi</h3>
            </div>
            <form id="formEdit" method="POST" class="space-y-4 text-xs">
                <div>
                    <label class="block text-slate-400 mb-1 font-medium">Jumlah/Kuantitas Baru</label>
                    <input type="number" id="inputJumlah" name="jumlah_baru" min="1" class="w-full bg-[#12161f] border border-[#30363d] rounded-lg p-2.5 text-white focus:border-cyan-500 outline-none transition" required>
                </div>
                <div>
                    <label class="block text-slate-400 mb-1 font-medium">Tanggal Transaksi</label>
                    <input type="date" id="inputTanggal" name="tanggal_baru" class="w-full bg-[#12161f] border border-[#30363d] rounded-lg p-2.5 text-white focus:border-cyan-500 outline-none transition text-slate-300" required>
                </div>
                <div class="flex justify-end gap-2 pt-2 border-t border-[#30363d]">
                    <button type="button" onclick="closeModalEdit()" class="px-4 py-2 bg-slate-800 text-slate-400 hover:text-white rounded-lg transition font-medium">Batal</button>
                    <button type="submit" class="px-4 py-2 bg-cyan-600 text-white font-semibold rounded-lg hover:bg-cyan-500 transition">Simpan Perubahan</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openModalBarang(id, nama, stok, harga) {
            document.getElementById('formBarang').action = '/laporan/barang/edit/' + id;
            document.getElementById('barangNama').value = nama;
            document.getElementById('barangStok').value = stok;
            document.getElementById('barangHarga').value = harga;
            document.getElementById('modalBarang').classList.remove('hidden');
        }
        function closeModalBarang() {
            document.getElementById('modalBarang').classList.add('hidden');
        }
        function openModalEdit(id, jumlah, tanggal) {
            document.getElementById('formEdit').action = '/laporan/edit/' + id;
            document.getElementById('inputJumlah').value = jumlah;
            
            if (tanggal) {
                const dateObj = new Date(tanggal);
                if (!isNaN(dateObj.getTime())) {
                    const formattedDate = dateObj.toISOString().split('T')[0];
                    document.getElementById('inputTanggal').value = formattedDate;
                } else {
                    document.getElementById('inputTanggal').value = tanggal;
                }
            }
            
            document.getElementById('modalEdit').classList.remove('hidden');
        }
        function closeModalEdit() {
            document.getElementById('modalEdit').classList.add('hidden');
        }
    </script>
</body>
</html>
