<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laporan Gudang - InvenioWeb</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0b0f19;
        }
        /* CSS Khusus untuk menangani layouting saat cetak printer/pdf */
        @media print {
            .no-print {
                display: none !important;
            }
            body, .main-content {
                background: white !important;
                color: black !important;
                padding: 0 !important;
                margin: 0 !important;
            }
            .print-container {
                width: 100% !important;
                max-width: 100% !important;
                position: absolute;
                left: 0;
                top: 0;
            }
            .print-card {
                border: 1px solid #d4d4d8 !important;
                background-color: transparent !important;
                box-shadow: none !important;
                color: black !important;
            }
            .text-white { color: #000000 !important; }
            .text-zinc-400, .text-zinc-300 { color: #3f3f46 !important; }
            .bg-zinc-950 { background-color: #f4f4f5 !important; border-bottom: 2px solid #000 !important; }
            .bg-slate-900\/40 { background: transparent !important; }
        }
    </style>
</head>
<body class="text-zinc-100 min-h-screen flex">

    <aside class="no-print w-64 bg-[#0d121f] border-r border-zinc-800 flex flex-col justify-between p-5 shrink-0 fixed h-full">
        <div class="space-y-8">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center font-bold text-white shadow-lg shadow-blue-500/20">IWS</div>
                <span class="text-lg font-bold tracking-tight text-white">InvenioWeb</span>
            </div>
            <nav class="space-y-1">
                <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/40 rounded-xl text-sm transition-all">📋 Dashboard</a>
                <a href="/kelola-barang" class="flex items-center gap-3 px-4 py-3 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/40 rounded-xl text-sm transition-all">📦 Kelola Barang</a>
                <a href="/kelola-supplier" class="flex items-center gap-3 px-4 py-3 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/40 rounded-xl text-sm transition-all">🤝 Kelola Supplier</a>
                <a href="/kelola-transaksi" class="flex items-center gap-3 px-4 py-3 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/40 rounded-xl text-sm transition-all">⚙️ Kelola Transaksi</a>
                <a href="/cetak-laporan" class="flex items-center gap-3 px-4 py-3 bg-blue-600 text-white font-semibold rounded-xl text-sm transition-all shadow-lg shadow-blue-600/10">📊 Cetak Laporan</a>
                <a href="/barang-terjual" class="flex items-center gap-3 px-4 py-3 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/40 rounded-xl text-sm transition-all">🛒 Barang Terjual</a>
                <a href="/kelola-user" class="flex items-center gap-3 px-4 py-3 text-red-400/80 hover:text-red-400 hover:bg-red-500/5 rounded-xl text-sm transition-all">👤 Kelola User</a>
            </nav>
        </div>
        <div class="border-t border-zinc-800 pt-4 flex items-center justify-between">
            <div>
                <p class="text-xs text-zinc-500">Masuk sebagai</p>
                <p class="text-sm font-semibold text-zinc-200">Admin</p>
            </div>
            <a href="/logout" class="text-xs text-red-400 hover:underline">Logout</a>
        </div>
    </aside>

    <main class="main-content flex-1 md:pl-64 p-4 md:p-8 w-full">
        <div class="print-container max-w-5xl mx-auto space-y-8">
            
            <div class="flex justify-between items-center border-b border-zinc-800 pb-5">
                <div>
                    <h1 class="text-2xl font-bold text-white print:text-black">Laporan Mutasi & Akumulasi Stok Gudang</h1>
                    <p class="text-xs text-zinc-400 mt-1 print:text-zinc-700">Sistem rekapitulasi manajemen logistik internal dan sirkulasi gudang.</p>
                </div>
                <button onclick="window.print()" class="no-print bg-blue-600 hover:bg-blue-500 text-white font-semibold text-xs px-5 py-2.5 rounded-xl flex items-center gap-2 shadow-lg transition-all">
                    🖨️ Cetak Laporan Gudang
                </button>
            </div>

            <div class="print-card bg-slate-900/40 border border-zinc-800 rounded-2xl p-6 shadow-xl">
                <h2 class="text-xs font-bold text-blue-400 uppercase tracking-wider mb-4 print:text-blue-700">📊 Laporan Akumulasi Komoditas Gudang (Tahunan)</h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-xs text-zinc-300">
                        <thead class="bg-zinc-950 text-zinc-400 uppercase font-mono border-b border-zinc-800">
                            <tr>
                                <th class="p-3">Nama Produk</th>
                                <th class="p-3">Mitra Penyuplai (Supplier)</th>
                                <th class="p-3">Stok Terkini</th>
                                <th class="p-3 text-right">Harga Satuan</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-zinc-800/50 print:divide-zinc-300">
                            <% if (typeof komoditas !== 'undefined' && komoditas.length > 0) { %>
                                <% komoditas.forEach(item => { %>
                                    <tr class="hover:bg-zinc-900/30">
                                        <td class="p-3 font-medium text-white"><%= item.nama_barang %></td>
                                        <td class="p-3"><%= item.nama_supplier %></td>
                                        <td class="p-3 font-mono text-blue-400 font-bold"><%= item.stok %> Pcs</td>
                                        <td class="p-3 text-right font-mono">Rp <%= item.harga.toLocaleString('id-ID') %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="p-4 text-center text-zinc-500">Tidak ada data komoditas gudang ditemukan.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="print-card bg-slate-900/40 border border-zinc-800 rounded-2xl p-6 shadow-xl space-y-6">
                <h2 class="text-xs font-bold text-zinc-400 uppercase tracking-wider print:text-zinc-800">📋 Berkas Riwayat Mutasi Harian</h2>
                
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <div class="space-y-3">
                        <h3 class="text-xs font-bold text-emerald-400 uppercase tracking-wide">📥 Barang Masuk (Inbound)</h3>
                        <div class="border border-zinc-800 print:border-zinc-300 rounded-xl overflow-hidden bg-zinc-950/40">
                            <table class="w-full text-xs text-zinc-400">
                                <thead class="bg-zinc-950 text-zinc-500 border-b border-zinc-800 print:border-zinc-300">
                                    <tr>
                                        <th class="p-2.5 text-left">Nama Produk</th>
                                        <th class="p-2.5 text-left">Penyuplai</th>
                                        <th class="p-2.5 text-right">Jumlah</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-zinc-800/40 print:divide-zinc-300">
                                    <% if (typeof mutasiMasuk !== 'undefined' && mutasiMasuk.length > 0) { %>
                                        <% mutasiMasuk.forEach(m => { %>
                                            <tr>
                                                <td class="p-2.5 text-white"><%= m.nama_barang %></td>
                                                <td class="p-2.5"><%= m.nama_supplier %></td>
                                                <td class="p-2.5 text-right font-mono text-emerald-400 font-bold">+<%= m.jumlah %> Pcs</td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="3" class="p-3 text-center text-zinc-600">Kosong</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="space-y-3">
                        <h3 class="text-xs font-bold text-red-400 uppercase tracking-wide">📤 Barang Keluar (Outbound)</h3>
                        <div class="border border-zinc-800 print:border-zinc-300 rounded-xl overflow-hidden bg-zinc-950/40">
                            <table class="w-full text-xs text-zinc-400">
                                <thead class="bg-zinc-950 text-zinc-500 border-b border-zinc-800 print:border-zinc-300">
                                    <tr>
                                        <th class="p-2.5 text-left">Nama Produk</th>
                                        <th class="p-2.5 text-left">Penyuplai</th>
                                        <th class="p-2.5 text-right">Jumlah</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-zinc-800/40 print:divide-zinc-300">
                                    <% if (typeof mutasiKeluar !== 'undefined' && mutasiKeluar.length > 0) { %>
                                        <% mutasiKeluar.forEach(k => { %>
                                            <tr>
                                                <td class="p-2.5 text-white"><%= k.nama_barang %></td>
                                                <td class="p-2.5"><%= k.nama_supplier %></td>
                                                <td class="p-2.5 text-right font-mono text-red-400 font-bold">-<%= k.jumlah %> Pcs</td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="3" class="p-3 text-center text-zinc-600">Kosong</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </main>

</body>
</html>
