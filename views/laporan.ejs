<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laporan Gudang - InvenioWeb</title>
    <link class="no-print" rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
        input[type="number"] {
            appearance: textfield;
            -moz-appearance: textfield;
        }
        input[type="number"]::-webkit-outer-spin-button,
        input[type="number"]::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        @media print {
            .no-print {
                display: none !important;
            }
            body {
                background-color: white !important;
                color: black !important;
            }
            .print-card {
                background-color: transparent !important;
                border: 1px solid #d4d4d8 !important;
                box-shadow: none !important;
                color: black !important;
            }
            .text-white, .text-zinc-200, .text-zinc-300 { color: #000000 !important; }
            .text-zinc-400 { color: #27272a !important; }
            .bg-zinc-900, .bg-zinc-950, .bg-zinc-900\/50, .bg-zinc-900\/30 { background-color: transparent !important; }
            .border-zinc-800, .divide-zinc-800\/60, .divide-zinc-900 { border-color: #e4e4e7 !important; }
        }
    </style>
</head>
<body class="bg-zinc-950 text-white min-h-screen flex flex-col md:flex-row antialiased">

    <div class="no-print hidden md:flex w-64 bg-zinc-900 border-r border-zinc-800 p-6 flex-col justify-between shrink-0 min-h-screen sticky top-0">
        <div>
            <div class="flex items-center gap-3 mb-8 px-2">
                <div class="bg-[#5551ff] rounded-full p-1 shadow-lg shadow-[#5551ff]/20 flex items-center justify-center w-11 h-11 overflow-hidden shrink-0">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-full">
                </div>
                <span class="text-xl font-bold tracking-tight bg-gradient-to-r from-white via-zinc-200 to-zinc-400 bg-clip-text text-transparent drop-shadow-sm">
                    InvenioWeb
                </span>
            </div>
            
            <nav class="space-y-1.5">
                <a href="/dashboard" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Dashboard</a>
                <a href="/barang" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Kelola Barang</a>
                <a href="/supplier" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Kelola Supplier</a>
                <a href="/transaksi" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Kelola Transaksi</a>
                <a href="/laporan" class="block px-4 py-2.5 bg-[#5551ff] text-white rounded-xl text-sm font-medium transition-all duration-200 shadow-md shadow-[#5551ff]/10">Cetak Laporan</a>
                <a href="/barang-terjual" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Barang Terjual</a>
                <% if (user.role === 'admin') { %>
                    <a href="/admin/users" class="block px-4 py-2.5 text-red-400 hover:text-white hover:bg-red-900/30 rounded-xl text-sm font-medium transition border border-red-500/10 mt-4">Kelola User</a>
                <% } %>
            </nav>
        </div>
        
        <div class="border-t border-zinc-800 pt-4 flex items-center justify-between">
            <div>
                <p class="text-xs text-zinc-500">Masuk sebagai:</p>
                <p class="text-sm font-semibold text-zinc-200"><%= user.nama %></p>
                <div class="mt-1">
                    <span class="text-[10px] bg-[#5551ff]/20 text-indigo-400 px-2 py-0.5 rounded border border-[#5551ff]/30 font-medium capitalize"><%= user.role %></span>
                </div>
            </div>
            <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition shrink-0 ml-2">Logout</a>
        </div>
    </div>

    <div class="no-print md:hidden bg-zinc-900 border-b border-zinc-800 p-4">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="bg-[#5551ff] rounded-full p-0.5 flex items-center justify-center w-8 h-8 overflow-hidden shrink-0">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-full">
                </div>
                <span class="font-bold tracking-tight bg-gradient-to-r from-white via-zinc-200 to-zinc-400 bg-clip-text text-transparent drop-shadow-sm">
                    InvenioWeb
                </span>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-xs text-zinc-400"><%= user.nama %></span>
                <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition">Logout</a>
            </div>
        </div>
        <nav class="flex flex-wrap gap-2">
            <a href="/dashboard" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition">Dashboard</a>
            <a href="/barang" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition">Barang</a>
            <a href="/supplier" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition">Supplier</a>
            <a href="/transaksi" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition">Transaksi</a>
            <a href="/laporan" class="px-3 py-1.5 bg-[#5551ff] text-white rounded-lg text-xs font-medium shadow-md shadow-[#5551ff]/10">Laporan</a>
            <a href="/barang-terjual" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition">Barang Terjual</a>
        </nav>
    </div>

    <div class="flex-grow p-6 md:p-10 overflow-y-auto w-full space-y-8">
        
        <header class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-b border-zinc-800 pb-5">
            <div>
                <h1 class="text-2xl md:text-3xl font-bold tracking-tight">Laporan Mutasi & Akumulasi Stok Gudang</h1>
                <p class="text-zinc-400 text-sm mt-1">Sistem rekapitulasi data komoditas internal logistik gudang.</p>
            </div>
            <button onclick="window.print()" class="no-print bg-[#5551ff] hover:bg-[#433eff] text-white font-semibold text-xs px-5 py-3 rounded-xl flex items-center gap-2 shadow-lg transition-all duration-200 shrink-0">
                🖨️ Cetak Laporan Gudang
            </button>
        </header>

        <div class="print-card bg-zinc-900 border border-zinc-800 rounded-xl shadow-xl overflow-hidden">
            <div class="flex items-center gap-2 p-6 border-b border-zinc-800 bg-zinc-900/50">
                <span>📊</span>
                <h2 class="text-base font-bold text-[#5551ff]">Laporan Akumulasi Komoditas Gudang (Tahunan)</h2>
            </div>
            <div class="overflow-x-auto w-full">
                <table class="w-full text-left border-collapse text-sm">
                    <thead>
                        <tr class="border-b border-zinc-800 text-zinc-400 text-xs font-semibold uppercase tracking-wider bg-zinc-900/30">
                            <th class="p-4">Nama Produk</th>
                            <th class="p-4">Mitra Penyuplai (Supplier)</th>
                            <th class="p-4 text-center">Stok Terkini</th>
                            <th class="p-4">Harga Satuan</th>
                            <th class="p-4 text-center no-print">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-zinc-800/60 text-zinc-300">
                        <% if (typeof rawBarang === 'undefined' || rawBarang.length === 0) { %>
                            <tr>
                                <td colspan="5" class="p-8 text-center text-zinc-500 italic">Belum ada data akumulasi barang master.</td>
                            </tr>
                        <% } else { %>
                            <% rawBarang.forEach(g => { %>
                                <tr class="hover:bg-zinc-800/20 transition">
                                    <td class="p-4 font-medium text-white"><%= g.nama_barang %></td>
                                    <td class="p-4 text-zinc-400"><%= g.nama_supplier %></td>
                                    <td class="p-4 text-center font-bold font-mono <%= g.stok < 0 ? 'text-red-400 bg-red-500/5' : 'text-zinc-200' %>"><%= g.stok %> Pcs</td>
                                    <td class="p-4 font-mono text-zinc-300">Rp <%= g.harga.toLocaleString('id-ID') %></td>
                                    <td class="p-4 text-center space-x-3 text-xs no-print">
                                        <button onclick="openModalBarang('<%= g.id_barang %>', '<%= g.nama_barang %>', '<%= g.stok %>', '<%= g.harga %>')" class="text-indigo-400 hover:text-indigo-300 font-medium transition hover:underline">✏️ Edit</button>
                                        <a href="/laporan/barang/hapus/<%= g.id_barang %>" onclick="return confirm('⚠️ HAPUS BARANG MASTER?\nSeluruh riwayat transaksi barang ini juga akan ikut dihapus secara permanen!')" class="text-rose-400 hover:text-rose-300 font-medium transition hover:underline">🗑️ Hapus</a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="space-y-6">
            <h2 class="text-base font-bold text-zinc-400 border-b border-zinc-800 pb-2 flex items-center gap-2">🗓️ Riwayat Mutasi Harian</h2>
            
            <% if (typeof laporanPerHari === 'undefined' || Object.keys(laporanPerHari).length === 0) { %>
                <div class="bg-zinc-900/50 border border-zinc-800 p-8 text-center text-zinc-500 italic rounded-xl">
                    Belum ada riwayat aktivitas transaksi masuk atau keluar di dalam sistem.
                </div>
            <% } else { %>
                <% Object.keys(laporanPerHari).forEach(tanggal => { %>
                    <div class="print-card bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden shadow-md space-y-1">
                        <div class="flex items-center justify-between p-4 bg-zinc-900/80 border-b border-zinc-800/80">
                            <h3 class="text-sm font-bold text-zinc-200 flex items-center gap-2">
                                📅 Laporan Hari: <span class="text-indigo-400"><%= new Date(tanggal).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                            </h3>
                            <span class="text-xs bg-zinc-800 border border-zinc-700/50 text-zinc-400 px-2.5 py-1 rounded-md font-mono font-medium"><%= tanggal %></span>
                        </div>

                        <div class="p-4 grid grid-cols-1 lg:grid-cols-2 gap-6 bg-zinc-900/20">
                            
                            <div class="bg-zinc-950 p-4 rounded-xl border border-zinc-800/60 overflow-hidden print-card">
                                <div class="flex items-center gap-1.5 mb-3 border-b border-zinc-900 pb-2">
                                    <span>📥</span>
                                    <h4 class="text-xs font-bold text-amber-500 uppercase tracking-wider">Barang Masuk (Inbound)</h4>
                                </div>
                                <div class="overflow-x-auto w-full">
                                    <table class="w-full text-xs text-left border-collapse">
                                        <thead>
                                            <tr class="border-b border-zinc-800 text-zinc-500 font-semibold uppercase tracking-wider">
                                                <th class="pb-2">Nama Produk</th>
                                                <th class="pb-2">Mitra Penyuplai</th>
                                                <th class="pb-2 text-center">Jumlah</th>
                                                <th class="pb-2 text-center no-print">Aksi</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-zinc-900 text-zinc-300">
                                            <% if (laporanPerHari[tanggal].masuk.length === 0) { %>
                                                <tr><td colspan="4" class="py-4 text-center text-zinc-600 italic">Tidak ada transaksi masuk.</td></tr>
                                            <% } else { %>
                                                <% laporanPerHari[tanggal].masuk.forEach(bm => { %>
                                                    <tr class="hover:bg-zinc-900/50 transition">
                                                        <td class="py-2.5 font-medium text-white"><%= bm.nama_barang %></td>
                                                        <td class="py-2.5 text-zinc-400"><%= bm.nama_supplier %></td>
                                                        <td class="py-2.5 text-center text-amber-400 font-bold font-mono">+<%= bm.jumlah %> Pcs</td>
                                                        <td class="py-2.5 text-center space-x-2 font-medium no-print">
                                                            <button onclick="openModalEdit('<%= bm.id_transaksi %>', '<%= bm.jumlah %>', '<%= tanggal %>')" class="text-indigo-400 hover:text-indigo-300 transition hover:underline">Edit</button>
                                                            <a href="/laporan/hapus/<%= bm.id_transaksi %>" onclick="return confirm('Hapus record ini? Stok gudang akan otomatis disesuaikan kembali.')" class="text-rose-400 hover:text-rose-300 transition hover:underline">Hapus</a>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="bg-zinc-950 p-4 rounded-xl border border-zinc-800/60 overflow-hidden print-card">
                                <div class="flex items-center gap-1.5 mb-3 border-b border-zinc-900 pb-2">
                                    <span>📤</span>
                                    <h4 class="text-xs font-bold text-rose-500 uppercase tracking-wider">Barang Keluar (Outbound)</h4>
                                </div>
                                <div class="overflow-x-auto w-full">
                                    <table class="w-full text-xs text-left border-collapse">
                                        <thead>
                                            <tr class="border-b border-zinc-800 text-zinc-500 font-semibold uppercase tracking-wider">
                                                <th class="pb-2">Nama Produk</th>
                                                <th class="pb-2">Mitra Penyuplai</th>
                                                <th class="pb-2 text-center">Jumlah</th>
                                                <th class="pb-2 text-center no-print">Aksi</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-zinc-900 text-zinc-300">
                                            <% if (laporanPerHari[tanggal].keluar.length === 0) { %>
                                                <tr><td colspan="4" class="py-4 text-center text-zinc-600 italic">Tidak ada transaksi keluar.</td></tr>
                                            <% } else { %>
                                                <% laporanPerHari[tanggal].keluar.forEach(bk => { %>
                                                    <tr class="hover:bg-zinc-900/50 transition">
                                                        <td class="py-2.5 font-medium text-white"><%= bk.nama_barang %></td>
                                                        <td class="py-2.5 text-zinc-400"><%= bk.nama_supplier %></td>
                                                        <td class="py-2.5 text-center text-rose-400 font-bold font-mono">-<%= bk.jumlah %> Pcs</td>
                                                        <td class="py-2.5 text-center space-x-2 font-medium no-print">
                                                            <button onclick="openModalEdit('<%= bk.id_transaksi %>', '<%= bk.jumlah %>', '<%= tanggal %>')" class="text-indigo-400 hover:text-indigo-300 transition hover:underline">Edit</button>
                                                            <a href="/laporan/hapus/<%= bk.id_transaksi %>" onclick="return confirm('Hapus record ini? Stok gudang akan otomatis disesuaikan kembali.')" class="text-rose-400 hover:text-rose-300 transition hover:underline">Hapus</a>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>

    </div>

    <div id="modalBarang" class="no-print hidden fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center p-4 z-50 transition-all duration-300">
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 w-full max-w-md shadow-2xl space-y-4">
            <div class="flex items-center gap-2 border-b border-zinc-800 pb-3">
                <span class="text-xl">✏️</span>
                <h3 class="text-base font-bold text-white">Edit Master Barang Gudang</h3>
            </div>
            <form id="formBarang" method="POST" class="space-y-4">
                <div>
                    <label class="block text-xs text-zinc-400 mb-1 font-medium">Nama Barang / Produk</label>
                    <input type="text" id="barangNama" name="nama_barang" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm text-white focus:border-indigo-500 outline-none transition" required>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs text-zinc-400 mb-1 font-medium">Stok Gudang (Pcs)</label>
                        <input type="number" id="barangStok" name="stok" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm text-white focus:border-indigo-500 outline-none transition" required>
                    </div>
                    <div>
                        <label class="block text-xs text-zinc-400 mb-1 font-medium">Harga Satuan (Rp)</label>
                        <input type="number" id="barangHarga" name="harga" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm text-white focus:border-indigo-500 outline-none transition" required>
                    </div>
                </div>
                <div class="flex justify-end gap-2 pt-2 border-t border-zinc-800">
                    <button type="button" onclick="closeModalBarang()" class="px-4 py-2 bg-zinc-800 text-xs font-semibold text-zinc-400 hover:text-white rounded-lg transition">Batal</button>
                    <button type="submit" class="px-4 py-2 bg-indigo-600 text-xs text-white font-semibold rounded-lg hover:bg-indigo-500 transition shadow-md shadow-indigo-900/20">Simpan Data</button>
                </div>
            </form>
        </div>
    </div>

    <div id="modalEdit" class="no-print hidden fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center p-4 z-50 transition-all duration-300">
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 w-full max-w-sm shadow-2xl space-y-4">
            <div class="flex items-center gap-2 border-b border-zinc-800 pb-3">
                <span class="text-xl">✏️</span>
                <h3 class="text-base font-bold text-white">Edit Jumlah Kuantitas Transaksi</h3>
            </div>
            <form id="formEdit" method="POST" class="space-y-4">
                <div>
                    <label class="block text-xs text-zinc-400 mb-1 font-medium">Jumlah/Kuantitas Baru</label>
                    <input type="number" id="inputJumlah" name="jumlah_baru" min="1" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm text-white focus:border-indigo-500 outline-none transition" required>
                </div>
                <div>
                    <label class="block text-xs text-zinc-400 mb-1 font-medium">Tanggal Transaksi</label>
                    <input type="date" id="inputTanggal" name="tanggal_baru" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm text-white focus:border-indigo-500 outline-none transition text-zinc-300" required>
                </div>
                <div class="flex justify-end gap-2 pt-2 border-t border-zinc-800">
                    <button type="button" onclick="closeModalEdit()" class="px-4 py-2 bg-zinc-800 text-xs font-semibold text-zinc-400 hover:text-white rounded-lg transition">Batal</button>
                    <button type="submit" class="px-4 py-2 bg-indigo-600 text-xs text-white font-semibold rounded-lg hover:bg-indigo-500 transition shadow-md shadow-indigo-900/20">Simpan Perubahan</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openModalBarang(id, nama, stok, harga) {
            document.getElementById('formBarang').action = '/laporan/barang/edit/' + id;
            document.getElementById('barangNama').value = nama;
            document.getElementById('barangStok').value = stok;
            document.getElementById('barangHarga').value = harga;
            document.getElementById('modalBarang').classList.remove('hidden');
        }
        function closeModalBarang() {
            document.getElementById('modalBarang').classList.add('hidden');
        }
        function openModalEdit(id, jumlah, tanggal) {
            document.getElementById('formEdit').action = '/laporan/edit/' + id;
            document.getElementById('inputJumlah').value = jumlah;
            
            // Format tanggal agar kompatibel dengan input type="date" (YYYY-MM-DD)
            if (tanggal) {
                const dateObj = new Date(tanggal);
                if (!isNaN(dateObj.getTime())) {
                    const formattedDate = dateObj.toISOString().split('T')[0];
                    document.getElementById('inputTanggal').value = formattedDate;
                } else {
                    document.getElementById('inputTanggal').value = tanggal;
                }
            }
            
            document.getElementById('modalEdit').classList.remove('hidden');
        }
        function closeModalEdit() {
            document.getElementById('modalEdit').classList.add('hidden');
        }
    </script>
</body>
</html>
