<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign in - InvenioWeb</title>
    <link rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Efek background radial gradient halus seperti pada gambar */
        body {
            background: radial-gradient(circle at 80% 20%, #13111c 0%, #09090b 60%);
        }
    </style>
</head>
<body class="text-zinc-200 flex items-center justify-center min-h-screen p-4 font-sans antialiased">

    <!-- CARD UTAMA -->
    <div class="bg-[#121115] border border-zinc-800/40 p-10 rounded-2xl w-full max-w-[460px] shadow-2xl">
        
        <!-- LOGO & HEADER -->
        <div class="flex items-center gap-3 mb-8">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-tr from-purple-500 via-indigo-500 to-pink-500 flex items-center justify-center font-bold text-white text-base shadow-lg shadow-indigo-500/10">I</div>
            <span class="font-semibold text-zinc-400 text-sm tracking-wide">InvenioWeb</span>
        </div>

        <h1 class="text-3xl font-bold tracking-tight text-white mb-8">Sign in to IWS</h1>

        <!-- NOTIFIKASI ERROR -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="bg-rose-500/10 border border-rose-500/20 text-rose-400 p-3 rounded-lg text-xs mb-4 text-center">
                <%= error %>
            </div>
        <% } %>

        <!-- FORM LOGIN -->
        <form action="/login" method="POST" class="space-y-5">
            
            <!-- INPUT USERNAME -->
            <div>
                <label class="block text-xs font-semibold text-zinc-400 mb-2">Username / Email</label>
                <input type="text" name="username" 
                       class="w-full bg-[#18171c] border border-zinc-800/80 rounded-lg p-3 text-sm text-white placeholder-zinc-600 outline-none focus:border-zinc-700 transition" 
                       placeholder="Masukkan username Anda..." required>
            </div>
            
            <!-- INPUT PASSWORD (DENGAN TOMBOL MATA) -->
            <div>
                <label class="block text-xs font-semibold text-zinc-400 mb-2">Password</label>
                <div class="relative">
                    <input type="password" id="passwordInput" name="password" 
                           class="w-full bg-[#18171c] border border-zinc-800/80 rounded-lg p-3 pr-12 text-sm text-white placeholder-zinc-600 outline-none focus:border-zinc-700 transition" 
                           placeholder="••••••••" required>
                    
                    <!-- TOMBOL MATA INTERAKTIF -->
                    <button type="button" onclick="togglePassword()" 
                            class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-zinc-500 hover:text-zinc-300 transition focus:outline-none">
                        <!-- Ikon Mata Terbuka -->
                        <svg id="eyeOpen" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0Z" />
                        </svg>
                        <!-- Ikon Mata Tertutup (Hidden di awal) -->
                        <svg id="eyeClose" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 hidden">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 01-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 11-4.243-4.243m4.242 4.242L9.88 9.88" />
                        </svg>
                    </button>
                </div>
            </div>

            <!-- TOMBOL LOG IN GRADIENT -->
            <button type="submit" 
                    class="w-full bg-gradient-to-r from-[#ffebd2] via-[#f7a2c4] to-[#f472b6] text-black font-bold uppercase tracking-wider text-xs py-3.5 rounded-lg hover:opacity-90 transition shadow-lg mt-2">
                LOG IN
            </button>
        </form>

        <!-- PEMISAH OR -->
        <div class="relative flex py-5 items-center my-2">
            <div class="flex-grow border-t border-zinc-800/60"></div>
            <span class="flex-shrink mx-4 text-zinc-600 text-xs tracking-widest font-medium">OR</span>
            <div class="flex-grow border-t border-zinc-800/60"></div>
        </div>

       <!-- GANTI BAGIAN DI BAWAH INI -->
        <div class="flex gap-4"> 
            <!-- Hapus tombol Google dan GitHub yang lama, lalu PASTE kode tombol baru di sini -->
            <a href="/register" class="w-full block text-center bg-gradient-to-r from-[#FFE5D9] via-[#FA93B4] to-[#F15BB5] text-black font-bold py-3 px-4 rounded-xl hover:opacity-90 transition duration-200 uppercase tracking-wider text-sm">
                Create New Account
            </a>
        </div>

        <!-- FOOTER BAWAH -->
        <div class="flex justify-center gap-4 text-xs text-zinc-600 font-medium">
            <a href="#" class="hover:text-zinc-400 transition">Terms of Use</a>
            <span>|</span>
            <a href="#" class="hover:text-zinc-400 transition">Privacy Policy</a>
        </div>
    </div>

    <!-- SCRIPT LOGIKA MATA -->
    <script>
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const eyeOpen = document.getElementById('eyeOpen');
            const eyeClose = document.getElementById('eyeClose');

            if (input.type === 'password') {
                input.type = 'text';
                eyeOpen.classList.add('hidden');
                eyeClose.classList.remove('hidden');
            } else {
                input.type = 'password';
                eyeOpen.classList.remove('hidden');
                eyeClose.classList.add('hidden');
            }
        }
    </script>
</body>
</html>
