<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>InvenioWeb Market System</title>
    <link rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* --- CORE BACKGROUND --- */
        body {
            position: relative;
            overflow-x: hidden;
            background-color: #020617; /* Gelap pekat agar kontras bintang & salju tajam */
        }

        /* --- 1. EFEK BINTANG BERGERAK (GALAXY DRIFT) --- */
        body::before {
            content: "";
            position: fixed;
            width: 200vw;
            height: 200vh;
            top: -50vh;
            left: -50vw;
            background-image: 
                radial-gradient(circle at 10% 15%, rgba(255, 255, 255, 0.4) 1.5px, transparent 1.5px),
                radial-gradient(circle at 40% 35%, rgba(14, 165, 233, 0.3) 2px, transparent 2px),
                radial-gradient(circle at 70% 25%, rgba(255, 255, 255, 0.45) 1.2px, transparent 1.2px),
                radial-gradient(circle at 85% 70%, rgba(236, 72, 153, 0.25) 2.5px, transparent 2.5px),
                radial-gradient(circle at 25% 80%, rgba(255, 255, 255, 0.35) 1.8px, transparent 1.8px);
            background-size: 260px 260px;
            animation: bintangRotasi 80s linear infinite;
            z-index: -2;
        }

        @keyframes bintangRotasi {
            from { transform: rotate(0deg) translate(0, 0); }
            to { transform: rotate(360deg) translate(-40px, -40px); }
        }

        /* --- 2. EFEK HUJAN SALJU TURUN (SNOWFALL LAYER) --- */
        .snow-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none; /* Agar tombol di web tetap bisa diklik */
            z-index: -1;
        }
        
        .snow-overlay::before, .snow-overlay::after {
            content: "";
            position: absolute;
            top: -100px;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(circle at 15% 10%, rgba(255, 255, 255, 0.75) 2.5px, transparent 2.5px),
                radial-gradient(circle at 45% 40%, rgba(255, 255, 255, 0.65) 3.5px, transparent 3.5px),
                radial-gradient(circle at 75% 20%, rgba(255, 255, 255, 0.7) 2px, transparent 2px),
                radial-gradient(circle at 90% 65%, rgba(255, 255, 255, 0.8) 4px, transparent 4px),
                radial-gradient(circle at 30% 75%, rgba(255, 255, 255, 0.6) 3px, transparent 3px);
            background-size: 350px 350px;
            animation: saljuTurun Cepat 12s linear infinite;
        }

        .snow-overlay::after {
            background-size: 240px 240px;
            animation: saljuTurunLambat 18s linear infinite;
            animation-delay: -5s;
            opacity: 0.5;
        }

        @keyframes saljuTurunCepat {
            0% { transform: translateY(0) translateX(0); }
            50% { transform: translateY(50vh) translateX(20px); }
            100% { transform: translateY(100vh) translateX(0); }
        }

        @keyframes saljuTurunLambat {
            0% { transform: translateY(0) translateX(0); }
            50% { transform: translateY(50vh) translateX(-15px); }
            100% { transform: translateY(100vh) translateX(0); }
        }
    </style>
</head>
<body class="text-slate-200 min-h-screen p-4 sm:p-6 font-['Plus_Jakarta_Sans']">

    <div class="snow-overlay"></div>

    <div class="max-w-4xl w-full mx-auto space-y-6 relative z-10">
        
        <header class="bg-[#0D192B]/90 backdrop-blur-md border border-cyan-950/80 rounded-2xl p-5 flex items-center justify-between shadow-xl">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-[#08101E] border border-cyan-500/30 flex items-center justify-center overflow-hidden shadow-inner">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo IWS" class="w-full h-full object-cover">
                </div>
                <div>
                    <h1 class="text-base font-semibold text-white tracking-wide">
                        Selamat Datang, <span class="text-emerald-400 font-bold"><%= user ? user.username : 'oracle' %>!</span>
                    </h1>
                    <div class="flex items-center gap-1 mt-1 text-[11px] text-cyan-400/90 bg-cyan-950/60 border border-cyan-800/40 px-2.5 py-0.5 rounded-md w-fit">
                        <span>👤</span> <span class="font-medium">Akun Pelanggan</span>
                    </div>
                </div>
            </div>
            <a href="/logout" class="text-xs border border-rose-950 bg-rose-950/20 hover:bg-rose-900/40 text-rose-400 font-medium px-4 py-2 rounded-xl transition duration-200">
                Logout
            </a>
        </header>

        <div class="bg-[#0A1322]/80 border border-slate-900/60 rounded-2xl p-4 flex flex-col md:flex-row md:items-center justify-between gap-4 shadow-md">
            <div class="flex items-start gap-3">
                <span class="text-2xl mt-0.5">🛍️</span>
                <div>
                    <h2 class="text-sm font-bold text-cyan-400 uppercase tracking-wider">Daftar Barang Tersedia</h2>
                    <p class="text-xs text-slate-400 mt-0.5">Atur jumlah pesanan menggunakan tombol plus-minus yang disediakan.</p>
                </div>
            </div>
            <button type="button" onclick="bukaModalKonfirmasi()" class="w-full md:w-auto bg-amber-500 hover:bg-amber-600 text-slate-950 font-bold text-xs px-5 py-2.5 rounded-xl shadow-lg transition duration-200 flex items-center justify-center gap-2">
                Beli Sekaligus (<span id="hitungBarang" class="font-mono">0</span>)
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            <% if (barang && barang.length > 0) { %>
                <% barang.forEach((item, index) => { %>
                    <div class="bg-[#0D192B]/90 border border-cyan-950/60 rounded-2xl p-5 space-y-5 shadow-xl flex flex-col justify-between">
                        
                        <div class="space-y-4">
                            <div class="flex justify-between items-start gap-2">
                                <h3 class="font-bold text-cyan-400 text-base tracking-wide"><%= item.nama_barang %></h3>
                                <span class="text-[9px] font-mono bg-slate-900 text-slate-500 px-1.5 py-0.5 rounded border border-slate-800/60 shrink-0">
                                    ID-BRG-<%= item.id_barang %>
                                </span>
                            </div>

                            <div class="space-y-2 text-xs text-slate-400">
                                <div class="flex justify-between items-center">
                                    <span>Harga Satuan:</span>
                                    <span class="font-bold text-white text-sm">Rp <%= parseFloat(item.harga).toLocaleString('id-ID') %></span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span>Sisa Stok:</span>
                                    <span class="font-semibold text-amber-400 font-mono"><%= item.stok %> pcs</span>
                                </div>
                            </div>
                        </div>

                        <form action="/beli-barang/proses" method="POST" class="space-y-4 pt-3 border-t border-slate-800/50 mt-4">
                            <input type="hidden" name="id_barang" value="<%= item.id_barang %>">
                            
                            <div class="space-y-1.5">
                                <div class="flex justify-between items-center text-[10px] text-slate-500">
                                    <span>Jumlah Beli:</span>
                                    <span>Max: <%= item.stok %></span>
                                </div>
                                
                                <div class="flex items-center bg-[#060B14] border border-cyan-950 rounded-xl p-1">
                                    <button type="button" onclick="decrement('input-<%= index %>')" class="w-10 h-8 flex items-center justify-center text-slate-400 hover:text-white font-bold text-base select-none transition">-</button>
                                    
                                    <input type="number" 
                                           id="input-<%= index %>" 
                                           name="jumlah_beli"
                                           data-id="<%= item.id_barang %>"
                                           data-nama="<%= item.nama_barang %>"
                                           data-harga="<%= item.harga %>"
                                           data-stok="<%= item.stok %>"
                                           value="0" 
                                           min="0" 
                                           max="<%= item.stok %>" 
                                           onchange="validasiInput(this)"
                                           class="input-kuantitas w-full bg-transparent text-center font-mono text-xs text-white font-bold outline-none">
                                    
                                    <button type="button" onclick="increment('input-<%= index %>')" class="w-10 h-8 flex items-center justify-center text-rose-500 hover:text-rose-400 font-bold text-base select-none transition">+</button>
                                </div>
                            </div>

                            <button type="submit" class="w-full bg-gradient-to-r from-orange-500 to-amber-500 hover:from-orange-600 hover:to-amber-600 text-slate-950 font-bold text-xs py-2.5 rounded-xl shadow-md transition duration-200">
                                Beli Sekarang
                            </button>
                        </form>

                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-1 md:col-span-3 text-center py-12 text-slate-500 text-sm bg-[#0D192B]/40 rounded-2xl border border-slate-900">
                    ⚠️ Tidak ada barang yang tersedia untuk dibeli.
                </div>
            <% } %>
        </div>
    </div>

    <div id="modalKonfirmasi" class="hidden fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center p-4 z-50">
        <div class="bg-[#0B1424] border border-cyan-900/40 rounded-2xl p-5 w-full max-w-md shadow-2xl space-y-4">
            <div class="flex items-center gap-2 border-b border-slate-800/80 pb-3">
                <span class="text-lg">📋</span>
                <h3 class="text-sm font-bold text-white">Konfirmasi Pembelian Massal</h3>
            </div>
            <div class="max-h-44 overflow-y-auto space-y-2" id="listKeranjangModal"></div>
            <div class="pt-2 flex justify-between items-center text-xs">
                <span class="text-slate-400">Total Transaksi:</span>
                <span id="totalBayarModal" class="font-mono font-bold text-cyan-400 text-sm">Rp 0</span>
            </div>
            <form action="/beli-sekaligus" method="POST" id="formCheckout">
                <input type="hidden" name="keranjangData" id="keranjangDataHidden">
                <div class="flex justify-end gap-3 mt-4">
                    <button type="button" onclick="tutupModalKonfirmasi()" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-[11px] font-bold text-slate-300 rounded-xl transition">Kembali</button>
                    <button type="submit" class="px-4 py-2 bg-gradient-to-r from-cyan-500 to-emerald-500 hover:from-cyan-600 hover:to-emerald-600 text-[11px] text-white font-bold rounded-xl transition shadow-md">Konfirmasi Checkout</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function increment(inputId) {
            const input = document.getElementById(inputId);
            let current = parseInt(input.value) || 0;
            let maxStok = parseInt(input.getAttribute('data-stok')) || 0; 
            if (current < maxStok) input.value = current + 1;
            perbaruiHitunganKeranjang();
        }

        function decrement(inputId) {
            const input = document.getElementById(inputId);
            let current = parseInt(input.value) || 0;
            if (current > 0) input.value = current - 1;
            perbaruiHitunganKeranjang();
        }

        function validasiInput(input) {
            let value = parseInt(input.value) || 0;
            let maxStok = parseInt(input.getAttribute('data-stok')) || 0;
            if (value < 0) value = 0;
            if (value > maxStok) value = maxStok;
            input.value = value;
            perbaruiHitunganKeranjang();
        }

        function perbaruiHitunganKeranjang() {
            let totalItem = 0;
            document.querySelectorAll('.input-kuantitas').forEach(input => {
                totalItem += parseInt(input.value) || 0;
            });
            document.getElementById('hitungBarang').innerText = totalItem;
        }

        function bukaModalKonfirmasi() {
            const listContainer = document.getElementById('listKeranjangModal');
            listContainer.innerHTML = '';
            let dataBelanja = [];
            let totalBayar = 0;

            document.querySelectorAll('.input-kuantitas').forEach(input => {
                let kuantitas = parseInt(input.value) || 0;
                if (kuantitas > 0) {
                    let id = input.getAttribute('data-id');
                    let nama = input.getAttribute('data-nama');
                    let harga = parseInt(input.getAttribute('data-harga')) || 0;
                    let subtotal = kuantitas * harga;
                    
                    totalBayar += subtotal;
                    dataBelanja.push({ id_barang: id, nama_barang: nama, jumlah: kuantitas, harga: harga });

                    let itemRow = document.createElement('div');
                    itemRow.className = "flex justify-between items-center text-xs bg-[#060B14] border border-slate-900 p-2.5 rounded-xl";
                    itemRow.innerHTML = `
                        <div>
                            <p class="font-semibold text-white text-[11px]">${nama}</p>
                            <p class="text-[10px] text-slate-500">${kuantitas} pcs x Rp ${harga.toLocaleString('id-ID')}</p>
                        </div>
                        <span class="font-mono font-bold text-slate-300">Rp ${subtotal.toLocaleString('id-ID')}</span>
                    `;
                    listContainer.appendChild(itemRow);
                }
            });

            if (dataBelanja.length === 0) {
                alert('Silakan tentukan kuantitas barang terlebih dahulu menggunakan tombol plus (+)!');
                return;
            }

            document.getElementById('totalBayarModal').innerText = 'Rp ' + totalBayar.toLocaleString('id-ID');
            document.getElementById('keranjangDataHidden').value = JSON.stringify(dataBelanja);
            document.getElementById('modalKonfirmasi').classList.remove('hidden');
        }

        function tutupModalKonfirmasi() {
            document.getElementById('modalKonfirmasi').classList.add('hidden');
        }
    </script>
</body>
</html>
