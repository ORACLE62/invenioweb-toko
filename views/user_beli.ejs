<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>InvenioWeb Market System</title>
    <link rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="text-slate-200 min-h-screen p-6 flex flex-col justify-between bg-gradient-to-b from-[#0B1528] to-[#040814] font-['Plus_Jakarta_Sans']">

    <div class="max-w-6xl w-full mx-auto space-y-8">
        <header class="bg-[#13223C]/50 backdrop-blur-md border border-cyan-900/40 rounded-2xl p-4 flex items-center justify-between shadow-2xl">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-cyan-600 flex items-center justify-center font-bold text-white shadow-lg">
                    IWS
                </div>
                <div>
                    <h1 class="text-sm font-semibold text-white">
                        Selamat Datang, <span class="text-cyan-400 font-bold"><%= user ? user.nama : 'Pelanggan' %></span>!
                    </h1>
                    <span class="text-[9px] bg-cyan-950/80 text-cyan-400 border border-cyan-800/50 px-2 py-0.5 rounded font-medium">👤 Akun Pelanggan</span>
                </div>
            </div>
            <a href="/logout" class="text-xs bg-rose-950/40 border border-rose-800/40 hover:bg-rose-900/50 text-rose-400 font-semibold px-4 py-2 rounded-xl transition">
                Logout
            </a>
        </header>

        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-slate-800 pb-5">
            <div>
                <h2 class="text-sm font-bold text-cyan-400 flex items-center gap-2 uppercase tracking-wider">🗃️ Daftar Barang Tersedia</h2>
                <p class="text-xs text-slate-400 mt-1">Atur jumlah kuantitas pesanan menggunakan tombol plus-minus.</p>
            </div>
            
            <button onclick="bukaModalKonfirmasi()" class="bg-gradient-to-r from-orange-500 to-amber-500 hover:from-orange-600 hover:to-amber-600 text-white font-bold text-xs px-6 py-3 rounded-xl shadow-lg transition flex items-center gap-2">
                Beli Sekaligus (<span id="hitungBarang" class="font-mono">0</span>)
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% if (barang && barang.length > 0) { %>
                <% barang.forEach((item, index) => { %>
                    <div class="bg-[#111C32]/60 border border-slate-800 rounded-2xl p-5 flex flex-col justify-between space-y-6 shadow-xl relative overflow-hidden">
                        
                        <div>
                            <div class="flex justify-between items-start gap-4 mb-3">
                                <h3 class="font-bold text-white text-base tracking-tight"><%= item.nama_barang %></h3>
                                <span class="text-[9px] font-mono bg-slate-800/80 text-slate-400 px-2 py-0.5 rounded border border-slate-700/50">
                                    ID-BRG-<%= item.id_barang %>
                                </span>
                            </div>

                            <div class="space-y-2.5 text-xs text-slate-400 pt-3 border-t border-slate-800/60">
                                <div class="flex justify-between">
                                    <span>Harga Satuan:</span>
                                    <span class="font-bold text-white">Rp <%= parseFloat(item.harga).toLocaleString('id-ID') %></span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span>Sisa Stok:</span>
                                    <span class="font-semibold text-rose-400 font-mono bg-rose-500/10 border border-rose-500/20 px-2 py-0.5 rounded">
                                        Sisa <%= item.stok %> pcs
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <div class="flex justify-between items-center text-[10px] text-slate-500 font-medium">
                                <span>Jumlah Beli:</span>
                                <span>Max: <%= item.stok %></span>
                            </div>
                            
                            <div class="flex items-center bg-[#070D19] border border-slate-800 rounded-xl p-1">
                                <button type="button" onclick="decrement('input-<%= index %>')" class="w-10 h-9 flex items-center justify-center text-zinc-400 hover:text-white rounded-lg transition font-bold text-lg select-none">-</button>
                                
                                <input type="number" 
                                       id="input-<%= index %>" 
                                       data-id="<%= item.id_barang %>"
                                       data-nama="<%= item.nama_barang %>"
                                       data-harga="<%= item.harga %>"
                                       data-stok="<%= item.stok %>"
                                       value="0" 
                                       min="0" 
                                       max="<%= item.stok %>" 
                                       onchange="validasiInput(this)"
                                       class="input-kuantitas w-full bg-transparent text-center font-mono text-sm text-white font-bold outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
                                
                                <button type="button" onclick="increment('input-<%= index %>')" class="w-10 h-9 flex items-center justify-center text-zinc-400 hover:text-white rounded-lg transition font-bold text-lg select-none">+</button>
                            </div>
                        </div>

                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full text-center py-12 text-slate-500 text-sm">
                    ⚠️ Tidak ada barang yang tersedia untuk dibeli.
                </div>
            <% } %>
        </div>
    </div>

    <div id="modalKonfirmasi" class="hidden fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center p-4 z-50">
        <div class="bg-[#0F1A2F] border border-cyan-900/30 rounded-2xl p-6 w-full max-w-md shadow-2xl space-y-4">
            
            <div class="flex items-center gap-2 border-b border-slate-800 pb-3">
                <span class="text-xl">📋</span>
                <h3 class="text-sm font-bold text-white">Konfirmasi Pembelian Anda</h3>
            </div>

            <div class="max-h-44 overflow-y-auto space-y-2" id="listKeranjangModal"></div>

            <div class="pt-3 border-t border-slate-800 flex justify-between items-center text-sm">
                <span class="font-medium text-slate-400">Total Pembayaran:</span>
                <span id="totalBayarModal" class="font-mono font-bold text-cyan-400 text-base">Rp 0</span>
            </div>

            <form action="/beli-sekaligus" method="POST" id="formCheckout">
                <input type="hidden" name="keranjangData" id="keranjangDataHidden">
                <p class="text-xs text-amber-400 bg-amber-500/10 border border-amber-500/20 rounded-xl p-3 leading-relaxed">
                    ⚠️ Apakah Anda yakin ingin memproses seluruh item pembelian di atas?
                </p>
                <div class="flex justify-end gap-3 mt-5">
                    <button type="button" onclick="tutupModalKonfirmasi()" class="px-4 py-2.5 bg-slate-800 hover:bg-slate-700 text-xs font-bold text-slate-300 rounded-xl transition">Batal</button>
                    <button type="submit" class="px-5 py-2.5 bg-gradient-to-r from-cyan-500 to-teal-500 hover:from-cyan-600 hover:to-teal-600 text-xs text-white font-bold rounded-xl transition shadow-lg">Ya, Beli Sekarang</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function increment(inputId) {
            const input = document.getElementById(inputId);
            let current = parseInt(input.value) || 0;
            let maxStok = parseInt(input.getAttribute('data-stok')) || 0; 
            if (current < maxStok) input.value = current + 1;
            perbaruiHitunganKeranjang();
        }

        function decrement(inputId) {
            const input = document.getElementById(inputId);
            let current = parseInt(input.value) || 0;
            if (current > 0) input.value = current - 1;
            perbaruiHitunganKeranjang();
        }

        function validasiInput(input) {
            let value = parseInt(input.value) || 0;
            let maxStok = parseInt(input.getAttribute('data-stok')) || 0;
            if (value < 0) value = 0;
            if (value > maxStok) value = maxStok;
            input.value = value;
            perbaruiHitunganKeranjang();
        }

        function perbaruiHitunganKeranjang() {
            let totalItem = 0;
            document.querySelectorAll('.input-kuantitas').forEach(input => {
                totalItem += parseInt(input.value) || 0;
            });
            document.getElementById('hitungBarang').innerText = totalItem;
        }

        function bukaModalKonfirmasi() {
            const listContainer = document.getElementById('listKeranjangModal');
            listContainer.innerHTML = '';
            let dataBelanja = [];
            let totalBayar = 0;

            document.querySelectorAll('.input-kuantitas').forEach(input => {
                let kuantitas = parseInt(input.value) || 0;
                if (kuantitas > 0) {
                    let id = input.getAttribute('data-id');
                    let nama = input.getAttribute('data-nama');
                    let harga = parseInt(input.getAttribute('data-harga')) || 0;
                    let subtotal = kuantitas * harga;
                    
                    totalBayar += subtotal;
                    dataBelanja.push({ id_barang: id, nama_barang: nama, jumlah: kuantitas, harga: harga });

                    let itemRow = document.createElement('div');
                    itemRow.className = "flex justify-between items-center text-xs bg-[#070D19] border border-slate-800 p-2.5 rounded-xl";
                    itemRow.innerHTML = `
                        <div>
                            <p class="font-semibold text-white">${nama}</p>
                            <p class="text-[10px] text-slate-500">${kuantitas} pcs x Rp ${harga.toLocaleString('id-ID')}</p>
                        </div>
                        <span class="font-mono font-bold text-slate-300">Rp ${subtotal.toLocaleString('id-ID')}</span>
                    `;
                    listContainer.appendChild(itemRow);
                }
            });

            if (dataBelanja.length === 0) {
                alert('Silakan pilih kuantitas barang terlebih dahulu!');
                return;
            }

            document.getElementById('totalBayarModal').innerText = 'Rp ' + totalBayar.toLocaleString('id-ID');
            document.getElementById('keranjangDataHidden').value = JSON.stringify(dataBelanja);
            document.getElementById('modalKonfirmasi').classList.remove('hidden');
        }

        function tutupModalKonfirmasi() {
            document.getElementById('modalKonfirmasi').classList.add('hidden');
        }
    </script>
</body>
</html>
