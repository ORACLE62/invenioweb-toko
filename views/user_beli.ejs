<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Halaman Belanja - InvenioWeb</title>
    <link rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: radial-gradient(circle at center, #0e2a38 0%, #061321 60%, #020710 100%);
            overflow-x: hidden;
        }

        /* Efek Grid Pola Mesh Bergerak Lambat */
        .cyber-mesh {
            background-image: radial-gradient(rgba(20, 184, 166, 0.15) 1px, transparent 0);
            background-size: 32px 32px;
            animation: meshMove 40s linear infinite;
        }

        /* Animasi Pendaran Cahaya Mengambang secara Acak */
        .glow-orb-1 {
            animation: floatOrb1 20s ease-in-out infinite alternate;
        }
        .glow-orb-2 {
            animation: floatOrb2 25s ease-in-out infinite alternate;
        }

        @keyframes meshMove {
            0% { background-position: 0px 0px; }
            100% { background-position: 1000px 1000px; }
        }

        @keyframes floatOrb1 {
            0% { transform: translate(0px, 0px) scale(1); opacity: 0.5; }
            50% { transform: translate(100px, 80px) scale(1.2); opacity: 0.8; }
            100% { transform: translate(-50px, 150px) scale(0.9); opacity: 0.4; }
        }

        @keyframes floatOrb2 {
            0% { transform: translate(0px, 0px) scale(1.1); opacity: 0.4; }
            50% { transform: translate(-120px, -60px) scale(0.83); opacity: 0.7; }
            100% { transform: translate(80px, -120px) scale(1.2); opacity: 0.5; }
        }

        /* Sembunyikan spinner bawaan browser agar input bersih */
        input[type="number"]::-webkit-inner-spin-button,
        input[type="number"]::-webkit-outer-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        input[type="number"] {
            appearance: textfield;
        }
    </style>
</head>
<body class="text-zinc-100 min-h-screen relative antialiased flex flex-col">

    <div class="absolute inset-0 cyber-mesh pointer-events-none opacity-80 z-0"></div>
    <div class="absolute top-[-10%] left-[-10%] w-[600px] h-[600px] bg-teal-500/15 rounded-full blur-[140px] pointer-events-none z-0 glow-orb-1"></div>
    <div class="absolute bottom-[-5%] right-[-5%] w-[700px] h-[700px] bg-cyan-500/10 rounded-full blur-[160px] pointer-events-none z-0 glow-orb-2"></div>

    <div class="relative z-10 p-4 md:p-8 max-w-7xl mx-auto w-full space-y-8 flex-grow">
        
        <header class="bg-slate-900/40 border border-teal-500/20 backdrop-blur-xl rounded-2xl p-4 md:p-6 flex items-center justify-between shadow-xl shadow-black/30">
            <div class="flex items-center gap-3">
                <div class="bg-gradient-to-tr from-[#5551ff] to-teal-400 rounded-full p-0.5 w-11 h-11 overflow-hidden shrink-0 shadow-lg shadow-teal-500/10">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-full">
                </div>
                <div>
                    <h1 class="text-sm md:text-base font-bold text-white tracking-tight">
                        Selamat Datang, <span class="text-teal-400 font-mono"><%= user.nama %>!</span>
                    </h1>
                    <span class="inline-flex items-center text-[10px] bg-teal-500/10 text-teal-300 px-2 py-0.5 rounded border border-teal-500/20 mt-0.5 font-medium">
                        👤 Akun Pelanggan
                    </span>
                </div>
            </div>
            
            <a href="/logout" class="text-xs font-bold text-red-400 hover:text-red-300 bg-red-500/10 hover:bg-red-500/20 px-4 py-2.5 rounded-xl border border-red-500/30 shadow-md transition-all duration-200">
                Logout
            </a>
        </header>

        <div class="flex items-center gap-2.5 px-1">
            <span class="text-xl">🛍️</span>
            <div>
                <h2 class="text-sm font-bold uppercase tracking-wider text-teal-400">Daftar Barang Tersedia</h2>
                <p class="text-xs text-zinc-400 mt-0.5">Atur jumlah pesanan menggunakan tombol plus-minus yang disediakan.</p>
            </div>
        </div>

        <% if (barang.length === 0) { %>
            <div class="bg-slate-900/30 border border-zinc-800/80 backdrop-blur-md rounded-2xl p-12 text-center max-w-md mx-auto shadow-xl">
                <div class="text-4xl mb-3">📦</div>
                <h3 class="text-zinc-300 font-semibold mb-1">Stok Belum Tersedia</h3>
                <p class="text-xs text-zinc-500">Maaf, saat ini belum ada stok barang dari petugas gudang.</p>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                <% barang.forEach((item, index) => { %>
                    <div class="bg-slate-900/50 border border-zinc-800/60 hover:border-teal-500/40 backdrop-blur-md rounded-2xl p-5 shadow-xl transition-all duration-300 hover:-translate-y-1 flex flex-col justify-between group">
                        
                        <div>
                            <div class="flex justify-between items-start gap-2 mb-3">
                                <h4 class="font-bold text-white group-hover:text-teal-300 transition-colors duration-200 line-clamp-2">
                                    <%= item.nama_barang %>
                                </h4>
                                <span class="text-[9px] bg-zinc-800 text-zinc-400 px-2 py-0.5 rounded border border-zinc-700/50 font-mono">
                                    ID-<%= item.id_barang %>
                                </span>
                            </div>
                            
                            <div class="space-y-2 text-xs border-y border-zinc-800/60 py-3.5 mb-4">
                                <div class="flex justify-between items-center">
                                    <span class="text-zinc-400">Harga Satuan:</span>
                                    <span class="font-bold text-zinc-100 font-mono text-sm">
                                        Rp <%= item.harga.toLocaleString('id-ID') %>
                                    </span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-zinc-400">Sisa Stok:</span>
                                    <% if (item.stok <= 5) { %>
                                        <span class="font-semibold text-red-400 font-mono bg-red-500/10 px-2 py-0.5 rounded border border-red-500/20 text-[11px]">
                                            Sisa <%= item.stok %> pcs
                                        </span>
                                    <% } else { %>
                                        <span class="font-semibold text-amber-400 font-mono"><%= item.stok %> pcs</span>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <form action="/beli-barang/proses" method="POST" class="space-y-4">
                            <input type="hidden" name="id_barang" value="<%= item.id_barang %>">
                            
                            <div>
                                <div class="flex justify-between items-center mb-1.5">
                                    <label class="block text-[11px] text-zinc-400 font-medium">Jumlah Beli:</label>
                                    <span class="text-[10px] text-zinc-500 font-mono">Max: <%= item.stok %></span>
                                </div>

                                <div class="flex items-center bg-zinc-950/80 border border-zinc-800 focus-within:border-teal-500 rounded-xl overflow-hidden p-0.5 transition duration-200">
                                    <button type="button" 
                                            data-input-id="input-<%= index %>"
                                            onclick="handleDecrement(this)"
                                            class="w-10 h-9 flex items-center justify-center text-zinc-400 hover:text-red-400 hover:bg-red-500/10 rounded-lg font-bold text-base transition active:scale-90 select-none">
                                        &minus;
                                    </button>
                                    
                                    <input type="number" id="input-<%= index %>" name="jumlah_beli" min="1" max="<%= item.stok %>" value="1" required
                                           class="w-full bg-transparent text-center font-mono text-sm text-white outline-none py-1">
                                    
                                    <button type="button" 
                                            data-input-id="input-<%= index %>" 
                                            data-max="<%= item.stok %>"
                                            onclick="handleIncrement(this)"
                                            class="w-10 h-9 flex items-center justify-center text-zinc-400 hover:text-red-400 hover:bg-red-500/10 rounded-lg font-bold text-base transition active:scale-90 select-none">
                                        &plus;
                                    </button>
                                </div>
                            </div>
                            
                            <button type="submit" class="w-full bg-gradient-to-r from-red-500 to-amber-500 hover:from-red-400 hover:to-amber-400 text-zinc-950 font-bold text-xs py-3 rounded-xl transition-all duration-200 shadow-lg shadow-red-500/10">
                                Beli Sekarang
                            </button>
                        </form>

                    </div>
                <% }) %>
            </div>
        <% } %>

    </div>

    <footer class="relative z-10 text-center py-5 border-t border-zinc-800/30 text-[11px] text-zinc-600 font-medium tracking-wide">
        &copy; 2026 InvenioWeb Market System. All rights reserved.
    </footer>

    <script>
        function handleIncrement(button) {
            const inputId = button.getAttribute('data-input-id');
            const maxStock = parseInt(button.getAttribute('data-max')) || 1;
            
            const input = document.getElementById(inputId);
            let currentValue = parseInt(input.value) || 1;
            if (currentValue < maxStock) {
                input.value = currentValue + 1;
            }
        }

        function handleDecrement(button) {
            const inputId = button.getAttribute('data-input-id');
            
            const input = document.getElementById(inputId);
            let currentValue = parseInt(input.value) || 1;
            if (currentValue > 1) {
                input.value = currentValue - 1;
            }
        }
    </script>

</body>
</html>
