<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>InvenioWeb Market System</title>
    <link rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* --- CORE BACKGROUND & SCIFI TUNNEL EFFECT --- */
        body {
            position: relative;
            overflow-x: hidden;
            background-color: #030008; /* Hitam pekat ruang angkasa */
            perspective: 800px;
        }

        /* Container Terowongan */
        .tunnel-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
            background: radial-gradient(circle at 50% 50%, rgba(13, 10, 28, 0.3) 0%, #030008 80%);
        }

        /* Efek Garis Lorong Perspektif 3D */
        .tunnel-walls {
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background-image: 
                linear-gradient(90deg, rgba(6, 182, 212, 0.15) 1px, transparent 1px),
                linear-gradient(0deg, rgba(244, 63, 94, 0.15) 1px, transparent 1px);
            background-size: 80px 80px;
            transform: rotateX(75deg) translateZ(-100px);
            opacity: 0.4;
        }

        /* Lampu Neon Melesat / Hyperdrive (Orange & Cyan) */
        .neon-laser-beams {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            background: 
                linear-gradient(to bottom, transparent 40%, rgba(244, 63, 94, 0.8) 50%, transparent 60%),
                linear-gradient(to right, transparent 30%, rgba(6, 182, 212, 0.8) 50%, transparent 70%);
            background-size: 400px 400px;
            mask-image: radial-gradient(circle at 50% 50%, transparent 10%, black 80%);
            -webkit-mask-image: radial-gradient(circle at 50% 50%, transparent 10%, black 80%);
            animation: hyperdrive 4s linear infinite;
        }

        /* Lapisan Tambahan untuk Variasi Kecepatan Lampu */
        .neon-laser-beams-fast {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            background: 
                linear-gradient(90deg, transparent 45%, rgba(249, 115, 22, 0.7) 50%, transparent 55%),
                linear-gradient(0deg, transparent 20%, rgba(14, 165, 233, 0.6) 50%, transparent 80%);
            background-size: 300px 300px;
            mask-image: radial-gradient(circle at 50% 50%, transparent 5%, black 90%);
            -webkit-mask-image: radial-gradient(circle at 50% 50%, transparent 5%, black 90%);
            animation: hyperdrive 2s linear infinite reverse;
            opacity: 0.7;
        }

        /* Animasi Efek Bergerak Maju Mendekati Layar */
        @keyframes hyperdrive {
            0% {
                transform: scale(0.4) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            90% {
                opacity: 1;
            }
            100% {
                transform: scale(2.2) rotate(15deg);
                opacity: 0;
            }
        }

        /* Titik Pusat Lorong (Vanish Point Glow) */
        .tunnel-core {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 120px;
            height: 120px;
            background: radial-gradient(circle, rgba(244, 63, 94, 0.4) 0%, rgba(6, 182, 212, 0.2) 50%, transparent 100%);
            filter: blur(10px);
            box-shadow: 0 0 60px rgba(6, 182, 212, 0.4);
            border-radius: 50%;
        }
    </style>
</head>
<body class="text-slate-200 min-h-screen p-4 sm:p-6 font-['Plus_Jakarta_Sans']">

    <!-- BACKGROUND ENGINE CYBERPUNK TUNNEL -->
    <div class="tunnel-container">
        <div class="tunnel-walls"></div>
        <div class="neon-laser-beams"></div>
        <div class="neon-laser-beams-fast"></div>
        <div class="tunnel-core"></div>
    </div>

    <div class="max-w-4xl w-full mx-auto space-y-6 relative z-10">
        
        <!-- HEADER PROFILE -->
        <header class="bg-[#0A071E]/80 backdrop-blur-xl border border-cyan-500/20 rounded-2xl p-5 flex items-center justify-between shadow-[0_0_25px_rgba(6,182,212,0.15)]">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-[#050312] border border-cyan-500/40 flex items-center justify-center overflow-hidden shadow-inner">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo IWS" class="w-full h-full object-cover">
                </div>
                <div>
                    <h1 class="text-base font-semibold text-white tracking-wide">
                        Selamat Datang, <span class="text-emerald-400 font-bold"><%= user ? user.username : 'oracle' %>!</span>
                    </h1>
                    <div class="flex items-center gap-1 mt-1 text-[11px] text-cyan-400/90 bg-cyan-950/60 border border-cyan-500/30 px-2.5 py-0.5 rounded-md w-fit">
                        <span>👤</span> <span class="font-medium">Akun Pelanggan</span>
                    </div>
                </div>
            </div>
            <a href="/logout" class="text-xs border border-rose-950 bg-rose-950/40 hover:bg-rose-900/60 text-rose-400 font-medium px-4 py-2 rounded-xl transition duration-200">
                Logout
            </a>
        </header>

        <!-- ACTION BAR BARANG TERSEDIA -->
        <div class="bg-[#07051A]/80 backdrop-blur-md border border-slate-800/60 rounded-2xl p-4 flex flex-col md:flex-row md:items-center justify-between gap-4 shadow-md">
            <div class="flex items-start gap-3">
                <span class="text-2xl mt-0.5">🛍️</span>
                <div>
                    <h2 class="text-sm font-bold text-cyan-400 uppercase tracking-wider">Daftar Barang Tersedia</h2>
                    <p class="text-xs text-slate-400 mt-0.5">Atur jumlah pesanan menggunakan tombol plus-minus yang disediakan.</p>
                </div>
            </div>
            <button type="button" onclick="bukaModalKonfirmasi()" class="w-full md:w-auto bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-600 hover:to-orange-600 text-slate-950 font-bold text-xs px-5 py-2.5 rounded-xl shadow-lg transition duration-200 flex items-center justify-center gap-2">
                Beli Sekaligus (<span id="hitungBarang" class="font-mono">0</span>)
            </button>
        </div>

        <!-- GRID DATA PRODUK BARANG -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            <% if (barang && barang.length > 0) { %>
                <% barang.forEach((item, index) => { %>
                    <div class="bg-[#0A071E]/90 backdrop-blur-sm border border-slate-800/80 rounded-2xl p-5 space-y-5 shadow-xl flex flex-col justify-between hover:border-cyan-500/30 transition duration-300">
                        
                        <div class="space-y-4">
                            <div class="flex justify-between items-start gap-2">
                                <h3 class="font-bold text-cyan-400 text-base tracking-wide"><%= item.nama_barang %></h3>
                                <span class="text-[9px] font-mono bg-slate-950 text-slate-500 px-1.5 py-0.5 rounded border border-slate-800/60 shrink-0">
                                    ID-BRG-<%= item.id_barang %>
                                </span>
                            </div>

                            <div class="space-y-2 text-xs text-slate-400">
                                <div class="flex justify-between items-center">
                                    <span>Harga Satuan:</span>
                                    <span class="font-bold text-white text-sm">Rp <%= parseFloat(item.harga).toLocaleString('id-ID') %></span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span>Sisa Stok:</span>
                                    <span class="font-semibold text-amber-400 font-mono"><%= item.stok %> pcs</span>
                                </div>
                            </div>
                        </div>

                        <!-- FORM CONTROL COUNTER ECERAN -->
                        <form action="/beli-barang/proses" method="POST" class="space-y-4 pt-3 border-t border-slate-800/50 mt-4">
                            <input type="hidden" name="id_barang" value="<%= item.id_barang %>">
                            
                            <div class="space-y-1.5">
                                <div class="flex justify-between items-center text-[10px] text-slate-500">
                                    <span>Jumlah Beli:</span>
                                    <span>Max: <%= item.stok %></span>
                                </div>
                                
                                <div class="flex items-center bg-[#03010C] border border-slate-800 rounded-xl p-1">
                                    <button type="button" onclick="decrement('input-<%= index %>')" class="w-10 h-8 flex items-center justify-center text-slate-400 hover:text-white font-bold text-base select-none transition">-</button>
                                    
                                    <input type="number" 
                                           id="input-<%= index %>" 
                                           name="jumlah_beli"
                                           data-id="<%= item.id_barang %>"
                                           data-nama="<%= item.nama_barang %>"
                                           data-harga="<%= item.harga %>"
                                           data-stok="<%= item.stok %>"
                                           value="0" 
                                           min="0" 
                                           max="<%= item.stok %>" 
                                           onchange="validasiInput(this)"
                                           class="input-kuantitas w-full bg-transparent text-center font-mono text-xs text-white font-bold outline-none">
                                    
                                    <button type="button" onclick="increment('input-<%= index %>')" class="w-10 h-8 flex items-center justify-center text-rose-500 hover:text-rose-400 font-bold text-base select-none transition">+</button>
                                </div>
                            </div>

                            <button type="submit" class="w-full bg-gradient-to-r from-orange-500 to-amber-500 hover:from-orange-600 hover:to-amber-600 text-slate-950 font-bold text-xs py-2.5 rounded-xl shadow-md transition duration-200">
                                Beli Sekarang
                            </button>
                        </form>

                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-1 md:col-span-3 text-center py-12 text-slate-500 text-sm bg-[#0A071E]/40 rounded-2xl border border-slate-900">
                    ⚠️ Tidak ada barang yang tersedia untuk dibeli.
                </div>
            <% } %>
        </div>
    </div>

    <!-- MODAL MASALAH CHECKOUT MULTIPLE -->
    <div id="modalKonfirmasi" class="hidden fixed inset-0 bg-black/80 backdrop-blur-md flex items-center justify-center p-4 z-50">
        <div class="bg-[#0A071E] border border-cyan-500/30 rounded-2xl p-5 w-full max-w-md shadow-2xl space-y-4">
            <div class="flex items-center gap-2 border-b border-slate-800/80 pb-3">
                <span class="text-lg">📋</span>
                <h3 class="text-sm font-bold text-white">Konfirmasi Pembelian Massal</h3>
            </div>
            <div class="max-h-44 overflow-y-auto space-y-2" id="listKeranjangModal"></div>
            <div class="pt-2 flex justify-between items-center text-xs">
                <span class="text-slate-400">Total Transaksi:</span>
                <span id="totalBayarModal" class="font-mono font-bold text-cyan-400 text-sm">Rp 0</span>
            </div>
            <form action="/beli-sekaligus" method="POST" id="formCheckout">
                <input type="hidden" name="keranjangData" id="keranjangDataHidden">
                <div class="flex justify-end gap-3 mt-4">
                    <button type="button" onclick="tutupModalKonfirmasi()" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-[11px] font-bold text-slate-300 rounded-xl transition">Kembali</button>
                    <button type="submit" class="px-4 py-2 bg-gradient-to-r from-cyan-500 to-emerald-500 hover:from-cyan-600 hover:to-emerald-600 text-[11px] text-white font-bold rounded-xl transition shadow-md">Konfirmasi Checkout</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function increment(inputId) {
            const input = document.getElementById(inputId);
            let current = parseInt(input.value) || 0;
            let maxStok = parseInt(input.getAttribute('data-stok')) || 0; 
            if (current < maxStok) input.value = current + 1;
            perbaruiHitunganKeranjang();
        }

        function decrement(inputId) {
            const input = document.getElementById(inputId);
            let current = parseInt(input.value) || 0;
            if (current > 0) input.value = current - 1;
            perbaruiHitunganKeranjang();
        }

        function validasiInput(input) {
            let value = parseInt(input.value) || 0;
            let maxStok = parseInt(input.getAttribute('data-stok')) || 0;
            if (value < 0) value = 0;
            if (value > maxStok) value = maxStok;
            input.value = value;
            perbaruiHitunganKeranjang();
        }

        function perbaruiHitunganKeranjang() {
            let totalItem = 0;
            document.querySelectorAll('.input-kuantitas').forEach(input => {
                totalItem += parseInt(input.value) || 0;
            });
            document.getElementById('hitungBarang').innerText = totalItem;
        }

        function bukaModalKonfirmasi() {
            const listContainer = document.getElementById('listKeranjangModal');
            listContainer.innerHTML = '';
            let dataBelanja = [];
            let totalBayar = 0;

            document.querySelectorAll('.input-kuantitas').forEach(input => {
                let kuantitas = parseInt(input.value) || 0;
                if (kuantitas > 0) {
                    let id = input.getAttribute('data-id');
                    let nama = input.getAttribute('data-nama');
                    let harga = parseInt(input.getAttribute('data-harga')) || 0;
                    let subtotal = kuantitas * harga;
                    
                    totalBayar += subtotal;
                    dataBelanja.push({ id_barang: id, nama_barang: nama, jumlah: kuantitas, harga: harga });

                    let itemRow = document.createElement('div');
                    itemRow.className = "flex justify-between items-center text-xs bg-[#03010C] border border-slate-900 p-2.5 rounded-xl";
                    itemRow.innerHTML = `
                        <div>
                            <p class="font-semibold text-white text-[11px]">${nama}</p>
                            <p class="text-[10px] text-slate-500">${kuantitas} pcs x Rp ${harga.toLocaleString('id-ID')}</p>
                        </div>
                        <span class="font-mono font-bold text-slate-300">Rp ${subtotal.toLocaleString('id-ID')}</span>
                    `;
                    listContainer.appendChild(itemRow);
                }
            });

            if (dataBelanja.length === 0) {
                alert('Silakan tentukan kuantitas barang terlebih dahulu!');
                return;
            }

            document.getElementById('totalBayarModal').innerText = 'Rp ' + totalBayar.toLocaleString('id-ID');
            document.getElementById('keranjangDataHidden').value = JSON.stringify(dataBelanja);
            document.getElementById('modalKonfirmasi').classList.remove('hidden');
        }

        function tutupModalKonfirmasi() {
            document.getElementById('modalKonfirmasi').classList.add('hidden');
        }
    </script>
</body>
</html>
