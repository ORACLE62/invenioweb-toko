<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daftar Barang Tersedia - InvenioWeb</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-100 text-gray-800 min-h-screen p-6 flex flex-col justify-between font-['Plus_Jakarta_Sans']">

    <div class="max-w-7xl w-full mx-auto space-y-6">
        <header class="bg-white border border-gray-200 rounded-xl p-6 flex items-center justify-between shadow-sm">
            <div>
                <h1 class="text-lg font-bold text-gray-900">
                    Selamat Datang, <span class="text-indigo-600"><%= user.nama %></span>! (Pelanggan)
                </h1>
            </div>
            <a href="/logout" class="text-sm text-red-600 hover:underline font-semibold">
                Logout
            </a>
        </header>

        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pt-2">
            <div class="flex items-center gap-2">
                <span>🗳️</span>
                <h2 class="text-base font-bold text-gray-900">Daftar Barang Tersedia</h2>
            </div>
            
            <button onclick="bukaModalKonfirmasi()" class="bg-emerald-600 hover:bg-emerald-700 text-white font-bold text-sm px-6 py-3 rounded-xl shadow-md transition flex items-center gap-2">
                🛒 Beli Sekaligus (<span id="hitungBarang">0</span>)
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% barangList.forEach((item, index) => { %>
                <div class="bg-white border border-gray-200 rounded-xl p-6 flex flex-col justify-between space-y-5 shadow-sm">
                    
                    <div class="space-y-3">
                        <div class="flex justify-between items-start gap-2">
                            <h3 class="font-bold text-gray-900 text-base leading-snug"><%= item.nama_barang %></h3>
                            <span class="text-[10px] font-mono bg-gray-100 text-gray-500 px-2 py-0.5 rounded border border-gray-200 shrink-0">
                                ID-BRG-<%= item.id_barang %>
                            </span>
                        </div>

                        <div class="space-y-1.5 text-sm text-gray-600">
                            <div class="flex justify-between">
                                <span class="font-medium text-gray-500">Harga:</span>
                                <span class="font-semibold text-gray-900">Rp <%= item.harga.toLocaleString('id-ID') %></span>
                            </div>
                            <div class="flex justify-between">
                                <span class="font-medium text-gray-500">Sisa Stok:</span>
                                <span class="font-semibold text-gray-900"><%= item.stok %> pcs</span>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <div class="flex justify-between items-center text-xs text-gray-500">
                            <label for="input-<%= index %>">Jumlah Beli:</label>
                            <span>Max: <%= item.stok %></span>
                        </div>
                        
                        <div class="flex items-center bg-gray-50 border border-gray-300 rounded-lg p-1">
                            <button type="button" onclick="ubahJumlah('<%= index %>', -1)" class="w-10 h-9 flex items-center justify-center text-gray-500 hover:bg-gray-200 rounded font-bold text-lg select-none">-</button>
                            
                            <input type="number" 
                                   id="input-<%= index %>" 
                                   data-id="<%= item.id_barang %>"
                                   data-nama="<%= item.nama_barang %>"
                                   data-harga="<%= item.harga %>"
                                   data-stok="<%= item.stok %>"
                                   value="0" 
                                   min="0" 
                                   max="<%= item.stok %>" 
                                   onchange="validasiInput(this)"
                                   class="input-kuantitas w-full bg-transparent text-center font-semibold text-sm text-gray-900 outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
                            
                            <button type="button" onclick="ubahJumlah('<%= index %>', 1)" class="w-10 h-9 flex items-center justify-center text-gray-500 hover:bg-gray-200 rounded font-bold text-lg select-none">+</button>
                        </div>
                    </div>

                </div>
            <% }) %>
        </div>
    </div>

    <div id="modalKonfirmasi" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-xl p-6 w-full max-w-md shadow-xl space-y-4 border border-gray-200">
            
            <div class="flex items-center gap-2 border-b border-gray-200 pb-3">
                <span class="text-xl">📋</span>
                <h3 class="text-base font-bold text-gray-900">Konfirmasi Pembelian Anda</h3>
            </div>

            <div class="max-h-48 overflow-y-auto space-y-2" id="listKeranjangModal"></div>

            <div class="pt-3 border-t border-gray-200 flex justify-between items-center text-sm">
                <span class="font-medium text-gray-500">Total Pembayaran:</span>
                <span id="totalBayarModal" class="font-bold text-emerald-600 text-base">Rp 0</span>
            </div>

            <form action="/barang/beli-sekaligus" method="POST" id="formCheckout">
                <input type="hidden" name="keranjangData" id="keranjangDataHidden">
                
                <p class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-lg p-3 leading-relaxed">
                    ⚠️ Apakah Anda yakin ingin memproses seluruh item pembelian di atas?
                </p>

                <div class="flex justify-end gap-3 mt-4">
                    <button type="button" onclick="tutupModalKonfirmasi()" class="px-4 py-2 bg-gray-200 hover:bg-gray-300 text-xs font-bold text-gray-700 rounded-lg transition">
                        Tidak, Batalkan
                    </button>
                    <button type="submit" class="px-5 py-2 bg-emerald-600 hover:bg-emerald-700 text-xs text-white font-bold rounded-lg transition shadow-sm">
                        Ya, Beli Sekarang
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function ubahJumlah(index, nilai) {
            const input = document.getElementById('input-' + index);
            let current = parseInt(input.value) || 0;
            let maxStok = parseInt(input.getAttribute('data-stok')) || 0;
            
            let hasil = current + nilai;
            if (hasil < 0) hasil = 0;
            if (hasil > maxStok) hasil = maxStok;
            
            input.value = hasil;
            perbaruiHitunganKeranjang();
        }

        function validasiInput(input) {
            let value = parseInt(input.value) || 0;
            let maxStok = parseInt(input.getAttribute('data-stok')) || 0;
            
            if (value < 0) value = 0;
            if (value > maxStok) value = maxStok;
            
            input.value = value;
            perbaruiHitunganKeranjang();
        }

        function perbaruiHitunganKeranjang() {
            let totalItem = 0;
            document.querySelectorAll('.input-kuantitas').forEach(input => {
                totalItem += parseInt(input.value) || 0;
            });
            document.getElementById('hitungBarang').innerText = totalItem;
        }

        function bukaModalKonfirmasi() {
            const listContainer = document.getElementById('listKeranjangModal');
            listContainer.innerHTML = '';
            
            let dataBelanja = [];
            let totalBayar = 0;

            document.querySelectorAll('.input-kuantitas').forEach(input => {
                let kuantitas = parseInt(input.value) || 0;
                if (kuantitas > 0) {
                    let id = input.getAttribute('data-id');
                    let nama = input.getAttribute('data-nama');
                    let harga = parseInt(input.getAttribute('data-harga')) || 0;
                    let subtotal = kuantitas * harga;
                    
                    totalBayar += subtotal;
                    dataBelanja.push({ id_barang: id, nama_barang: nama, jumlah: kuantitas, harga: harga });

                    let itemRow = document.createElement('div');
                    itemRow.className = "flex justify-between items-center text-xs bg-gray-50 border border-gray-200 p-2.5 rounded-lg";
                    itemRow.innerHTML = `
                        <div>
                            <p class="font-semibold text-gray-900">${nama}</p>
                            <p class="text-[10px] text-gray-500">${kuantitas} pcs x Rp ${harga.toLocaleString('id-ID')}</p>
                        </div>
                        <span class="font-bold text-gray-700">Rp ${subtotal.toLocaleString('id-ID')}</span>
                    `;
                    listContainer.appendChild(itemRow);
                }
            });

            if (dataBelanja.length === 0) {
                alert('Silakan tentukan kuantitas jumlah beli barang terlebih dahulu!');
                return;
            }

            document.getElementById('totalBayarModal').innerText = 'Rp ' + totalBayar.toLocaleString('id-ID');
            document.getElementById('keranjangDataHidden').value = JSON.stringify(dataBelanja);
            document.getElementById('modalKonfirmasi').classList.remove('hidden');
        }

        function tutupModalKonfirmasi() {
            document.getElementById('modalKonfirmasi').classList.add('hidden');
        }
    </script>
</body>
</html>
