<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - InvenioWeb</title>
    <link rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
    </style>
</head>
<body class="bg-zinc-950 text-white min-h-screen flex flex-col md:flex-row antialiased">

    <div class="hidden md:flex w-64 bg-zinc-900 border-r border-zinc-800 p-6 flex-col justify-between shrink-0 min-h-screen sticky top-0">
        <div>
            <div class="flex items-center gap-3 mb-8 px-2">
                <div class="bg-[#5551ff] rounded-full p-1 shadow-lg shadow-[#5551ff]/20 flex items-center justify-center w-11 h-11 overflow-hidden shrink-0">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-full">
                </div>
                <span class="text-xl font-bold tracking-tight bg-gradient-to-r from-white via-zinc-200 to-zinc-400 bg-clip-text text-transparent drop-shadow-sm">
                    InvenioWeb
                </span>
            </div>

            <nav class="space-y-1.5">
                <a href="/dashboard" class="block px-4 py-2.5 bg-[#5551ff] text-white rounded-xl text-sm font-medium transition-all duration-200 shadow-md shadow-[#5551ff]/10">Dashboard</a>
                <a href="/barang" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Kelola Barang</a>
                <a href="/supplier" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Kelola Supplier</a>
                <a href="/transaksi" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Kelola Transaksi</a>
                <a href="/laporan" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Cetak Laporan</a>
                <a href="/barang-terjual" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Barang Terjual</a>
                <% if (user.role === 'admin') { %>
                    <a href="/admin/users" class="block px-4 py-2.5 text-red-400 hover:text-white hover:bg-red-900/30 rounded-xl text-sm font-medium transition border border-red-500/10 mt-4">Kelola User</a>
                <% } %>
            </nav>      
        </div>

        <div class="border-t border-zinc-800 pt-4 flex items-center justify-between">
            <div>
                <p class="text-xs text-zinc-500">Masuk sebagai:</p>
                <% if (user.username === 'admin' || user.username === 'gudang' || user.username === 'pimpinan') { %>
                    <p class="text-sm font-semibold text-zinc-200"><%= user.nama %></p>
                    <div class="mt-1">
                        <span class="text-[10px] bg-[#5551ff]/20 text-indigo-400 px-2 py-0.5 rounded border border-[#5551ff]/30 font-medium capitalize"><%= user.role %></span>
                    </div>
                <% } else { %>
                    <p class="text-sm font-semibold text-zinc-200"><%= user.nama %></p>
                <% } %>

                <% if (user.role === 'admin') { %>
                    <div class="mt-2">
                        <a href="/admin/users" class="inline-block text-xs bg-red-500/20 text-red-400 hover:bg-red-500/30 px-2 py-1 rounded border border-red-500/30 font-medium transition">Kelola User</a>
                    </div>
                <% } %>
            </div>
            <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition shrink-0 ml-2">Logout</a>
        </div>
    </div>

    <div class="md:hidden bg-zinc-900 border-b border-zinc-800 p-4">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="bg-[#5551ff] rounded-full p-0.5 flex items-center justify-center w-8 h-8 overflow-hidden shrink-0">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-full">
                </div>
                <span class="font-bold tracking-tight bg-gradient-to-r from-white via-zinc-200 to-zinc-400 bg-clip-text text-transparent drop-shadow-sm">
                    InvenioWeb
                </span>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-xs text-zinc-400">
                    <%= user.nama %>
                    <% if (user.username === 'admin' || user.username === 'gudang' || user.username === 'pimpinan') { %>
                        (<%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>)
                    <% } %>
                </span>
                <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition">Logout</a>
            </div>
        </div>
        
        <nav class="flex flex-wrap gap-2">
            <a href="/dashboard" class="px-3 py-1.5 bg-[#5551ff] text-white rounded-lg text-xs font-medium shadow-md shadow-[#5551ff]/10">Dashboard</a>
            <a href="/barang" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition hover:text-white">Barang</a>
            <a href="/supplier" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition hover:text-white">Supplier</a>
            <a href="/transaksi" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition hover:text-white">Transaksi</a>
            <a href="/laporan" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition hover:text-white">Laporan</a>
            <a href="/barang-terjual" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition hover:text-white">Barang Terjual</a>
            <% if (user.role === 'admin') { %>
                <a href="/admin/users" class="px-3 py-1.5 bg-red-900/50 text-red-400 rounded-lg text-xs font-medium border border-red-500/20">Kelola User</a>
            <% } %>
        </nav>
    </div>

    <div class="flex-grow p-6 md:p-10 overflow-y-auto">
        <header class="mb-8">
            <h1 class="text-2xl md:text-3xl font-bold tracking-tight">Sistem Inventaris Barang Toko</h1>
            <p class="text-zinc-400 text-sm mt-1">Metode Pengembangan: Waterfall SDLC Model</p>
        </header>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mb-10">
            <div class="p-6 bg-zinc-900 border border-zinc-800 rounded-xl relative overflow-hidden">
                <p class="text-xs text-zinc-500 font-medium uppercase tracking-wider">Total Varian Produk</p>
                <p class="text-3xl font-bold mt-2 text-indigo-400"><%= totalBarang %></p>
                <div class="absolute right-2 bottom-2 text-6xl font-bold text-zinc-800/10">📦</div>
            </div>
            <div class="p-6 bg-zinc-900 border border-zinc-800 rounded-xl relative overflow-hidden">
                <p class="text-xs text-zinc-500 font-medium uppercase tracking-wider">Mitra Penyuplai (Supplier)</p>
                <p class="text-3xl font-bold mt-2 text-emerald-400"><%= totalSupplier %></p>
                <div class="absolute right-2 bottom-2 text-6xl font-bold text-zinc-800/10">🤝</div>
            </div>
            <div class="p-6 bg-zinc-900 border border-zinc-800 rounded-xl relative overflow-hidden">
                <p class="text-xs text-zinc-500 font-medium uppercase tracking-wider">Transaksi Barang Masuk</p>
                <p class="text-3xl font-bold mt-2 text-amber-400"><%= totalMasuk %></p>
                <div class="absolute right-2 bottom-2 text-6xl font-bold text-zinc-800/10">📥</div>
            </div>
            <div class="p-6 bg-zinc-900 border border-zinc-800 rounded-xl relative overflow-hidden">
                <p class="text-xs text-zinc-500 font-medium uppercase tracking-wider">Transaksi Barang Keluar</p>
                <p class="text-3xl font-bold mt-2 text-rose-400"><%= totalKeluar %></p>
                <div class="absolute right-2 bottom-2 text-6xl font-bold text-zinc-800/10">📤</div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8">
            <div class="lg:col-span-2 p-6 bg-zinc-900 border border-zinc-800 rounded-xl">
                <h3 class="text-lg font-bold mb-4 flex items-center gap-2">⚠️ Notifikasi Stok Produk Menipis</h3>
                <p class="text-zinc-400 text-xs mb-4">Segera hubungi supplier terkait jika stok menyentuh batas aman (minimal 5 item).</p>
                <div class="space-y-3">
                    <div class="p-4 bg-zinc-950 rounded-lg border border-zinc-800/50 flex justify-between items-center">
                        <div>
                            <p class="text-sm font-medium">Beras Premium 5kg</p>
                            <span class="text-xs text-zinc-500 font-mono">SUP-001 (PT. Sumber Rasa)</span>
                        </div>
                        <span class="text-xs font-bold text-rose-400 bg-rose-500/10 px-2 py-1 rounded border border-rose-500/20">Sisa 2 Pcs</span>
                    </div>
                    <div class="p-4 bg-zinc-950 rounded-lg border border-zinc-800/50 flex justify-between items-center">
                        <div>
                            <p class="text-sm font-medium">Minyak Goreng 2L</p>
                            <span class="text-xs text-zinc-500 font-mono">SUP-003 (Wilmar Retail)</span>
                        </div>
                        <span class="text-xs font-bold text-rose-400 bg-rose-500/10 px-2 py-1 rounded border border-rose-500/20">Sisa 4 Pcs</span>
                    </div>
                </div>
            </div>

            <div class="p-6 bg-zinc-900 border border-zinc-800 rounded-xl flex flex-col justify-between">
                <div>
                    <h3 class="text-lg font-bold mb-2">📊 Status Alur Waterfall</h3>
                    <p class="text-xs text-zinc-400 leading-relaxed">Sistem ini dikembangkan secara sekuensial terstruktur sesuai metodologi air terjun:</p>
                    
                    <div class="mt-4 space-y-2 text-xs">
                        <div class="flex items-center gap-2 text-zinc-500"><span class="text-emerald-400">✓</span> 1. Analisis Kebutuhan Toko</div>
                        <div class="flex items-center gap-2 text-zinc-500"><span class="text-emerald-400">✓</span> 2. Desain Database & ERD</div>
                        <div class="flex items-center gap-2 text-indigo-400">➔ 3. Tahap Coding & Implementasi</div>
                        <div class="flex items-center gap-2 text-zinc-600">⚪ 4. Pengujian Sistem Toko</div>
                    </div>
                </div>
                <div class="mt-6 pt-4 border-t border-zinc-800 text-[11px] text-zinc-500 text-center">
                    InvenioWeb v1.0.0 © 2026
                </div>
            </div>
        </div>

    </div>

</body>
</html>
