<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transaksi Inventoris Toko - InvenioWeb</title>
    <link rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0b0c10;
            color: #c5c6c7;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col md:flex-row antialiased select-none">

    <div class="hidden md:flex w-64 bg-[#1f2833] border-r border-gray-800 p-4 flex-col justify-between shrink-0 min-h-screen sticky top-0">
        <div>
            <div class="flex items-center gap-3 px-2 py-4 border-b border-gray-700 mb-6">
                <div class="w-10 h-10 bg-[#45f3ff] rounded-full flex items-center justify-center p-1 shadow-lg shadow-[#45f3ff]/20 overflow-hidden shrink-0">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-full">
                </div>
                <div>
                    <h1 class="text-white font-bold tracking-wide text-sm">InvenioWeb</h1>
                    <span class="text-[10px] text-[#45f3ff] font-medium tracking-wider uppercase">Market System</span>
                </div>
            </div>
            
            <nav class="space-y-1">
                <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all duration-200">
                    <span class="text-sm font-medium">Dashboard</span>
                </a>
                <a href="/barang" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all duration-200">
                    <span class="text-sm font-medium">Kelola Barang</span>
                </a>
                <a href="/supplier" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all duration-200">
                    <span class="text-sm font-medium">Kelola Supplier</span>
                </a>
                <a href="/transaksi" class="flex items-center gap-3 px-4 py-3 bg-gradient-to-r from-[#45f3ff]/20 to-transparent border-l-4 border-[#45f3ff] text-white rounded-r-lg transition-all">
                    <span class="text-sm font-medium">Kelola Transaksi</span>
                </a>
                <a href="/laporan" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all duration-200">
                    <span class="text-sm font-medium">Cetak Laporan</span>
                </a>
                <a href="/barang-terjual" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all duration-200">
                    <span class="text-sm font-medium">Barang Terjual</span>
                </a>
                <% if (user.role === 'admin') { %>
                    <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 text-red-400 hover:bg-red-950/20 hover:text-red-300 rounded-lg transition-all mt-2">
                        <span class="text-sm font-medium">Kelola User</span>
                    </a>
                <% } %>
            </nav>
        </div>
        
        <div class="bg-[#151a21] p-3 rounded-xl border border-gray-800 flex items-center justify-between shadow-inner">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 bg-purple-600 rounded-full flex items-center justify-center text-white text-xs font-bold uppercase border border-purple-500/30">
                    <%= user.nama.substring(0,2) %>
                </div>
                <div>
                    <p class="text-white text-xs font-semibold truncate max-w-[110px]"><%= user.nama %></p>
                    <span class="text-[10px] bg-purple-950 text-purple-300 px-1.5 py-0.5 rounded border border-purple-800/50 block w-max capitalize mt-0.5"><%= user.role %></span>
                </div>
            </div>
            <a href="/logout" class="text-gray-500 hover:text-red-400 p-1.5 hover:bg-gray-800/30 rounded-lg transition-colors" title="Log Out">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
            </a>
        </div>
    </div>

    <div class="md:hidden bg-[#1f2833] border-b border-gray-800 p-4">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="bg-[#45f3ff] rounded-full p-0.5 flex items-center justify-center w-8 h-8 overflow-hidden shrink-0">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-full">
                </div>
                <span class="font-bold tracking-tight text-white">
                    InvenioWeb
                </span>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-xs text-gray-400">
                    <%= user.nama %>
                    <% if (user.username === 'admin' || user.username === 'gudang' || user.username === 'pimpinan') { %>
                        (<%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>)
                    <% } %>
                </span>
                <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition">Logout</a>
            </div>
        </div>
        <nav class="flex flex-wrap gap-2">
            <a href="/dashboard" class="px-3 py-1.5 bg-[#151a21] text-gray-400 rounded-lg text-xs font-medium transition hover:text-white">Dashboard</a>
            <a href="/barang" class="px-3 py-1.5 bg-[#151a21] text-gray-400 rounded-lg text-xs font-medium transition hover:text-white">Barang</a>
            <a href="/supplier" class="px-3 py-1.5 bg-[#151a21] text-gray-400 rounded-lg text-xs font-medium transition hover:text-white">Supplier</a>
            <a href="/transaksi" class="px-3 py-1.5 bg-[#45f3ff] text-[#0b0c10] rounded-lg text-xs font-bold shadow-md">Transaksi</a>
            <a href="/laporan" class="px-3 py-1.5 bg-[#151a21] text-gray-400 rounded-lg text-xs font-medium transition hover:text-white">Laporan</a>
            <a href="/barang-terjual" class="px-3 py-1.5 bg-[#151a21] text-gray-400 rounded-lg text-xs font-medium transition hover:text-white">Barang Terjual</a>
            <% if (user.role === 'admin') { %>
                <a href="/admin/users" class="px-3 py-1.5 bg-red-950/50 text-red-400 rounded-lg text-xs font-medium border border-red-500/20">Kelola User</a>
            <% } %>
        </nav>
    </div>

    <div class="flex-grow p-6 md:p-10 overflow-y-auto w-full space-y-8 bg-[#0b0c10]">
        <header>
            <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-white">Transaksi Inventoris Toko</h1>
            <p class="text-gray-500 text-sm mt-1">Pencatatan sirkulasi barang masuk (inbound) dan barang keluar (outbound) secara realtime.</p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-[#1f2833] border border-gray-800 p-6 rounded-xl shadow-xl">
                <div class="flex items-center gap-2 mb-4">
                    <span>📥</span>
                    <h2 class="text-base font-bold text-amber-500">Input Transaksi Barang Masuk</h2>
                </div>
                <form action="/transaksi/masuk" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Pilih Produk Barang</label>
                        <select name="id_barang" class="w-full bg-[#0b0c10] border border-gray-800 rounded-lg p-2.5 text-sm focus:border-amber-500 outline-none text-white appearance-none" required>
                            <option value="" disabled selected>-- Pilih Produk --</option>
                            <% if (typeof barang !== 'undefined' && barang.length > 0) { %>
                                <% barang.forEach(b => { %>
                                    <option value="<%= b.id_barang %>" class="bg-[#1f2833]">
                                        <%= b.nama_barang %> (Sisa: <%= b.stok %> Pcs)
                                    </option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Jumlah Masuk</label>
                            <input type="number" name="jumlah" min="1" class="w-full bg-[#0b0c10] border border-gray-800 rounded-lg p-2.5 text-sm focus:border-amber-500 outline-none text-white" placeholder="Contoh: 50" required>
                        </div>
                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Tanggal Masuk</label>
                            <input type="date" name="tanggal" class="w-full bg-[#0b0c10] border border-gray-800 rounded-lg p-2.5 text-sm focus:border-amber-500 outline-none text-white text-gray-300" required>
                        </div>
                    </div>
                    
                    <button type="submit" class="w-full py-2.5 bg-amber-600 hover:bg-amber-500 text-white font-semibold rounded-lg text-sm transition shadow-lg shadow-amber-900/20 mt-2">
                        Simpan Transaksi Masuk
                    </button>
                </form>
            </div>

            <div class="bg-[#1f2833] border border-gray-800 p-6 rounded-xl shadow-xl">
                <div class="flex items-center gap-2 mb-4">
                    <span>📤</span>
                    <h2 class="text-base font-bold text-rose-500">Input Transaksi Barang Keluar</h2>
                </div>
                <form action="/transaksi/keluar" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Pilih Produk Barang</label>
                        <select name="id_barang" class="w-full bg-[#0b0c10] border border-gray-800 rounded-lg p-2.5 text-sm focus:border-rose-500 outline-none text-white appearance-none" required>
                            <option value="" disabled selected>-- Pilih Produk --</option>
                            <% if (typeof barang !== 'undefined' && barang.length > 0) { %>
                                <% barang.forEach(b => { %>
                                    <option value="<%= b.id_barang %>" class="bg-[#1f2833]">
                                        <%= b.nama_barang %> (Sisa: <%= b.stok %> Pcs)
                                    </option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Jumlah Keluar</label>
                            <input type="number" name="jumlah" min="1" class="w-full bg-[#0b0c10] border border-gray-800 rounded-lg p-2.5 text-sm focus:border-rose-500 outline-none text-white" placeholder="Contoh: 10" required>
                        </div>
                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Tanggal Keluar</label>
                            <input type="date" name="tanggal" class="w-full bg-[#0b0c10] border border-gray-800 rounded-lg p-2.5 text-sm focus:border-rose-500 outline-none text-white text-gray-300" required>
                        </div>
                    </div>
                    
                    <button type="submit" class="w-full py-2.5 bg-rose-600 hover:bg-rose-500 text-white font-semibold rounded-lg text-sm transition shadow-lg shadow-rose-900/20 mt-2">
                        Simpan Transaksi Keluar
                    </button>
                </form>
            </div>
        </div>

        <div class="bg-[#1f2833] border border-gray-800 rounded-xl shadow-2xl overflow-hidden">
            <div class="flex items-center gap-2 p-6 bg-[#151a21]/50 border-b border-gray-800">
                <span>📜</span>
                <h2 class="text-base font-bold text-white">Log Riwayat Transaksi Terbaru</h2>
            </div>
            
            <div class="overflow-x-auto w-full">
                <table class="w-full text-left border-collapse min-w-[600px]">
                    <thead>
                        <tr class="border-b border-gray-800 text-gray-400 text-xs font-semibold uppercase tracking-wider bg-[#151a21]/30">
                            <th class="p-4">Waktu & Tanggal</th>
                            <th class="p-4">Nama Produk</th>
                            <th class="p-4 text-center">Tipe</th>
                            <th class="p-4 text-center">Jumlah</th>
                            <th class="p-4 text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-800/60 text-sm text-gray-300">
                        <% if (typeof transaksi === 'undefined' || transaksi.length === 0) { %>
                            <tr>
                                <td colspan="5" class="p-8 text-center text-gray-500 italic">
                                    Belum ada log aktivitas transaksi masuk atau keluar saat ini.
                                </td>
                            </tr>
                        <% } else { %>
                            <% transaksi.forEach(t => { %>
                                <tr class="hover:bg-[#151a21]/40 transition">
                                    <td class="p-4 text-gray-400 text-xs font-mono"><%= new Date(t.tanggal).toLocaleString('id-ID', { dateStyle: 'medium', timeStyle: 'short' }) %></td>
                                    <td class="p-4 font-medium text-white"><%= t.nama_barang %></td>
                                    <td class="p-4 text-center">
                                        <span class="px-2.5 py-1 rounded-md text-xs font-bold tracking-wide <%= t.jenis_transaksi === 'masuk' ? 'bg-amber-500/10 text-amber-400 border border-amber-500/20' : 'bg-rose-500/10 text-rose-400 border border-rose-500/20' %>">
                                            <%= t.jenis_transaksi === 'masuk' ? 'MASUK' : 'KELUAR' %>
                                        </span>
                                    </td>
                                    <td class="p-4 text-center font-bold font-mono text-gray-100"><%= t.jumlah %> Pcs</td>
                                    <td class="p-4 text-center">
                                        <a href="/transaksi/hapus/<%= t.id_transaksi %>" 
                                           onclick="return confirm('⚠️ Batalkan transaksi ini?\nStok barang terkait akan disesuaikan kembali secara otomatis ke kondisi sebelumnya.')" 
                                           class="bg-rose-500/10 hover:bg-rose-500/20 border border-rose-500/20 text-rose-400 px-2.5 py-1.5 rounded-md text-xs font-semibold transition inline-block">
                                            🗑️ Hapus
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        document.querySelectorAll('input[type="date"]').forEach(input => {
            if(!input.value) {
                input.value = new Date().toISOString().split('T')[0];
            }
        });
    </script>
</body>
</html>
