<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transaksi Inventoris Toko - InvenioWeb</title>
    <link rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
    </style>
</head>
<body class="bg-zinc-950 text-white min-h-screen flex flex-col md:flex-row antialiased">

    <div class="hidden md:flex w-64 bg-zinc-900 border-r border-zinc-800 p-6 flex-col justify-between shrink-0 min-h-screen sticky top-0">
        <div>
            <div class="flex items-center gap-3 mb-8 px-2">
                <div class="bg-[#5551ff] rounded-full p-1 shadow-lg shadow-[#5551ff]/20 flex items-center justify-center w-11 h-11 overflow-hidden shrink-0">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-full">
                </div>
                <span class="text-xl font-bold tracking-tight bg-gradient-to-r from-white via-zinc-200 to-zinc-400 bg-clip-text text-transparent drop-shadow-sm">
                    InvenioWeb
                </span>
            </div>
            
            <nav class="space-y-1.5">
                <a href="/dashboard" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Dashboard</a>
                <a href="/barang" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Kelola Barang</a>
                <a href="/supplier" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Kelola Supplier</a>
                <a href="/transaksi" class="block px-4 py-2.5 bg-[#5551ff] text-white rounded-xl text-sm font-medium transition-all duration-200 shadow-md shadow-[#5551ff]/10">Kelola Transaksi</a>
                <a href="/laporan" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Cetak Laporan</a>
                <a href="/barang-terjual" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Barang Terjual</a>
                <% if (user.role === 'admin') { %>
                    <a href="/admin/users" class="block px-4 py-2.5 text-red-400 hover:text-white hover:bg-red-900/30 rounded-xl text-sm font-medium transition border border-red-500/10 mt-4">Kelola User</a>
                <% } %>
            </nav>
        </div>
        
        <div class="border-t border-zinc-800 pt-4 flex items-center justify-between">
            <div>
                <p class="text-xs text-zinc-500">Masuk sebagai:</p>
                <% if (user.username === 'admin' || user.username === 'gudang' || user.username === 'pimpinan') { %>
                    <p class="text-sm font-semibold text-zinc-200"><%= user.nama %></p>
                    <div class="mt-1">
                        <span class="text-[10px] bg-[#5551ff]/20 text-indigo-400 px-2 py-0.5 rounded border border-[#5551ff]/30 font-medium capitalize"><%= user.role %></span>
                    </div>
                <% } else { %>
                    <p class="text-sm font-semibold text-zinc-200"><%= user.nama %></p>
                <% } %>

                <% if (user.role === 'admin') { %>
                    <div class="mt-2">
                        <a href="/admin/users" class="inline-block text-xs bg-red-500/20 text-red-400 hover:bg-red-500/30 px-2 py-1 rounded border border-red-500/30 font-medium transition">Kelola User</a>
                    </div>
                <% } %>
            </div>
            <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition shrink-0 ml-2">Logout</a>
        </div>
    </div>

    <div class="md:hidden bg-zinc-900 border-b border-zinc-800 p-4">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="bg-[#5551ff] rounded-full p-0.5 flex items-center justify-center w-8 h-8 overflow-hidden shrink-0">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-full">
                </div>
                <span class="font-bold tracking-tight bg-gradient-to-r from-white via-zinc-200 to-zinc-400 bg-clip-text text-transparent drop-shadow-sm">
                    InvenioWeb
                </span>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-xs text-zinc-400">
                    <%= user.nama %>
                    <% if (user.username === 'admin' || user.username === 'gudang' || user.username === 'pimpinan') { %>
                        (<%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>)
                    <% } %>
                </span>
                <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition">Logout</a>
            </div>
        </div>
        <nav class="flex flex-wrap gap-2">
            <a href="/dashboard" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition hover:text-white">Dashboard</a>
            <a href="/barang" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition hover:text-white">Barang</a>
            <a href="/supplier" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition hover:text-white">Supplier</a>
            <a href="/transaksi" class="px-3 py-1.5 bg-[#5551ff] text-white rounded-lg text-xs font-medium shadow-md shadow-[#5551ff]/10">Transaksi</a>
            <a href="/laporan" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition hover:text-white">Laporan</a>
            <a href="/barang-terjual" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium transition hover:text-white">Barang Terjual</a>
            <% if (user.role === 'admin') { %>
                <a href="/admin/users" class="px-3 py-1.5 bg-red-900/50 text-red-400 rounded-lg text-xs font-medium border border-red-500/20">Kelola User</a>
            <% } %>
        </nav>
    </div>

    <div class="flex-grow p-6 md:p-10 overflow-y-auto w-full space-y-8">
        <header>
            <h1 class="text-2xl md:text-3xl font-bold tracking-tight">Transaksi Inventoris Toko</h1>
            <p class="text-zinc-400 text-sm mt-1">Pencatatan sirkulasi barang masuk (inbound) dan barang keluar (outbound) secara realtime.</p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-zinc-900/50 border border-zinc-800 p-6 rounded-xl shadow-xl">
                <div class="flex items-center gap-2 mb-4">
                    <span>📥</span>
                    <h2 class="text-base font-bold text-amber-500">Input Transaksi Barang Masuk</h2>
                </div>
                <form action="/transaksi/masuk" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-xs text-zinc-500 mb-1">Pilih Produk Barang</label>
                        <select name="id_barang" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-amber-500 outline-none text-white appearance-none" required>
                            <option value="" disabled selected>-- Pilih Produk --</option>
                            <% if (typeof barang !== 'undefined' && barang.length > 0) { %>
                                <% barang.forEach(b => { %>
                                    <option value="<%= b.id_barang %>" class="bg-zinc-900">
                                        <%= b.nama_barang %> (Sisa: <%= b.stok %> Pcs)
                                    </option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-zinc-500 mb-1">Jumlah Masuk</label>
                            <input type="number" name="jumlah" min="1" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-amber-500 outline-none text-white" placeholder="Contoh: 50" required>
                        </div>
                        <div>
                            <label class="block text-xs text-zinc-500 mb-1">Tanggal Masuk</label>
                            <input type="date" name="tanggal" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-amber-500 outline-none text-white text-zinc-300" required>
                        </div>
                    </div>
                    
                    <button type="submit" class="w-full py-2.5 bg-amber-600 hover:bg-amber-500 text-white font-semibold rounded-lg text-sm transition shadow-lg shadow-amber-900/20 mt-2">
                        Simpan Transaksi Masuk
                    </button>
                </form>
            </div>

            <div class="bg-zinc-900/50 border border-zinc-800 p-6 rounded-xl shadow-xl">
                <div class="flex items-center gap-2 mb-4">
                    <span>📤</span>
                    <h2 class="text-base font-bold text-rose-500">Input Transaksi Barang Keluar</h2>
                </div>
                <form action="/transaksi/keluar" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-xs text-zinc-500 mb-1">Pilih Produk Barang</label>
                        <select name="id_barang" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-rose-500 outline-none text-white appearance-none" required>
                            <option value="" disabled selected>-- Pilih Produk --</option>
                            <% if (typeof barang !== 'undefined' && barang.length > 0) { %>
                                <% barang.forEach(b => { %>
                                    <option value="<%= b.id_barang %>" class="bg-zinc-900">
                                        <%= b.nama_barang %> (Sisa: <%= b.stok %> Pcs)
                                    </option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-zinc-500 mb-1">Jumlah Keluar</label>
                            <input type="number" name="jumlah" min="1" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-rose-500 outline-none text-white" placeholder="Contoh: 10" required>
                        </div>
                        <div>
                            <label class="block text-xs text-zinc-500 mb-1">Tanggal Keluar</label>
                            <input type="date" name="tanggal" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-rose-500 outline-none text-white text-zinc-300" required>
                        </div>
                    </div>
                    
                    <button type="submit" class="w-full py-2.5 bg-rose-600 hover:bg-rose-500 text-white font-semibold rounded-lg text-sm transition shadow-lg shadow-rose-900/20 mt-2">
                        Simpan Transaksi Keluar
                    </button>
                </form>
            </div>
        </div>

        <div class="bg-zinc-900 border border-zinc-800 rounded-xl shadow-2xl overflow-hidden">
            <div class="flex items-center gap-2 p-6 bg-zinc-900/50 border-b border-zinc-800">
                <span>📜</span>
                <h2 class="text-base font-bold text-white">Log Riwayat Transaksi Terbaru</h2>
            </div>
            
            <div class="overflow-x-auto w-full">
                <table class="w-full text-left border-collapse min-w-[600px]">
                    <thead>
                        <tr class="border-b border-zinc-800 text-zinc-400 text-xs font-semibold uppercase tracking-wider bg-zinc-900/30">
                            <th class="p-4">Waktu & Tanggal</th>
                            <th class="p-4">Nama Produk</th>
                            <th class="p-4 text-center">Tipe</th>
                            <th class="p-4 text-center">Jumlah</th>
                            <th class="p-4 text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-zinc-800/60 text-sm text-zinc-300">
                        <% if (typeof transaksi === 'undefined' || transaksi.length === 0) { %>
                            <tr>
                                <td colspan="5" class="p-8 text-center text-zinc-500 italic">
                                    Belum ada log aktivitas transaksi masuk atau keluar saat ini.
                                </td>
                            </tr>
                        <% } else { %>
                            <% transaksi.forEach(t => { %>
                                <tr class="hover:bg-zinc-800/20 transition">
                                    <td class="p-4 text-zinc-400 text-xs font-mono"><%= new Date(t.tanggal).toLocaleString('id-ID', { dateStyle: 'medium', timeStyle: 'short' }) %></td>
                                    <td class="p-4 font-medium text-white"><%= t.nama_barang %></td>
                                    <td class="p-4 text-center">
                                        <span class="px-2.5 py-1 rounded-md text-xs font-bold tracking-wide <%= t.jenis_transaksi === 'masuk' ? 'bg-amber-500/10 text-amber-400 border border-amber-500/20' : 'bg-rose-500/10 text-rose-400 border border-rose-500/20' %>">
                                            <%= t.jenis_transaksi === 'masuk' ? 'MASUK' : 'KELUAR' %>
                                        </span>
                                    </td>
                                    <td class="p-4 text-center font-bold font-mono text-zinc-100"><%= t.jumlah %> Pcs</td>
                                    <td class="p-4 text-center">
                                        <a href="/transaksi/hapus/<%= t.id_transaksi %>" 
                                           onclick="return confirm('⚠️ Batalkan transaksi ini?\nStok barang terkait akan disesuaikan kembali secara otomatis ke kondisi sebelumnya.')" 
                                           class="bg-rose-500/10 hover:bg-rose-500/20 border border-rose-500/20 text-rose-400 px-2.5 py-1.5 rounded-md text-xs font-semibold transition inline-block">
                                            🗑️ Hapus
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        document.querySelectorAll('input[type="date"]').forEach(input => {
            if(!input.value) {
                input.value = new Date().toISOString().split('T')[0];
            }
        });
    </script>
</body>
</html>
