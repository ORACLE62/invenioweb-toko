<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transaksi Inventoris Toko - InvenioWeb</title>
    <link rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-white font-sans min-h-screen flex flex-col md:flex-row">

    <div class="hidden md:flex w-64 bg-zinc-900 border-r border-zinc-800 p-6 flex-col justify-between shrink-0">
        <div>
            <div class="flex items-center gap-3 mb-8">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-indigo-500 to-pink-500 flex items-center justify-center font-bold">I</div>
                <span class="font-bold text-lg tracking-wider">InvenioWeb</span>
            </div>
            <nav class="space-y-2">
                <a href="/dashboard" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Dashboard</a>
                <a href="/barang" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Kelola Barang</a>
                <a href="/supplier" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Kelola Supplier</a>
                <a href="/transaksi" class="block px-4 py-2.5 bg-indigo-600 rounded-lg text-sm font-medium transition">Kelola Transaksi</a>
                <a href="/laporan" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Cetak Laporan</a>
            </nav>
        </div>
        <div class="border-t border-zinc-800 pt-4 flex items-center justify-between">
            <div>
                <p class="text-xs text-zinc-500">Masuk sebagai:</p>
                <p class="text-sm font-semibold text-zinc-200"><%= user.nama %> (Admin)</p>
                <div class="mt-1">
                    <span class="text-xs bg-indigo-500/20 text-indigo-400 px-2.5 py-0.5 rounded border border-indigo-500/30 font-medium">Admin</span>
                </div>
            </div>
            <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition">Logout</a>
        </div>
    </div>

    <div class="md:hidden bg-zinc-900 border-b border-zinc-800 p-4">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-indigo-500 to-pink-500 flex items-center justify-center font-bold">I</div>
                <span class="font-bold text-lg tracking-wider">InvenioWeb</span>
            </div>
            <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition">Logout</a>
        </div>
        <nav class="flex flex-wrap gap-2">
            <a href="/dashboard" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Dashboard</a>
            <a href="/barang" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Barang</a>
            <a href="/supplier" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Supplier</a>
            <a href="/transaksi" class="px-3 py-1.5 bg-indigo-600 text-white rounded-lg text-xs font-medium">Transaksi</a>
            <a href="/laporan" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Laporan</a>
        </nav>
    </div>

    <div class="flex-grow p-4 md:p-10 overflow-y-auto w-full space-y-8">
        
        <header>
            <h1 class="text-2xl md:text-3xl font-bold tracking-tight">Transaksi Inventoris Toko</h1>
            <p class="text-zinc-400 text-sm mt-1">Pencatatan sirkulasi barang masuk (inbound) dan barang keluar (outbound) secara realtime.</p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            
            <div class="bg-zinc-900/50 border border-zinc-800 p-6 rounded-xl shadow-xl">
                <div class="flex items-center gap-2 mb-4">
                    <span>📥</span>
                    <h2 class="text-base font-bold text-amber-500">Input Transaksi Barang Masuk</h2>
                </div>
                <form action="/transaksi/masuk" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-xs text-zinc-500 mb-1">Pilih Produk Barang</label>
                        <select name="id_barang" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-amber-500 outline-none text-white" required>
                            <option value="" disabled selected>-- Pilih Produk --</option>
                            <% if (typeof barang !== 'undefined' && barang.length > 0) { %>
                                <% barang.forEach(b => { %>
                                    <option value="<%= b.id_barang %>" class="bg-zinc-900">
                                        <%= b.nama_barang %> (Sisa: <%= b.stok %> Pcs)
                                    </option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-zinc-500 mb-1">Jumlah Masuk</label>
                            <input type="number" name="jumlah" min="1" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-amber-500 outline-none text-white" placeholder="Contoh: 50" required>
                        </div>
                        <div>
                            <label class="block text-xs text-zinc-500 mb-1">Tanggal Masuk</label>
                            <input type="date" name="tanggal" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-amber-500 outline-none text-white" required>
                        </div>
                    </div>
                    
                    <button type="submit" class="w-full py-2.5 bg-amber-600 hover:bg-amber-500 text-white font-semibold rounded-lg text-sm transition shadow-lg shadow-amber-900/20 mt-2">
                        Simpan Transaksi Masuk
                    </button>
                </form>
            </div>

            <div class="bg-zinc-900/50 border border-zinc-800 p-6 rounded-xl shadow-xl">
                <div class="flex items-center gap-2 mb-4">
                    <span>📤</span>
                    <h2 class="text-base font-bold text-rose-500">Input Transaksi Barang Keluar</h2>
                </div>
                <form action="/transaksi/keluar" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-xs text-zinc-500 mb-1">Pilih Produk Barang</label>
                        <select name="id_barang" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-rose-500 outline-none text-white" required>
                            <option value="" disabled selected>-- Pilih Produk --</option>
                            <% if (typeof barang !== 'undefined' && barang.length > 0) { %>
                                <% barang.forEach(b => { %>
                                    <option value="<%= b.id_barang %>" class="bg-zinc-900">
                                        <%= b.nama_barang %> (Sisa: <%= b.stok %> Pcs)
                                    </option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-zinc-500 mb-1">Jumlah Keluar</label>
                            <input type="number" name="jumlah" min="1" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-rose-500 outline-none text-white" placeholder="Contoh: 10" required>
                        </div>
                        <div>
                            <label class="block text-xs text-zinc-500 mb-1">Tanggal Keluar</label>
                            <input type="date" name="tanggal" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-rose-500 outline-none text-white" required>
                        </div>
                    </div>
                    
                    <button type="submit" class="w-full py-2.5 bg-rose-600 hover:bg-rose-500 text-white font-semibold rounded-lg text-sm transition shadow-lg shadow-rose-900/20 mt-2">
                        Simpan Transaksi Keluar
                    </button>
                </form>
            </div>

        </div>

        <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 shadow-2xl">
            <div class="flex items-center gap-2 mb-4">
                <span>📜</span>
                <h2 class="text-base font-bold text-white">Log Riwayat Transaksi Terbaru</h2>
            </div>
            
            <div class="overflow-x-auto w-full">
                <table class="w-full text-left border-collapse min-w-[600px]">
                    <thead>
                        <tr class="border-b border-zinc-800 text-zinc-500 text-xs font-bold uppercase tracking-wider">
                            <th class="pb-3">Waktu & Tanggal</th>
                            <th class="pb-3">Nama Produk</th>
                            <th class="pb-3 text-center">Tipe</th>
                            <th class="pb-3 text-center">Jumlah</th>
                            <th class="pb-3 text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-zinc-800/60 text-sm text-zinc-300">
                        <% if (transaksi.length === 0) { %>
                            <tr>
                                <td colspan="5" class="p-8 text-center text-zinc-600 italic">
                                    Belum ada log aktivitas transaksi masuk atau keluar hari ini.
                                </td>
                            </tr>
                        <% } else { %>
                            <% transaksi.forEach(t => { %>
                                <tr class="hover:bg-zinc-800/20 transition">
                                    <td class="py-3.5 text-zinc-400 text-xs"><%= new Date(t.tanggal).toLocaleString('id-ID') %></td>
                                    <td class="py-3.5 font-medium text-white"><%= t.nama_barang %></td>
                                    <td class="py-3.5 text-center">
                                        <span class="px-2 py-0.5 rounded text-xs font-bold <%= t.jenis_transaksi === 'masuk' ? 'bg-amber-500/10 text-amber-400 border border-amber-500/20' : 'bg-rose-500/10 text-rose-400 border border-rose-500/20' %>">
                                            <%= t.jenis_transaksi === 'masuk' ? 'MASUK' : 'KELUAR' %>
                                        </span>
                                    </td>
                                    <td class="py-3.5 text-center font-bold font-mono text-zinc-100"><%= t.jumlah %> Pcs</td>
                                    <td class="py-3.5 text-center">
                                        <a href="/transaksi/hapus/<%= t.id_transaksi %>" 
                                           onclick="return confirm('⚠️ Batalkan transaksi ini?\nStok barang terkait akan disesuaikan kembali secara otomatis.')" 
                                           class="bg-rose-500/10 hover:bg-rose-500/20 text-rose-400 px-2.5 py-1 rounded text-xs transition">
                                            Hapus
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <script>
        document.querySelectorAll('input[type="date"]').forEach(input => {
            if(!input.value) {
                input.value = new Date().toISOString().split('T')[0];
            }
        });
    </script>
</body>
</html>
