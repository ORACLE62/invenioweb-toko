<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transaksi Inventoris Toko - InvenioWeb</title>
    <link class="no-print" rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0c1017;
            color: #c9d1d9;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col md:flex-row antialiased select-none">

    <div class="no-print hidden md:flex w-64 bg-[#12161f] border-r border-[#1f242e] p-4 flex-col justify-between shrink-0 min-h-screen sticky top-0">
        <div>
            <div class="flex items-center gap-3 px-2 py-4 border-b border-[#1f242e] mb-6">
                <div class="w-10 h-10 bg-cyan-500/10 border border-cyan-500/30 rounded-lg flex items-center justify-center p-1.5 shadow-lg shadow-cyan-500/10 overflow-hidden shrink-0">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-md">
                </div>
                <div>
                    <h1 class="text-white font-bold tracking-wide text-sm">InvenioWeb</h1>
                    <span class="text-[11px] text-cyan-400 font-semibold tracking-wider uppercase block">Market System</span>
                </div>
            </div>
            
            <nav class="space-y-1">
                <a href="/dashboard" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-chart-pie w-5 text-center"></i> <span>Dashboard</span>
                </a>
                <a href="/barang" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-box w-5 text-center"></i> <span>Kelola Barang</span>
                </a>
                <a href="/supplier" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-truck w-5 text-center"></i> <span>Kelola Supplier</span>
                </a>
                <a href="/transaksi" class="flex items-center gap-3 px-4 py-2.5 bg-[#1c212c] text-white border-l-4 border-cyan-500 rounded-r-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-exchange-alt w-5 text-center text-cyan-400"></i> <span>Kelola Transaksi</span>
                </a>
                <a href="/laporan" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-file-invoice-dollar w-5 text-center"></i> <span>Cetak Laporan</span>
                </a>
                <a href="/barang-terjual" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-receipt w-5 text-center"></i> <span>Barang Terjual</span>
                </a>
                <% if (user.role === 'admin') { %>
                    <a href="/admin/users" class="flex items-center gap-3 px-4 py-2.5 text-red-400 hover:bg-red-950/20 hover:text-red-300 rounded-lg text-sm font-medium transition duration-150 mt-4">
                        <i class="fa-solid fa-users-cog w-5 text-center"></i> <span>Kelola User</span>
                    </a>
                <% } %>
            </nav>
        </div>
        
        <div class="bg-[#171b26] p-3 rounded-xl border border-[#222834] flex items-center justify-between">
            <div class="flex items-center gap-2.5">
                <div class="w-8 h-8 bg-purple-600 rounded-full flex items-center justify-center text-white text-xs font-bold uppercase">
                    <%= user.nama.substring(0,2) %>
                </div>
                <div class="leading-tight">
                    <p class="text-white text-xs font-semibold truncate max-w-[110px]"><%= user.nama %></p>
                    <span class="text-[10px] text-purple-400 font-medium capitalize block w-max mt-0.5"><%= user.role %></span>
                </div>
            </div>
            <a href="/logout" class="text-slate-500 hover:text-red-400 p-1.5 hover:bg-gray-800/30 rounded-lg transition-colors" title="Log Out">
                <i class="fa-solid fa-sign-out-alt"></i>
            </a>
        </div>
    </div>

    <div class="md:hidden bg-[#12161f] border-b border-[#1f242e] p-4 w-full">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-2">
                <div class="bg-cyan-500/10 border border-cyan-500/30 rounded-lg p-1 w-8 h-8 flex items-center justify-center overflow-hidden shrink-0">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-md">
                </div>
                <span class="font-bold text-sm tracking-tight text-white">InvenioWeb</span>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-xs text-slate-400 font-medium">
                    <%= user.nama %>
                    <% if (user.username === 'admin' || user.username === 'gudang' || user.username === 'pimpinan') { %>
                        (<%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>)
                    <% } %>
                </span>
                <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition">Logout</a>
            </div>
        </div>
        <nav class="flex flex-wrap gap-1.5">
            <a href="/dashboard" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Dashboard</a>
            <a href="/barang" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Barang</a>
            <a href="/supplier" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Supplier</a>
            <a href="/transaksi" class="px-3 py-1.5 bg-sky-500/20 text-sky-400 border border-sky-500/30 rounded-md text-xs font-medium">Transaksi</a>
            <a href="/laporan" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Laporan</a>
            <a href="/barang-terjual" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Barang Terjual</a>
        </nav>
    </div>

    <div class="flex-grow p-6 md:p-8 overflow-y-auto w-full space-y-6 bg-[#0c1017]">
        <header>
            <h1 class="text-xl md:text-2xl font-bold tracking-tight text-white">Transaksi Inventoris Toko</h1>
            <p class="text-slate-400 text-xs mt-1">Pencatatan sirkulasi barang masuk (inbound) dan barang keluar (outbound) secara realtime.</p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-[#161b22] border border-[#30363d] p-5 rounded-xl shadow-md">
                <div class="flex items-center gap-2 mb-4">
                    <i class="fa-solid fa-circle-arrow-down text-amber-500 text-sm"></i>
                    <h2 class="text-sm font-bold text-white">Input Transaksi Barang Masuk</h2>
                </div>
                <form action="/transaksi/masuk" method="POST" class="space-y-4 text-xs">
                    <div>
                        <label class="block text-slate-400 mb-1">Pilih Produk Barang</label>
                        <select name="id_barang" class="w-full bg-[#0c1017] border border-[#30363d] rounded-lg p-2.5 text-xs focus:border-amber-500 outline-none text-white" required>
                            <option value="" disabled selected>-- Pilih Produk --</option>
                            <% if (typeof barang !== 'undefined' && barang.length > 0) { %>
                                <% barang.forEach(b => { %>
                                    <option value="<%= b.id_barang %>" class="bg-[#161b22]">
                                        <%= b.nama_barang %> (Sisa: <%= b.stok %> Pcs)
                                    </option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-slate-400 mb-1">Jumlah Masuk</label>
                            <input type="number" name="jumlah" min="1" class="w-full bg-[#0c1017] border border-[#30363d] rounded-lg p-2.5 text-xs focus:border-amber-500 outline-none text-white" placeholder="Contoh: 50" required>
                        </div>
                        <div>
                            <label class="block text-slate-400 mb-1">Tanggal Masuk</label>
                            <input type="date" name="tanggal" class="w-full bg-[#0c1017] border border-[#30363d] rounded-lg p-2.5 text-xs focus:border-amber-500 outline-none text-slate-300" required>
                        </div>
                    </div>
                    
                    <button type="submit" class="w-full py-2.5 bg-amber-600 hover:bg-amber-500 text-white font-semibold rounded-lg transition shadow-md shadow-amber-900/10 mt-2">
                        <i class="fa-solid fa-plus mr-1"></i> Simpan Transaksi Masuk
                    </button>
                </form>
            </div>

            <div class="bg-[#161b22] border border-[#30363d] p-5 rounded-xl shadow-md">
                <div class="flex items-center gap-2 mb-4">
                    <i class="fa-solid fa-circle-arrow-up text-rose-500 text-sm"></i>
                    <h2 class="text-sm font-bold text-white">Input Transaksi Barang Keluar</h2>
                </div>
                <form action="/transaksi/keluar" method="POST" class="space-y-4 text-xs">
                    <div>
                        <label class="block text-slate-400 mb-1">Pilih Produk Barang</label>
                        <select name="id_barang" class="w-full bg-[#0c1017] border border-[#30363d] rounded-lg p-2.5 text-xs focus:border-rose-500 outline-none text-white" required>
                            <option value="" disabled selected>-- Pilih Produk --</option>
                            <% if (typeof barang !== 'undefined' && barang.length > 0) { %>
                                <% barang.forEach(b => { %>
                                    <option value="<%= b.id_barang %>" class="bg-[#161b22]">
                                        <%= b.nama_barang %> (Sisa: <%= b.stok %> Pcs)
                                    </option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-slate-400 mb-1">Jumlah Keluar</label>
                            <input type="number" name="jumlah" min="1" class="w-full bg-[#0c1017] border border-[#30363d] rounded-lg p-2.5 text-xs focus:border-rose-500 outline-none text-white" placeholder="Contoh: 10" required>
                        </div>
                        <div>
                            <label class="block text-slate-400 mb-1">Tanggal Keluar</label>
                            <input type="date" name="tanggal" class="w-full bg-[#0c1017] border border-[#30363d] rounded-lg p-2.5 text-xs focus:border-rose-500 outline-none text-slate-300" required>
                        </div>
                    </div>
                    
                    <button type="submit" class="w-full py-2.5 bg-rose-600 hover:bg-rose-500 text-white font-semibold rounded-lg transition shadow-md shadow-rose-900/10 mt-2">
                        <i class="fa-solid fa-minus mr-1"></i> Simpan Transaksi Keluar
                    </button>
                </form>
            </div>
        </div>

        <div class="bg-[#161b22] border border-[#30363d] rounded-xl shadow-md overflow-hidden">
            <div class="flex items-center gap-2 p-4 bg-[#12161f] border-b border-[#30363d]">
                <i class="fa-solid fa-clock-rotate-left text-slate-400 text-sm"></i>
                <h2 class="text-sm font-bold text-white">Log Riwayat Transaksi Terbaru</h2>
            </div>
            
            <div class="overflow-x-auto w-full">
                <table class="w-full text-left border-collapse min-w-[600px]">
                    <thead>
                        <tr class="border-b border-[#30363d] text-slate-400 text-xs font-semibold uppercase tracking-wider bg-[#12161f]/50">
                            <th class="p-4">Waktu & Tanggal</th>
                            <th class="p-4">Nama Produk</th>
                            <th class="p-4 text-center">Tipe</th>
                            <th class="p-4 text-center">Jumlah</th>
                            <th class="p-4 text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#30363d] text-xs text-slate-300">
                        <% if (typeof transaksi === 'undefined' || transaksi.length === 0) { %>
                            <tr>
                                <td colspan="5" class="p-8 text-center text-slate-500 italic">
                                    Belum ada log aktivitas transaksi masuk atau keluar saat ini.
                                </td>
                            </tr>
                        <% } else { %>
                            <% transaksi.forEach(t => { %>
                                <tr class="hover:bg-[#12161f]/40 transition">
                                    <td class="p-4 text-slate-400 font-mono"><%= new Date(t.tanggal).toLocaleString('id-ID', { dateStyle: 'medium', timeStyle: 'short' }) %></td>
                                    <td class="p-4 font-medium text-white"><%= t.nama_barang %></td>
                                    <td class="p-4 text-center">
                                        <span class="px-2.5 py-1 rounded-md text-[10px] font-bold tracking-wide <%= t.jenis_transaksi === 'masuk' ? 'bg-amber-500/10 text-amber-400 border border-amber-500/20' : 'bg-rose-500/10 text-rose-400 border border-rose-500/20' %>">
                                            <%= t.jenis_transaksi === 'masuk' ? 'MASUK' : 'KELUAR' %>
                                        </span>
                                    </td>
                                    <td class="p-4 text-center font-bold font-mono text-slate-100"><%= t.jumlah %> Pcs</td>
                                    <td class="p-4 text-center">
                                        <a href="/transaksi/hapus/<%= t.id_transaksi %>" 
                                           onclick="return confirm('⚠️ Batalkan transaksi ini?\nStok barang terkait akan disesuaikan kembali secara otomatis ke kondisi sebelumnya.')" 
                                           class="bg-rose-500/10 hover:bg-rose-500/20 border border-rose-500/20 text-rose-400 px-2.5 py-1.5 rounded-md font-semibold transition inline-block">
                                            <i class="fa-solid fa-trash-can mr-1"></i> Hapus
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        document.querySelectorAll('input[type="date"]').forEach(input => {
            if(!input.value) {
                input.value = new Date().toISOString().split('T')[0];
            }
        });
    </script>
</body>
</html>
