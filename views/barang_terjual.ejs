<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laporan Penjualan - InvenioWeb</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0b0f19;
        }
        @media print {
            .no-print {
                display: none !important;
            }
            body, .main-content {
                background: white !important;
                color: black !important;
                padding: 0 !important;
                margin: 0 !important;
            }
            .print-container {
                width: 100% !important;
                max-width: 100% !important;
                position: absolute;
                left: 0;
                top: 0;
            }
            .print-card {
                border: 1px solid #d4d4d8 !important;
                background-color: transparent !important;
                box-shadow: none !important;
                color: black !important;
            }
            .text-white { color: #000000 !important; }
            .text-zinc-400, .text-zinc-300 { color: #3f3f46 !important; }
            .bg-zinc-950 { background-color: #f4f4f5 !important; border-bottom: 2px solid #000 !important; }
            .bg-gradient-to-r { background: transparent !important; }
        }
    </style>
</head>
<body class="text-zinc-100 min-h-screen flex">

    <aside class="no-print w-64 bg-[#0d121f] border-r border-zinc-800 flex flex-col justify-between p-5 shrink-0 fixed h-full">
        <div class="space-y-8">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-purple-600 rounded-xl flex items-center justify-center font-bold text-white shadow-lg shadow-purple-500/20">IWS</div>
                <span class="text-lg font-bold tracking-tight text-white">InvenioWeb</span>
            </div>
            <nav class="space-y-1">
                <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/40 rounded-xl text-sm transition-all">📋 Dashboard</a>
                <a href="/kelola-barang" class="flex items-center gap-3 px-4 py-3 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/40 rounded-xl text-sm transition-all">📦 Kelola Barang</a>
                <a href="/kelola-supplier" class="flex items-center gap-3 px-4 py-3 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/40 rounded-xl text-sm transition-all">🤝 Kelola Supplier</a>
                <a href="/kelola-transaksi" class="flex items-center gap-3 px-4 py-3 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/40 rounded-xl text-sm transition-all">⚙️ Kelola Transaksi</a>
                <a href="/cetak-laporan" class="flex items-center gap-3 px-4 py-3 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/40 rounded-xl text-sm transition-all">📊 Cetak Laporan</a>
                <a href="/barang-terjual" class="flex items-center gap-3 px-4 py-3 bg-purple-600 text-white font-semibold rounded-xl text-sm transition-all shadow-lg shadow-purple-600/10">🛒 Barang Terjual</a>
                <a href="/kelola-user" class="flex items-center gap-3 px-4 py-3 text-red-400/80 hover:text-red-400 hover:bg-red-500/5 rounded-xl text-sm transition-all">👤 Kelola User</a>
            </nav>
        </div>
        <div class="border-t border-zinc-800 pt-4 flex items-center justify-between">
            <div>
                <p class="text-xs text-zinc-500">Masuk sebagai</p>
                <p class="text-sm font-semibold text-zinc-200">Admin</p>
            </div>
            <a href="/logout" class="text-xs text-red-400 hover:underline">Logout</a>
        </div>
    </aside>

    <main class="main-content flex-1 md:pl-64 p-4 md:p-8 w-full">
        <div class="print-container max-w-5xl mx-auto space-y-6">
            
            <div class="flex justify-between items-center border-b border-zinc-800 pb-5">
                <div>
                    <h1 class="text-2xl font-bold text-white print:text-black">Laporan Realisasi Penjualan & Pendapatan</h1>
                    <p class="text-xs text-zinc-400 mt-1 print:text-zinc-700">Rekapitulasi berkas transaksi komersial dari aktivitas checkout belanja konsumen.</p>
                </div>
                <button onclick="window.print()" class="no-print bg-purple-600 hover:bg-purple-500 text-white font-semibold text-xs px-5 py-2.5 rounded-xl flex items-center gap-2 shadow-lg transition-all">
                    🖨️ Cetak Laporan Penjualan
                </button>
            </div>

            <div class="print-card bg-gradient-to-r from-purple-950/30 to-slate-900/40 border border-purple-500/20 rounded-2xl p-6 shadow-xl flex justify-between items-center">
                <div>
                    <span class="text-xs uppercase tracking-wider text-purple-400 font-semibold">Total Pendapatan Bersih Terbuku</span>
                    <h3 class="text-2xl font-mono font-bold text-white mt-1 print:text-black">
                        Rp <%= typeof totalPendapatan !== 'undefined' ? totalPendapatan.toLocaleString('id-ID') : '0' %>
                    </h3>
                </div>
                <div class="text-3xl no-print">💰</div>
            </div>

            <div class="print-card bg-slate-900/40 border border-zinc-800 rounded-2xl p-6 shadow-xl">
                <h2 class="text-xs font-bold text-purple-400 uppercase tracking-wider mb-4 print:text-purple-700">🛒 Daftar Faktur Transaksi Penjualan Sukses</h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-xs text-zinc-300">
                        <thead class="bg-zinc-950 text-zinc-400 uppercase font-mono border-b border-zinc-800">
                            <tr>
                                <th class="p-3">Tanggal</th>
                                <th class="p-3">Nama Pembeli</th>
                                <th class="p-3">Komoditas Barang</th>
                                <th class="p-3 text-center">Volume Beli</th>
                                <th class="p-3 text-right">Total Transaksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-zinc-800/50 print:divide-zinc-300">
                            <% if (typeof penjualan !== 'undefined' && penjualan.length > 0) { %>
                                <% penjualan.forEach(trx => { %>
                                    <tr class="hover:bg-zinc-900/30">
                                        <td class="p-3 font-mono text-zinc-400"><%= trx.tanggal_format %></td>
                                        <td class="p-3 font-medium text-white"><%= trx.nama_user %></td>
                                        <td class="p-3 text-zinc-300"><%= trx.nama_barang %></td>
                                        <td class="p-3 text-center font-mono text-purple-300 font-semibold"><%= trx.jumlah_beli %> Pcs</td>
                                        <td class="p-3 text-right font-mono text-emerald-400 font-bold">Rp <%= (trx.jumlah_beli * trx.harga_satuan).toLocaleString('id-ID') %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="p-4 text-center text-zinc-500">Belum ada transaksi masuk dari pembeli.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>

</body>
</html>
