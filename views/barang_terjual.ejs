<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Barang Terjual - InvenioWeb</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body { background-color: #121212; color: #e0e0e0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .sidebar { background-color: #1a1a1a; min-height: 100vh; padding: 20px; }
        .brand { font-size: 24px; font-weight: bold; color: #ffffff; margin-bottom: 30px; display: flex; align-items: center; gap: 10px; }
        .nav-link { color: #aaaaaa; padding: 12px 15px; border-radius: 8px; margin-bottom: 5px; display: block; text-decoration: none; }
        .nav-link:hover, .nav-link.active { background-color: #3b3b98; color: white; }
        .main-content { padding: 40px; }
        .card-custom { background-color: #1e1e1e; border: 1px solid #2d2d2d; border-radius: 12px; padding: 24px; }
        .table-custom { color: #e0e0e0; }
        .table-custom thead th { background-color: #2a2a2a; color: #ffffff; border-color: #3d3d3d; }
        .table-custom tbody td { border-color: #2d2d2d; vertical-align: middle; }
        .badge-user { background-color: #2d3748; color: #a0aec0; padding: 6px 12px; border-radius: 6px; font-size: 13px; }
    </style>
</head>
<body>

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2 sidebar">
            <div class="brand">📦 InvenioWeb</div>
            <nav class="space-y-2">
                <a href="/dashboard" class="block px-4 py-2.5 bg-zinc-800 text-zinc-400 hover:text-white hover:bg-zinc-700 rounded-lg text-sm font-medium transition">Dashboard</a>
                <a href="/barang" class="block px-4 py-2.5 bg-zinc-800 text-zinc-400 hover:text-white hover:bg-zinc-700 rounded-lg text-sm font-medium transition">Kelola Barang</a>
                <a href="/supplier" class="block px-4 py-2.5 bg-zinc-800 text-zinc-400 hover:text-white hover:bg-zinc-700 rounded-lg text-sm font-medium transition">Kelola Supplier</a>
                <a href="/transaksi" class="block px-4 py-2.5 bg-zinc-800 text-zinc-400 hover:text-white hover:bg-zinc-700 rounded-lg text-sm font-medium transition">Kelola Transaksi</a>
                <a href="/laporan" class="block px-4 py-2.5 bg-zinc-800 text-zinc-400 hover:text-white hover:bg-zinc-700 rounded-lg text-sm font-medium transition">Cetak Laporan</a>
                <a href="/barang-terjual" class="block px-4 py-2.5 bg-indigo-600 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Barang Terjual</a>
            </nav>
            <hr class="text-secondary">
            <div class="small text-muted mb-2">Masuk sebagai:</div>
            <div class="fw-bold text-light"><%= user.nama %> (<%= user.role %>)</div>
            <a href="/logout" class="btn btn-sm btn-outline-danger w-100 mt-3">Logout</a>
        </div>

        <div class="col-md-10 main-content">
            <h2 class="mb-4">Daftar Barang Terjual (Pesanan Pelanggan)</h2>
            
            <div class="card-custom">
                <% if (terjual.length === 0) { %>
                    <div class="text-center py-4 text-muted">
                        Belum ada barang yang dibeli oleh pelanggan saat ini.
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-custom table-dark table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Tanggal</th>
                                    <th>Nama Barang</th>
                                    <th>Jumlah Beli</th>
                                    <th>Harga Satuan</th>
                                    <th>Total Pendapatan</th>
                                    <th>Nama Pembeli</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% terjual.forEach(item => { %>
                                    <tr>
                                        <td><%= new Date(item.tanggal).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' }) %></td>
                                        <td class="fw-bold text-info"><%= item.nama_barang %></td>
                                        <td><%= item.jumlah %> pcs</td>
                                        <td>Rp <%= parseFloat(item.harga).toLocaleString('id-ID') %></td>
                                        <td class="text-success fw-bold">Rp <%= (item.jumlah * item.harga).toLocaleString('id-ID') %></td>
                                        <td><span class="badge-user">👤 <%= item.nama_pembeli %></span></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

</body>
</html>
