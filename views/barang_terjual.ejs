<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laporan Realisasi Penjualan & Pendapatan - InvenioWeb</title>
    <link class="no-print" rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        body {
            background-color: #0c1017;
            color: #c9d1d9;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
        
        /* === PERBAIKAN UNTUK CETAK / PRINT MODE === */
        @media print {
            .no-print { 
                display: none !important; 
            }
            body { 
                background-color: #ffffff !important; 
                color: #111827 !important; 
            }
            .print-card { 
                background-color: #ffffff !important; 
                border: 1px solid #d1d5db !important; 
                box-shadow: none !important;
                color: #111827 !important; 
            }
            
            /* Ubah teks putih/terang bawaan dashboard menjadi gelap */
            h1, h2, h3, h4, th, td, p, span, .text-white, .text-slate-200, .text-slate-300 { 
                color: #111827 !important; 
            }
            .text-slate-400, .text-slate-500 { 
                color: #4b5563 !important; 
            }
            
            /* Berikan warna kontras tinggi khusus komponen nominal saat di-print */
            .text-amber-500 {
                color: #b45309 !important; /* Kuning menjadi Oranye/Cokelat Tua */
            }
            .text-emerald-400, .text-emerald-500 {
                color: #047857 !important; /* Hijau cerah menjadi Hijau Tua/Emerald */
            }
            .text-cyan-400 {
                color: #0369a1 !important; /* Cyan menjadi Biru Tua */
            }
            
            /* Reset Background Utility Tailwind */
            [class*="bg-"] { 
                background-color: transparent !important; 
            }
            [class*="border-"] { 
                border-color: #e5e7eb !important; 
            }

            /* Desain Struktur Tabel Cetak Formal */
            thead tr {
                background-color: #f3f4f6 !important;
                border-bottom: 2px solid #d1d5db !important;
            }
            th {
                color: #111827 !important;
                font-weight: 700 !important;
            }
            td {
                border-bottom: 1px solid #e5e7eb !important;
            }
        }
    </style>
</head>
<body class="min-h-screen flex flex-col md:flex-row antialiased select-none">

    <div class="no-print hidden md:flex w-64 bg-[#12161f] border-r border-[#1f242e] p-4 flex-col justify-between shrink-0 min-h-screen sticky top-0">
        <div>
            <div class="flex items-center gap-3 px-2 py-4 border-b border-[#1f242e] mb-6">
                <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-10 h-10 object-contain rounded-lg shadow-md">
                <div>
                    <h1 class="text-white font-bold tracking-wide text-sm">InvenioWeb</h1>
                    <span class="text-[11px] text-cyan-400 font-semibold tracking-wider uppercase block">Market System</span>
                </div>
            </div>
            
            <nav class="space-y-1">
                <a href="/dashboard" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-chart-pie w-5 text-center"></i> <span>Dashboard</span>
                </a>
                <a href="/barang" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-box w-5 text-center"></i> <span>Kelola Barang</span>
                </a>
                <a href="/supplier" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-truck w-5 text-center"></i> <span>Kelola Supplier</span>
                </a>
                <a href="/transaksi" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-exchange-alt w-5 text-center"></i> <span>Kelola Transaksi</span>
                </a>
                <a href="/laporan" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-file-invoice-dollar w-5 text-center"></i> <span>Cetak Laporan</span>
                </a>
                <a href="/barang-terjual" class="flex items-center gap-3 px-4 py-2.5 bg-[#1c212c] text-white border-l-4 border-cyan-500 rounded-r-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-receipt w-5 text-center text-cyan-400"></i> <span>Barang Terjual</span>
                </a>
                <% if (user.role === 'admin') { %>
                <a href="/admin/users" class="flex items-center gap-3 px-4 py-2.5 text-red-400 hover:bg-red-950/20 hover:text-red-300 rounded-lg text-sm font-medium transition duration-150 mt-4">
                    <i class="fa-solid fa-users-cog w-5 text-center"></i> <span>Kelola User</span>
                </a>
                <% } %>
            </nav>
        </div>

        <div class="bg-[#171b26] p-3 rounded-xl border border-[#222834] flex items-center justify-between">
            <div class="flex items-center gap-2.5">
                <div class="w-8 h-8 bg-purple-600 rounded-full flex items-center justify-center text-white text-xs font-bold uppercase">
                    <%= user.nama.substring(0,2) %>
                </div>
                <div class="leading-tight">
                    <p class="text-white text-xs font-semibold truncate max-w-[100px]"><%= user.nama %></p>
                    <span class="text-[10px] text-purple-400 font-medium capitalize"><%= user.role %></span>
                </div>
            </div>
            <a href="/logout" class="text-slate-500 hover:text-red-400 text-xs transition-colors" title="Log Out">
                <i class="fa-solid fa-sign-out-alt"></i>
            </a>
        </div>
    </div>

    <div class="no-print md:hidden bg-[#12161f] border-b border-[#1f242e] p-4 w-full">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-2">
                <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-8 h-8 object-contain rounded-lg">
                <span class="font-bold text-sm tracking-tight text-white">InvenioWeb</span>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-xs text-slate-400 font-medium"><%= user.nama %></span>
                <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition"><i class="fa-solid fa-sign-out-alt"></i></a>
            </div>
        </div>
        <nav class="flex flex-wrap gap-1.5">
            <a href="/dashboard" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Dashboard</a>
            <a href="/barang" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Barang</a>
            <a href="/supplier" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Supplier</a>
            <a href="/transaksi" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Transaksi</a>
            <a href="/laporan" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Laporan</a>
            <a href="/barang-terjual" class="px-3 py-1.5 bg-sky-500/20 text-sky-400 border border-sky-500/30 rounded-md text-xs font-medium">Barang Terjual</a>
        </nav>
    </div>

    <main class="flex-1 p-6 md:p-8 overflow-y-auto space-y-6">
        
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <h2 class="text-xl md:text-2xl font-bold text-white tracking-tight">Laporan Realisasi Penjualan & Pendapatan</h2>
                <p class="text-xs text-slate-400 mt-1">Rekapitulasi berkas seluruh transaksi komersial dari checkout belanja konsumen.</p>
            </div>
            <button onclick="window.print()" class="no-print bg-[#238636] hover:bg-[#2ea043] text-white font-semibold text-xs px-4 py-2.5 rounded-lg flex items-center gap-2 shadow transition-all shrink-0">
                <i class="fa-solid fa-print"></i> Cetak Laporan Penjualan
            </button>
        </div>

        <% 
            let totalPendapatan = 0; 
            if (typeof terjual !== 'undefined') {
                terjual.forEach(t => { 
                    totalPendapatan += (t.jumlah * t.harga); 
                }); 
            }
        %>

        <div class="print-card bg-[#161b22] p-6 rounded-xl border border-[#30363d] shadow-md relative">
            <p class="text-[11px] uppercase tracking-wider text-slate-400 font-semibold mb-1">Total Pendapatan Terbuku</p>
            <div class="flex items-baseline gap-1.5">
                <span class="text-xl font-bold text-slate-400">Rp</span>
                <span class="text-2xl md:text-3xl font-extrabold text-white tracking-tight">
                    <%= totalPendapatan.toLocaleString('id-ID') %>
                </span>
            </div>
            <div class="absolute right-6 bottom-6 text-xl text-slate-600/40 no-print">
                <i class="fa-solid fa-sack-dollar"></i>
            </div>
        </div>

        <div class="print-card bg-[#161b22] rounded-xl border border-[#30363d] shadow-md overflow-hidden">
            <div class="p-4 bg-[#1f242e]/50 border-b border-[#30363d] flex items-center gap-2">
                <h3 class="text-xs font-bold text-cyan-400 uppercase tracking-wider">🛒 Daftar Transaksi Pelanggan Sukses</h3>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left text-xs border-collapse min-w-[700px]">
                    <thead>
                        <tr class="bg-[#12161f]/50 text-slate-400 uppercase tracking-wider border-b border-[#30363d] font-semibold">
                            <th class="p-4">Tanggal Transaksi</th>
                            <th class="p-4">Nama Pembeli (User)</th>
                            <th class="p-4">Komoditas Barang</th>
                            <th class="p-4 text-center">Volume Beli</th>
                            <th class="p-4 text-right">Total Nominal</th>
                            <th class="p-4 text-center no-print">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#30363d]/60 text-slate-300">
                        <% if (typeof terjual === 'undefined' || terjual.length === 0) { %>
                            <tr>
                                <td colspan="6" class="p-8 text-center text-slate-500 italic">
                                    Belum ada data transaksi dari pembeli.
                                </td>
                            </tr>
                        <% } else { %>
                            <% terjual.forEach(t => { %>
                                <tr class="hover:bg-[#1f242e]/30 transition-colors">
                                    <td class="p-4 text-slate-400 font-mono">
                                        <%= t.tanggal ? new Date(t.tanggal).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' }) : '-' %>
                                    </td>
                                    <td class="p-4 font-medium text-white">
                                        <i class="fa-solid fa-user-circle text-slate-500 mr-1.5 no-print"></i>
                                        <%= t.nama_pembeli %>
                                    </td>
                                    <td class="p-4 text-slate-200 font-medium">
                                        <%= t.nama_barang %>
                                    </td>
                                    <td class="p-4 text-center text-amber-500 font-mono font-bold">
                                        <%= t.jumlah %> Pcs
                                    </td>
                                    <td class="p-4 text-right text-emerald-400 font-mono font-bold">
                                        Rp <%= (t.jumlah * t.harga).toLocaleString('id-ID') %>
                                    </td>
                                    <td class="p-4 text-center no-print">
                                        <a href="/barang-terjual/hapus/<%= t.id %>" 
                                           onclick="return confirm('Apakah Anda yakin ingin menghapus riwayat transaksi milik <%= t.nama_pembeli %> ini?')" 
                                           class="inline-flex items-center justify-center bg-red-600/20 hover:bg-red-600 text-red-400 hover:text-white text-[11px] px-2.5 py-1.5 rounded transition duration-150" 
                                           title="Hapus Data">
                                            <i class="fa-solid fa-trash-can mr-1"></i> Hapus
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </main>
</body>
</html>
