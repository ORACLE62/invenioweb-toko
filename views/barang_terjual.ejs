<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laporan Realisasi Penjualan & Pendapatan</title>
    <link rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background-color: #0b0c10;
            color: #c5c6c7;
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>
<body class="flex min-h-screen">

    <div class="w-64 bg-[#1f2833] flex flex-col justify-between p-4 border-r border-gray-800">
        <div>
            <div class="flex items-center gap-3 px-2 py-4 border-b border-gray-700 mb-6">
                <div class="w-10 h-10 bg-[#66fcf1] rounded-lg flex items-center justify-center text-[#0b0c10] font-bold text-xl shadow-lg shadow-[#66fcf1]/20">
                    IW
                </div>
                <div>
                    <h1 class="text-white font-bold tracking-wide">InvenioWeb</h1>
                    <span class="text-xs text-[#66fcf1] font-medium">Market System</span>
                </div>
            </div>
            
            <nav class="space-y-1">
                <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all group">
                    <i class="fa-solid : fa-chart-pie text-lg group-hover:text-[#66fcf1]"></i> <span class="text-sm font-medium">Dashboard</span>
                </a>
                <a href="/barang" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all group">
                    <i class="fa-solid fa-box text-lg group-hover:text-[#66fcf1]"></i> <span class="text-sm font-medium">Kelola Barang</span>
                </a>
                <a href="/supplier" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all group">
                    <i class="fa-solid fa-truck-field text-lg group-hover:text-[#66fcf1]"></i> <span class="text-sm font-medium">Kelola Supplier</span>
                </a>
                <a href="/transaksi" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all group">
                    <i class="fa-solid fa-exchange-alt text-lg group-hover:text-[#66fcf1]"></i> <span class="text-sm font-medium">Kelola Transaksi</span>
                </a>
                <a href="/laporan" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all group">
                    <i class="fa-solid fa-file-invoice-dollar text-lg group-hover:text-[#66fcf1]"></i> <span class="text-sm font-medium">Cetak Laporan</span>
                </a>
                <a href="/barang-terjual" class="flex items-center gap-3 px-4 py-3 bg-gradient-to-r from-[#45f3ff]/20 to-transparent border-l-4 border-[#45f3ff] text-white rounded-r-lg transition-all">
                    <i class="fa-solid fa-receipt text-lg text-[#45f3ff]"></i> <span class="text-sm font-medium">Barang Terjual</span>
                </a>
                <% if (user.role === 'admin') { %>
                <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 text-red-400 hover:bg-red-950/20 hover:text-red-300 rounded-lg transition-all group">
                    <i class="fa-solid fa-users-cog text-lg"></i> <span class="text-sm font-medium">Kelola User</span>
                </a>
                <% } %>
            </nav>
        </div>

        <div class="bg-[#151a21] p-3 rounded-xl border border-gray-800 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-purple-600 rounded-full flex items-center justify-center text-white text-xs font-bold uppercase">
                    <%= user.nama.substring(0,2) %>
                </div>
                <div>
                    <p class="text-white text-xs font-semibold truncate max-w-[100px]"><%= user.nama %></p>
                    <span class="text-[10px] bg-purple-900/50 text-purple-300 px-1.5 py-0.5 rounded border border-purple-700/50 block w-max capitalize"><%= user.role %></span>
                </div>
            </div>
            <a href="/logout" class="text-gray-500 hover:text-red-400 transition-colors" title="Log Out">
                <i class="fa-solid fa-sign-out-alt text-sm"></i>
            </a>
        </div>
    </div>

    <main class="flex-1 p-8 overflow-y-auto">
        
        <div class="flex justify-between items-center mb-8">
            <div>
                <h2 class="text-2xl font-bold text-white tracking-wide">Laporan Realisasi Penjualan & Pendapatan</h2>
                <p class="text-xs text-gray-500 mt-1">Rekapitulasi berkas seluruh transaksi komersial dari checkout belanja konsumen maupun pengeluaran logistik.</p>
            </div>
            <button onclick="window.print()" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold text-xs px-4 py-2.5 rounded-lg flex items-center gap-2 shadow-lg shadow-blue-600/20 transition-all">
                <i class="fa-solid fa-print"></i> Cetak Laporan Penjualan
            </button>
        </div>

        <% 
            let totalPendapatan = 0; 
            terjual.forEach(t => { 
                totalPendapatan += (t.jumlah * t.harga); 
            }); 
        %>

        <div class="bg-[#1f2833] p-6 rounded-xl border border-gray-800 shadow-xl relative overflow-hidden mb-8 group">
            <div class="absolute right-0 top-0 w-24 h-24 bg-gradient-to-bl from-amber-500/10 to-transparent rounded-bl-full pointer-events-none"></div>
            <p class="text-[11px] uppercase tracking-wider text-gray-400 font-semibold mb-1">Total Pendapatan Terbuku</p>
            <div class="flex items-baseline gap-2">
                <span class="text-xl font-bold text-gray-400">Rp</span>
                <span class="text-3xl font-extrabold text-white tracking-tight group-hover:text-amber-400 transition-colors">
                    <%= totalPendapatan.toLocaleString('id-ID') %>
                </span>
            </div>
            <div class="absolute right-6 bottom-6 text-2xl text-amber-500/30 group-hover:scale-110 transition-transform">
                <i class="fa-solid fa-sack-dollar"></i>
            </div>
        </div>

        <div class="bg-[#1f2833] rounded-xl border border-gray-800 shadow-2xl overflow-hidden">
            <div class="p-4 bg-[#151a21] border-b border-gray-800 flex items-center gap-2">
                <i class="fa-solid : fa-list-check text-blue-400 text-sm"></i>
                <h3 class="text-xs font-bold text-blue-400 uppercase tracking-wider">Daftar Transaksi Pelanggan Sukses</h3>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left text-xs border-collapse">
                    <thead>
                        <tr class="bg-[#151a21]/50 text-gray-400 uppercase tracking-wider border-b border-gray-800 font-semibold">
                            <th class="p-4">Tanggal Transaksi</th>
                            <th class="p-4">Nama Pembeli (User)</th>
                            <th class="p-4">Komoditas Barang</th>
                            <th class="p-4 text-center">Volume Beli</th>
                            <th class="p-4 text-right">Total Nominal</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-800">
                        <% if (terjual.length === 0) { %>
                            <tr>
                                <td colspan="5" class="p-8 text-center text-gray-500 italic">
                                    Belum ada data transaksi dari pembeli atau pengeluaran logistik.
                                </td>
                            </tr>
                        <% } else { %>
                            <% terjual.forEach(t => { %>
                                <tr class="hover:bg-[#151a21]/30 transition-colors group">
                                    <td class="p-4 text-gray-400">
                                        <%= t.tanggal ? new Date(t.tanggal).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' }) : '-' %>
                                    </td>
                                    <td class="p-4 font-medium text-white">
                                        <i class="fa-solid fa-user-circle text-gray-600 mr-1.5 text-sm"></i>
                                        <%= t.nama_pembeli %>
                                    </td>
                                    <td class="p-4 text-gray-300 font-semibold group-hover:text-[#45f3ff] transition-colors">
                                        <%= t.nama_barang %>
                                    </td>
                                    <td class="p-4 text-center text-amber-400 font-mono font-bold">
                                        <%= t.jumlah %> Pcs
                                    </td>
                                    <td class="p-4 text-right text-emerald-400 font-mono font-bold">
                                        Rp <%= (t.jumlah * t.harga).toLocaleString('id-ID') %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

</body>
</html>
