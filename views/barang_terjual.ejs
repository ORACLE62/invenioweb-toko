<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Barang Terjual - InvenioWeb</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
    </style>
</head>
<body class="bg-[#121214] text-zinc-100 min-h-screen flex antialiased">

    <aside class="w-64 bg-[#18181b] border-r border-zinc-800/80 p-6 flex flex-col justify-between shrink-0 min-h-screen sticky top-0">
        <div>
            <div class="flex items-center gap-3 mb-8 px-2">
                <div class="bg-indigo-600 p-2 rounded-xl text-white font-bold text-lg shadow-lg shadow-indigo-600/30 flex items-center justify-center w-10 h-10">
                    📦
                </div>
                <span class="text-xl font-bold tracking-tight bg-gradient-to-r from-white to-zinc-400 bg-clip-text text-transparent">
                    InvenioWeb
                </span>
            </div>

            <nav class="space-y-1.5">
                <a href="/dashboard" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Dashboard</a>
                <a href="/barang" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Kelola Barang</a>
                <a href="/supplier" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Kelola Supplier</a>
                <a href="/transaksi" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Kelola Transaksi</a>
                <a href="/laporan" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-xl text-sm font-medium transition-all duration-200">Cetak Laporan</a>
                <a href="/barang-terjual" class="block px-4 py-2.5 bg-indigo-600 text-white shadow-md shadow-indigo-600/10 rounded-xl text-sm font-medium transition-all duration-200">Barang Terjual</a>
                <% if (user.role === 'admin') { %>
                    <a href="/admin/users" class="block px-4 py-2.5 text-red-400 hover:text-white hover:bg-red-900/30 rounded-lg text-sm font-medium transition border border-red-500/10 mt-4">Kelola User</a>
                <% } %>
            </nav>
        </div>

        <div class="border-t border-zinc-800 pt-4 flex items-center justify-between">
            <div>
                <p class="text-xs text-zinc-500">Masuk sebagai:</p>
                
                <% if (user.username === 'admin' || user.username === 'gudang' || user.username === 'pimpinan') { %>
                    <p class="text-sm font-semibold text-zinc-200"><%= user.nama %> (<%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>)</p>
                    <div class="mt-1">
                        <span class="text-xs bg-indigo-500/20 text-indigo-400 px-2.5 py-0.5 rounded border border-indigo-500/30 font-medium"><%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %></span>
                    </div>
                <% } else { %>
                    <p class="text-sm font-semibold text-zinc-200"><%= user.nama %></p>
                <% } %>

                <% if (user.role === 'admin') { %>
                    <div class="mt-2">
                        <a href="/admin/users" class="inline-block text-xs bg-red-500/20 text-red-400 hover:bg-red-500/30 px-2 py-1 rounded border border-red-500/30 font-medium transition">Kelola User</a>
                    </div>
                <% } %>
            </div>
            <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition shrink-0 ml-2">Logout</a>
        </div>
    </aside>

    <main class="flex-1 p-8 lg:p-10">
        <div class="max-w-6xl mx-auto">
            
            <div class="mb-8">
                <h1 class="text-2xl lg:text-3xl font-bold text-white tracking-tight">Daftar Barang Terjual</h1>
                <p class="text-sm text-zinc-400 mt-1.5">Pencatatan sirkulasi pesanan pelanggan yang sukses terjual secara realtime.</p>
            </div>

            <div class="bg-[#18181b] border border-zinc-800 rounded-xl overflow-hidden shadow-2xl shadow-black/40">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="border-b border-zinc-800 bg-zinc-900/40 text-zinc-400 text-xs font-semibold tracking-wider uppercase">
                                <th class="py-4 px-6 w-32">Tanggal</th>
                                <th class="py-4 px-6">Nama Barang</th>
                                <th class="py-4 px-6 text-center w-28">Jumlah Beli</th>
                                <th class="py-4 px-6 w-40">Harga Satuan</th>
                                <th class="py-4 px-6 w-44">Total Pendapatan</th>
                                <th class="py-4 px-6 w-40">Nama Pembeli</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-zinc-800/60 text-sm text-zinc-300">
                            <% if (typeof terjual !== 'undefined' && terjual && terjual.length > 0) { %>
                                <% terjual.forEach(t => { %>
                                    <tr class="hover:bg-zinc-900/20 transition-colors duration-150">
                                        <td class="py-4 px-6 whitespace-nowrap text-zinc-400 text-xs">
                                            <%= new Date(t.tanggal).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                        </td>
                                        <td class="py-4 px-6 font-medium text-cyan-400">
                                            <%= t.nama_barang %>
                                        </td>
                                        <td class="py-4 px-6 text-center font-semibold text-zinc-100 whitespace-nowrap">
                                            <%= t.jumlah %> <span class="text-zinc-500 font-normal text-xs">pcs</span>
                                        </td>
                                        <td class="py-4 px-6 whitespace-nowrap text-zinc-400">
                                            Rp <%= Number(t.harga).toLocaleString('id-ID') %>
                                        </td>
                                        <td class="py-4 px-6 font-bold text-emerald-400 whitespace-nowrap">
                                            Rp <%= (t.jumlah * t.harga).toLocaleString('id-ID') %>
                                        </td>
                                        <td class="py-4 px-6 whitespace-nowrap">
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-medium bg-zinc-800 text-zinc-300 border border-zinc-700/60 shadow-inner">
                                                <span class="text-zinc-500">👤</span> <%= t.nama_pembeli %>
                                            </span>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="py-12 text-center text-zinc-500 italic">
                                        <div class="text-2xl mb-2">🛒</div>
                                        Belum ada data barang yang terjual saat ini.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>

</body>
</html>
