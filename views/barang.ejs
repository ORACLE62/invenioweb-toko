<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kelola Barang - InvenioWeb</title>
    <link class="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-white font-sans min-h-screen flex flex-col md:flex-row">

    <div class="hidden md:flex w-64 bg-zinc-900 border-r border-zinc-800 p-6 flex-col justify-between shrink-0">
        <div>
            <div class="flex items-center gap-3 mb-8">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-indigo-500 to-pink-500 flex items-center justify-center font-bold">I</div>
                <span class="font-bold text-lg tracking-wider">InvenioWeb</span>
            </div>
            <nav class="space-y-2">
                <a href="/dashboard" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Dashboard</a>
                <a href="/barang" class="block px-4 py-2.5 bg-indigo-600 rounded-lg text-sm font-medium transition">Kelola Barang</a>
                <a href="/supplier" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Kelola Supplier</a>
                <a href="/transaksi" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Kelola Transaksi</a>
                <a href="/laporan" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Cetak Laporan</a>
            </nav>
        </div>
        
        <div class="border-t border-zinc-800 pt-4 flex items-center justify-between">
            <div>
                <p class="text-xs text-zinc-500">Masuk sebagai:</p>
                
                <% if (user.username === 'admin' || user.username === 'gudang' || user.username === 'pimpinan') { %>
                    <p class="text-sm font-semibold text-zinc-200"><%= user.nama %> (<%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>)</p>
                    <div class="mt-1">
                        <span class="text-xs bg-indigo-500/20 text-indigo-400 px-2.5 py-0.5 rounded border border-indigo-500/30 font-medium"><%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %></span>
                    </div>
                <% } else { %>
                    <p class="text-sm font-semibold text-zinc-200"><%= user.nama %></p>
                <% } %>

                <% if (user.role === 'admin') { %>
                    <div class="mt-2">
                        <a href="/admin/users" class="inline-block text-xs bg-red-500/20 text-red-400 hover:bg-red-500/30 px-2 py-1 rounded border border-red-500/30 font-medium transition">Kelola User</a>
                    </div>
                <% } %>
            </div>
            <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition shrink-0 ml-2">Logout</a>
        </div>
    </div>

    <div class="md:hidden bg-zinc-900 border-b border-zinc-800 p-4">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-indigo-500 to-pink-500 flex items-center justify-center font-bold">I</div>
                <span class="font-bold text-lg tracking-wider">InvenioWeb</span>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-xs text-zinc-400">
                    <%= user.nama %>
                    <% if (user.username === 'admin' || user.username === 'gudang' || user.username === 'pimpinan') { %>
                        ( <%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %> )
                    <% } %>
                </span>
                <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition">Logout</a>
            </div>
        </div>
        <nav class="flex flex-wrap gap-2">
            <a href="/dashboard" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Dashboard</a>
            <a href="/barang" class="px-3 py-1.5 bg-indigo-600 text-white rounded-lg text-xs font-medium">Barang</a>
            <a href="/supplier" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Supplier</a>
            <a href="/transaksi" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Transaksi</a>
            <a href="/laporan" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Laporan</a>
            <% if (user.role === 'admin') { %>
                <a href="/admin/users" class="px-3 py-1.5 bg-red-900/50 text-red-400 rounded-lg text-xs font-medium border border-red-500/20">Kelola User</a>
            <% } %>
        </nav>
    </div>

    <div class="flex-grow p-6 md:p-10 overflow-y-auto w-full">
        <header class="mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <h1 class="text-2xl md:text-3xl font-bold tracking-tight">Kelola Stok Barang Retail</h1>
                <p class="text-zinc-400 text-sm mt-1">Manajemen komoditas produk, sisa stok gudang, dan integrasi supplier.</p>
            </div>
            <button onclick="toggleModal('modalBarang')" class="w-full sm:w-auto bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2.5 rounded-lg text-sm font-semibold transition shadow-lg shadow-indigo-900/30 whitespace-nowrap">
                ➕ Tambah Barang Baru
            </button>
        </header>

        <div class="bg-zinc-900 border border-zinc-800 rounded-xl overflow-x-auto shadow-2xl">
            <table class="w-full text-left border-collapse min-w-[700px]">
                <thead>
                    <tr class="border-b border-zinc-800 bg-zinc-900/50 text-zinc-400 text-xs font-semibold uppercase tracking-wider">
                        <th class="p-4">ID Barang</th>
                        <th class="p-4">Nama Produk</th>
                        <th class="p-4">Nama Supplier</th>
                        <th class="p-4 text-center">Jumlah Stok</th>
                        <th class="p-4">Harga Satuan</th>
                        <th class="p-4 text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-zinc-800 text-sm text-zinc-300">
                    <% if (barang.length === 0) { %>
                        <tr>
                            <td colspan="6" class="p-8 text-center text-zinc-500 italic">Belum ada data barang di database.</td>
                        </tr>
                    <% } else { %>
                        <% barang.forEach(item => { %>
                            <tr class="hover:bg-zinc-800/30 transition">
                                <td class="p-4 font-mono text-indigo-400 font-semibold"><%= item.id_barang %></td>
                                <td class="p-4 font-medium text-white"><%= item.nama_barang %></td>
                                <td class="p-4 text-zinc-400"><%= item.nama_supplier || 'Tidak ada mitra' %></td>
                                <td class="p-4 text-center">
                                    <span class="font-bold <%= item.stok <= 5 ? 'text-rose-400' : 'text-emerald-400' %>">
                                        <%= item.stok %> Pcs
                                    </span>
                                </td>
                                <td class="p-4 font-mono">Rp <%= item.harga.toLocaleString('id-ID') %></td>
                                
                                <td class="p-4 flex items-center justify-center gap-2">
                                    <button onclick="bukaModalEdit('<%= item.id_barang %>', '<%= item.nama_barang %>', '<%= item.id_supplier %>', '<%= item.stok %>', '<%= item.harga %>')" 
                                            class="bg-amber-500/10 hover:bg-amber-500/20 border border-amber-500/20 text-amber-400 px-2.5 py-1.5 rounded-md text-xs font-semibold transition">
                                        ✏️ Edit
                                    </button>
                                    <a href="/barang/hapus/<%= item.id_barang %>" 
                                       onclick="return confirm('⚠️ Hapus barang [ <%= item.nama_barang %> ]?\nSemua riwayat transaksi barang ini juga akan ikut terhapus.')" 
                                       class="bg-rose-500/10 hover:bg-rose-500/20 border border-rose-500/20 text-rose-400 px-2.5 py-1.5 rounded-md text-xs font-semibold transition">
                                        🗑️ Hapus
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <div id="modalBarang" class="fixed inset-0 bg-black/70 backdrop-blur-sm flex items-center justify-center hidden z-50 p-4">
        <div class="bg-zinc-900 border border-zinc-800 w-full max-w-md rounded-xl shadow-2xl overflow-hidden">
            <div class="p-6 border-b border-zinc-800 flex justify-between items-center">
                <h3 class="text-lg font-bold text-white">📦 Form Tambah Barang Baru</h3>
                <button onclick="toggleModal('modalBarang')" class="text-zinc-400 hover:text-white transition text-xl">&times;</button>
            </div>
            <form action="/barang/tambah" method="POST" class="p-6 space-y-4">
                <div>
                    <label class="block text-xs text-zinc-400 mb-1">Nama Produk Barang</label>
                    <input type="text" name="nama_barang" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white" placeholder="Contoh: Gula Pasir 1kg" required>
                </div>
                <div>
                     <label class="block text-xs text-zinc-400 mb-1">Mitra Supplier Pasokan</label>
                     <select name="id_supplier" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white">
                        <option value="" selected class="bg-zinc-900 text-zinc-400">-- Tanpa Mitra Supplier --</option>
                        <% if (typeof supplier !== 'undefined' && supplier.length > 0) { %>
                            <% supplier.forEach(s => { %>
                                <option value="<%= s.id_supplier %>" class="bg-zinc-900 text-white">
                                    <%= s.nama_supplier %>
                                </option>
                            <% }) %>
                        <% } %>
                     </select>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs text-zinc-400 mb-1">Stok Awal (Pcs)</label>
                        <input type="number" name="stok" min="0" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white" placeholder="0" required>
                    </div>
                    <div>
                        <label class="block text-xs text-zinc-400 mb-1">Harga Satuan (Rp)</label>
                        <input type="number" name="harga" min="0" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white" placeholder="15000" required>
                    </div>
                </div>
                <div class="pt-2 flex gap-3">
                    <button type="button" onclick="toggleModal('modalBarang')" class="w-1/3 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 rounded-lg text-sm font-semibold transition">Batal</button>
                    <button type="submit" class="w-2/3 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg text-sm font-semibold transition shadow-lg shadow-indigo-900/20">Simpan Barang</button>
                </div>
            </form>
        </div>
    </div>

    <div id="modalEditBarang" class="fixed inset-0 bg-black/70 backdrop-blur-sm flex items-center justify-center hidden z-50 p-4">
        <div class="bg-zinc-900 border border-zinc-800 w-full max-w-md rounded-xl shadow-2xl overflow-hidden">
            <div class="p-6 border-b border-zinc-800 flex justify-between items-center">
                <h3 class="text-lg font-bold text-white">✏️ Form Edit Data Barang</h3>
                <button onclick="toggleModal('modalEditBarang')" class="text-zinc-400 hover:text-white transition text-xl">&times;</button>
            </div>
            
            <form id="formEditBarang" action="" method="POST" class="p-6 space-y-4">
                <input type="hidden" name="id_barang" id="edit_id_barang">
                <div>
                    <label class="block text-xs text-zinc-400 mb-1">Nama Produk Barang</label>
                    <input type="text" name="nama_barang" id="edit_nama_barang" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white" required>
                </div>
                <div>
                     <label class="block text-xs text-zinc-400 mb-1">Mitra Supplier Pasokan</label>
                     <select name="id_supplier" id="edit_id_supplier" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white">
                        <option value="" class="bg-zinc-900 text-zinc-400">-- Tanpa Mitra Supplier --</option>
                        <% if (typeof supplier !== 'undefined' && supplier.length > 0) { %>
                            <% supplier.forEach(s => { %>
                                <option value="<%= s.id_supplier %>" class="bg-zinc-900 text-white">
                                    <%= s.nama_supplier %>
                                </option>
                            <% }) %>
                        <% } %>
                     </select>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs text-zinc-400 mb-1">Jumlah Stok (Pcs)</label>
                        <input type="number" name="stok" id="edit_stok" min="0" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white" required>
                    </div>
                    <div>
                        <label class="block text-xs text-zinc-400 mb-1">Harga Satuan (Rp)</label>
                        <input type="number" name="harga" id="edit_harga" min="0" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white" required>
                    </div>
                </div>
                <div class="pt-2 flex gap-3">
                    <button type="button" onclick="toggleModal('modalEditBarang')" class="w-1/3 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 rounded-lg text-sm font-semibold transition">Batal</button>
                    <button type="submit" class="w-2/3 py-2.5 bg-amber-600 hover:bg-amber-500 text-white rounded-lg text-sm font-semibold transition shadow-lg shadow-amber-900/20">Update Data</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function toggleModal(idModal) {
            const modal = document.getElementById(idModal);
            modal.classList.toggle('hidden');
        }

        function bukaModalEdit(id, nama, idSupplier, stok, harga) {
            document.getElementById('edit_id_barang').value = id;
            document.getElementById('edit_nama_barang').value = nama;
            document.getElementById('edit_stok').value = stok;
            document.getElementById('edit_harga').value = harga;
            
            const selectSupplier = document.getElementById('edit_id_supplier');
            if (idSupplier && idSupplier !== 'null' && idSupplier !== 'undefined' && idSupplier !== '') {
                selectSupplier.value = idSupplier;
            } else {
                selectSupplier.value = "";
            }
            
            document.getElementById('formEditBarang').action = '/barang/edit/' + id;

            toggleModal('modalEditBarang');
        }
    </script>

</body>
</html>
