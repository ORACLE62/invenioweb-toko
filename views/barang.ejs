<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kelola Barang - InvenioWeb</title>
    <link rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0b0c10;
            color: #c5c6c7;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col md:flex-row antialiased select-none">

    <div class="hidden md:flex w-64 bg-[#1f2833] border-r border-gray-800 p-4 flex-col justify-between shrink-0 min-h-screen sticky top-0">
        <div>
            <div class="flex items-center gap-3 px-2 py-4 border-b border-gray-700 mb-6">
                <div class="w-10 h-10 bg-[#45f3ff] rounded-full flex items-center justify-center p-1 shadow-lg shadow-[#45f3ff]/20 overflow-hidden shrink-0">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-full">
                </div>
                <div>
                    <h1 class="text-white font-bold tracking-wide text-sm">InvenioWeb</h1>
                    <span class="text-[10px] text-[#45f3ff] font-medium tracking-wider uppercase">Market System</span>
                </div>
            </div>
            
            <nav class="space-y-1">
                <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all duration-200">
                    <span class="text-sm font-medium">Dashboard</span>
                </a>
                <a href="/barang" class="flex items-center gap-3 px-4 py-3 bg-gradient-to-r from-[#45f3ff]/20 to-transparent border-l-4 border-[#45f3ff] text-white rounded-r-lg transition-all">
                    <span class="text-sm font-medium">Kelola Barang</span>
                </a>
                <a href="/supplier" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all duration-200">
                    <span class="text-sm font-medium">Kelola Supplier</span>
                </a>
                <a href="/transaksi" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all duration-200">
                    <span class="text-sm font-medium">Kelola Transaksi</span>
                </a>
                <a href="/laporan" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all duration-200">
                    <span class="text-sm font-medium">Cetak Laporan</span>
                </a>
                <a href="/barang-terjual" class="flex items-center gap-3 px-4 py-3 text-gray-400 hover:bg-[#151a21] hover:text-white rounded-lg transition-all duration-200">
                    <span class="text-sm font-medium">Barang Terjual</span>
                </a>
                <% if (user.role === 'admin') { %>
                    <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 text-red-400 hover:bg-red-950/20 hover:text-red-300 rounded-lg transition-all mt-2">
                        <span class="text-sm font-medium">Kelola User</span>
                    </a>
                <% } %>
            </nav>
        </div>
        
        <div class="bg-[#151a21] p-3 rounded-xl border border-gray-800 flex items-center justify-between shadow-inner">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 bg-purple-600 rounded-full flex items-center justify-center text-white text-xs font-bold uppercase border border-purple-500/30">
                    <%= user.nama.substring(0,2) %>
                </div>
                <div>
                    <p class="text-white text-xs font-semibold truncate max-w-[110px]"><%= user.nama %></p>
                    <span class="text-[10px] bg-purple-950 text-purple-300 px-1.5 py-0.5 rounded border border-purple-800/50 block w-max capitalize mt-0.5"><%= user.role %></span>
                </div>
            </div>
            <a href="/logout" class="text-gray-500 hover:text-red-400 p-1.5 hover:bg-gray-800/30 rounded-lg transition-colors" title="Log Out">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
            </a>
        </div>
    </div>

    <div class="md:hidden bg-[#1f2833] border-b border-gray-800 p-4">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="bg-[#45f3ff] rounded-full p-0.5 flex items-center justify-center w-8 h-8 overflow-hidden shrink-0">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-full">
                </div>
                <span class="font-bold tracking-tight text-white">
                    InvenioWeb
                </span>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-xs text-gray-400">
                    <%= user.nama %>
                    <% if (user.username === 'admin' || user.username === 'gudang' || user.username === 'pimpinan') { %>
                        (<%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>)
                    <% } %>
                </span>
                <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition">Logout</a>
            </div>
        </div>
        <nav class="flex flex-wrap gap-2">
            <a href="/dashboard" class="px-3 py-1.5 bg-[#151a21] text-gray-400 rounded-lg text-xs font-medium transition hover:text-white">Dashboard</a>
            <a href="/barang" class="px-3 py-1.5 bg-[#45f3ff] text-[#0b0c10] rounded-lg text-xs font-bold shadow-md">Barang</a>
            <a href="/supplier" class="px-3 py-1.5 bg-[#151a21] text-gray-400 rounded-lg text-xs font-medium transition hover:text-white">Supplier</a>
            <a href="/transaksi" class="px-3 py-1.5 bg-[#151a21] text-gray-400 rounded-lg text-xs font-medium transition hover:text-white">Transaksi</a>
            <a href="/laporan" class="px-3 py-1.5 bg-[#151a21] text-gray-400 rounded-lg text-xs font-medium transition hover:text-white">Laporan</a>
            <a href="/barang-terjual" class="px-3 py-1.5 bg-[#151a21] text-gray-400 rounded-lg text-xs font-medium transition hover:text-white">Barang Terjual</a>
            <% if (user.role === 'admin') { %>
                <a href="/admin/users" class="px-3 py-1.5 bg-red-950/50 text-red-400 rounded-lg text-xs font-medium border border-red-500/20">Kelola User</a>
            <% } %>
        </nav>
    </div>

    <div class="flex-grow p-6 md:p-10 overflow-y-auto w-full bg-[#0b0c10]">
        <header class="mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-white">Kelola Stok Barang Retail</h1>
                <p class="text-gray-500 text-sm mt-1">Manajemen komoditas produk, sisa stok gudang, dan integrasi supplier.</p>
            </div>
            <button onclick="toggleModal('modalBarang')" class="w-full sm:w-auto bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2.5 rounded-lg text-sm font-semibold transition shadow-lg shadow-indigo-900/30 whitespace-nowrap">
                ➕ Tambah Barang Baru
            </button>
        </header>

        <div class="bg-[#1f2833] border border-gray-800 rounded-xl overflow-x-auto shadow-2xl">
            <table class="w-full text-left border-collapse min-w-[700px]">
                <thead>
                    <tr class="border-b border-gray-800 bg-[#151a21]/50 text-gray-400 text-xs font-semibold uppercase tracking-wider">
                        <th class="p-4">ID Barang</th>
                        <th class="p-4">Nama Produk</th>
                        <th class="p-4">Nama Supplier</th>
                        <th class="p-4 text-center">Jumlah Stok</th>
                        <th class="p-4">Harga Satuan</th>
                        <th class="p-4 text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800 text-sm text-gray-300">
                    <% if (barang.length === 0) { %>
                        <tr>
                            <td colspan="6" class="p-8 text-center text-gray-500 italic">Belum ada data barang di database.</td>
                        </tr>
                    <% } else { %>
                        <% barang.forEach(item => { %>
                            <tr class="hover:bg-[#151a21]/40 transition">
                                <td class="p-4 font-mono text-[#45f3ff] font-semibold"><%= item.id_barang %></td>
                                <td class="p-4 font-medium text-white"><%= item.nama_barang %></td>
                                <td class="p-4 text-gray-400"><%= item.nama_supplier || 'Tidak ada mitra' %></td>
                                <td class="p-4 text-center">
                                    <span class="font-bold <%= item.stok <= 5 ? 'text-rose-400' : 'text-emerald-400' %>">
                                        <%= item.stok %> Pcs
                                    </span>
                                </td>
                                <td class="p-4 font-mono">Rp <%= item.harga.toLocaleString('id-ID') %></td>
                                
                                <td class="p-4 flex items-center justify-center gap-2">
                                    <button onclick="bukaModalEdit('<%= item.id_barang %>', '<%= item.nama_barang %>', '<%= item.id_supplier %>', '<%= item.stok %>', '<%= item.harga %>')" 
                                            class="bg-amber-500/10 hover:bg-amber-500/20 border border-amber-500/20 text-amber-400 px-2.5 py-1.5 rounded-md text-xs font-semibold transition">
                                        ✏️ Edit
                                    </button>
                                    <a href="/barang/hapus/<%= item.id_barang %>" 
                                       onclick="return confirm('⚠️ Hapus barang [ <%= item.nama_barang %> ]?\nSemua riwayat transaksi barang ini juga akan ikut terhapus.')" 
                                       class="bg-rose-500/10 hover:bg-rose-500/20 border border-rose-500/20 text-rose-400 px-2.5 py-1.5 rounded-md text-xs font-semibold transition">
                                        🗑️ Hapus
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <div id="modalBarang" class="fixed inset-0 bg-black/70 backdrop-blur-sm flex items-center justify-center hidden z-50 p-4">
        <div class="bg-[#1f2833] border border-gray-800 w-full max-w-md rounded-xl shadow-2xl overflow-hidden">
            <div class="p-6 border-b border-gray-800 flex justify-between items-center">
                <h3 class="text-lg font-bold text-white">📦 Form Tambah Barang Baru</h3>
                <button onclick="toggleModal('modalBarang')" class="text-gray-400 hover:text-white transition text-xl">&times;</button>
            </div>
            <form action="/barang/tambah" method="POST" class="p-6 space-y-4">
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Nama Produk Barang</label>
                    <input type="text" name="nama_barang" class="w-full bg-[#0b0c10] border border-gray-800 rounded-lg p-2.5 text-sm focus:border-[#45f3ff] outline-none text-white" placeholder="Contoh: Gula Pasir 1kg" required>
                </div>
                <div>
                     <label class="block text-xs text-gray-400 mb-1">Mitra Supplier Pasokan</label>
                     <select name="id_supplier" class="w-full bg-[#0b0c10] border border-gray-800 rounded-lg p-2.5 text-sm focus:border-[#45f3ff] outline-none text-white">
                        <option value="" selected class="bg-[#1f2833] text-gray-400">-- Tanpa Mitra Supplier --</option>
                        <% if (typeof supplier !== 'undefined' && supplier.length > 0) { %>
                            <% supplier.forEach(s => { %>
                                <option value="<%= s.id_supplier %>" class="bg-[#1f2833] text-white">
                                    <%= s.nama_supplier %>
                                </option>
                            <% }) %>
                        <% } %>
                     </select>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Stok Awal (Pcs)</label>
                        <input type="number" name="stok" min="0" class="w-full bg-[#0b0c10] border border-gray-800 rounded-lg p-2.5 text-sm focus:border-[#45f3ff] outline-none text-white" placeholder="0" required>
                    </div>
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Harga Satuan (Rp)</label>
                        <input type="number" name="harga" min="0" class="w-full bg-[#0b0c10] border border-gray-800 rounded-lg p-2.5 text-sm focus:border-[#45f3ff] outline-none text-white" placeholder="15000" required>
                    </div>
                </div>
                <div class="pt-2 flex gap-3">
                    <button type="button" onclick="toggleModal('modalBarang')" class="w-1/3 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-lg text-sm font-semibold transition">Batal</button>
                    <button type="submit" class="w-2/3 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg text-sm font-semibold transition shadow-lg shadow-indigo-900/20">Simpan Barang</button>
                </div>
            </form>
        </div>
    </div>

    <div id="modalEditBarang" class="fixed inset-0 bg-black/70 backdrop-blur-sm flex items-center justify-center hidden z-50 p-4">
        <div class="bg-[#1f2833] border border-gray-800 w-full max-w-md rounded-xl shadow-2xl overflow-hidden">
            <div class="p-6 border-b border-gray-800 flex justify-between items-center">
                <h3 class="text-lg font-bold text-white">✏️ Form Edit Data Barang</h3>
                <button onclick="toggleModal('modalEditBarang')" class="text-gray-400 hover:text-white transition text-xl">&times;</button>
            </div>
            
            <form id="formEditBarang" action="" method="POST" class="p-6 space-y-4">
                <input type="hidden" name="id_barang" id="edit_id_barang">
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Nama Produk Barang</label>
                    <input type="text" name="nama_barang" id="edit_nama_barang" class="w-full bg-[#0b0c10] border border-gray-800 rounded-lg p-2.5 text-sm focus:border-[#45f3ff] outline-none text-white" required>
                </div>
                <div>
                     <label class="block text-xs text-gray-400 mb-1">Mitra Supplier Pasokan</label>
                     <select name="id_supplier" id="edit_id_supplier" class="w-full bg-[#0b0c10] border border-gray-800 rounded-lg p-2.5 text-sm focus:border-[#45f3ff] outline-none text-white">
                        <option value="" class="bg-[#1f2833] text-gray-400">-- Tanpa Mitra Supplier --</option>
                        <% if (typeof supplier !== 'undefined' && supplier.length > 0) { %>
                            <% supplier.forEach(s => { %>
                                <option value="<%= s.id_supplier %>" class="bg-[#1f2833] text-white">
                                    <%= s.nama_supplier %>
                                </option>
                            <% }) %>
                        <% } %>
                     </select>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Jumlah Stok (Pcs)</label>
                        <input type="number" name="stok" id="edit_stok" min="0" class="w-full bg-[#0b0c10] border border-gray-800 rounded-lg p-2.5 text-sm focus:border-[#45f3ff] outline-none text-white" required>
                    </div>
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Harga Satuan (Rp)</label>
                        <input type="number" name="harga" id="edit_harga" min="0" class="w-full bg-[#0b0c10] border border-gray-800 rounded-lg p-2.5 text-sm focus:border-[#45f3ff] outline-none text-white" required>
                    </div>
                </div>
                <div class="pt-2 flex gap-3">
                    <button type="button" onclick="toggleModal('modalEditBarang')" class="w-1/3 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-lg text-sm font-semibold transition">Batal</button>
                    <button type="submit" class="w-2/3 py-2.5 bg-amber-600 hover:bg-amber-500 text-white rounded-lg text-sm font-semibold transition shadow-lg shadow-amber-900/20">Update Data</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function toggleModal(idModal) {
            const modal = document.getElementById(idModal);
            modal.classList.toggle('hidden');
        }

        function bukaModalEdit(id, nama, idSupplier, stok, harga) {
            document.getElementById('edit_id_barang').value = id;
            document.getElementById('edit_nama_barang').value = nama;
            document.getElementById('edit_stok').value = stok;
            document.getElementById('edit_harga').value = harga;
            
            const selectSupplier = document.getElementById('edit_id_supplier');
            if (idSupplier && idSupplier !== 'null' && idSupplier !== 'undefined' && idSupplier !== '') {
                selectSupplier.value = idSupplier;
            } else {
                selectSupplier.value = "";
            }
            
            document.getElementById('formEditBarang').action = '/barang/edit/' + id;

            toggleModal('modalEditBarang');
        }
    </script>

</body>
</html>
