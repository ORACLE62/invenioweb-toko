<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kelola Supplier - InvenioWeb</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-white font-sans min-h-screen flex flex-col md:flex-row">

    <!-- SIDEBAR: Laptop -->
    <div class="hidden md:flex w-64 bg-zinc-900 border-r border-zinc-800 p-6 flex-col justify-between shrink-0">
        <div>
            <div class="flex items-center gap-3 mb-8">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-indigo-500 to-pink-500 flex items-center justify-center font-bold">I</div>
                <span class="font-bold text-lg tracking-wider">InvenioWeb</span>
            </div>
            <nav class="space-y-2">
                <a href="/dashboard" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Dashboard</a>
                <a href="/barang" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Kelola Barang</a>
                <a href="/supplier" class="block px-4 py-2.5 bg-indigo-600 rounded-lg text-sm font-medium transition">Kelola Supplier</a>
                <a href="/transaksi" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Kelola Transaksi</a>
                <a href="/laporan" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Cetak Laporan</a>
            </nav>
        </div>
        <div class="border-t border-zinc-800 pt-4">
            <p class="text-xs text-zinc-500">Masuk sebagai:</p>
            <p class="text-sm font-semibold text-zinc-200 mb-2"><%= user.nama %> (Admin)</p>
            <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition">Logout</a>
        </div>
    </div>

    <!-- NAVBAR: HP -->
    <div class="md:hidden bg-zinc-900 border-b border-zinc-800 p-4">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-indigo-500 to-pink-500 flex items-center justify-center font-bold">I</div>
                <span class="font-bold text-lg tracking-wider">InvenioWeb</span>
            </div>
            <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition">Logout</a>
        </div>
        <nav class="flex flex-wrap gap-2">
            <a href="/dashboard" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Dashboard</a>
            <a href="/barang" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Barang</a>
            <a href="/supplier" class="px-3 py-1.5 bg-indigo-600 text-white rounded-lg text-xs font-medium">Supplier</a>
            <a href="/transaksi" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Transaksi</a>
            <a href="/laporan" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Laporan</a>
        </nav>
    </div>

    <!-- MAIN CONTENT -->
    <div class="flex-grow p-4 md:p-10 overflow-y-auto w-full">
        <header class="mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <h1 class="text-2xl md:text-3xl font-bold tracking-tight">Kelola Mitra Supplier</h1>
                <p class="text-zinc-400 text-sm mt-1">Manajemen data produsen, distributor, dan pihak penyuplai pasokan.</p>
            </div>
            <button onclick="toggleModal('modalSupplier')" class="w-full sm:w-auto bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2.5 rounded-lg text-sm font-semibold transition shadow-lg shadow-indigo-900/30 whitespace-nowrap">
                ➕ Tambah Supplier Baru
            </button>
        </header>

        <div class="bg-zinc-900 border border-zinc-800 rounded-xl overflow-x-auto shadow-2xl">
            <table class="w-full text-left border-collapse min-w-[700px]">
                <thead>
                    <tr class="border-b border-zinc-800 bg-zinc-900/50 text-zinc-400 text-xs font-semibold uppercase tracking-wider">
                        <th class="p-4">ID Supplier</th>
                        <th class="p-4">Nama Instansi / Perusahaan</th>
                        <th class="p-4">Nomor Telepon</th>
                        <th class="p-4">Alamat Kantor</th>
                        <th class="p-4 text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-zinc-800 text-sm text-zinc-300">
                    <% if (supplier.length === 0) { %>
                        <tr>
                            <td colspan="5" class="p-8 text-center text-zinc-500 italic">Belum ada data supplier di database.</td>
                        </tr>
                    <% } else { %>
                        <% supplier.forEach(s => { %>
                            <tr class="hover:bg-zinc-800/30 transition">
                                <td class="p-4 font-mono text-indigo-400 font-semibold"><%= s.id_supplier %></td>
                                <td class="p-4 font-medium text-white"><%= s.nama_supplier %></td>
                                <td class="p-4 font-mono text-zinc-400"><%= s.telepon || '-' %></td>
                                <td class="p-4 text-zinc-400 truncate max-w-xs"><%= s.alamat || '-' %></td>
                                <td class="p-4 flex items-center justify-center gap-2">
                                    <button onclick="bukaModalEditSupplier('<%= s.id_supplier %>', '<%= s.nama_supplier %>', '<%= s.telepon %>', '<%= s.alamat %>')" 
                                            class="bg-amber-500/10 hover:bg-amber-500/20 border border-amber-500/20 text-amber-400 px-2.5 py-1.5 rounded-md text-xs font-semibold transition">
                                        ✏️ Edit
                                    </button>
                                    <a href="/supplier/hapus/<%= s.id_supplier %>" 
                                       onclick="return confirm('⚠️ Hapus supplier [ <%= s.nama_supplier %> ]?\nTindakan ini akan mengosongkan status supplier pada produk terkait.')" 
                                       class="bg-rose-500/10 hover:bg-rose-500/20 border border-rose-500/20 text-rose-400 px-2.5 py-1.5 rounded-md text-xs font-semibold transition">
                                        🗑️ Hapus
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- MODAL: TAMBAH SUPPLIER -->
    <div id="modalSupplier" class="fixed inset-0 bg-black/70 backdrop-blur-sm flex items-center justify-center hidden z-50 p-4">
        <div class="bg-zinc-900 border border-zinc-800 w-full max-w-md rounded-xl shadow-2xl overflow-hidden">
            <div class="p-6 border-b border-zinc-800 flex justify-between items-center">
                <h3 class="text-lg font-bold text-white">🤝 Form Tambah Supplier</h3>
                <button onclick="toggleModal('modalSupplier')" class="text-zinc-400 hover:text-white transition text-xl">&times;</button>
            </div>
            <form action="/supplier/tambah" method="POST" class="p-6 space-y-4">
                <div>
                    <label class="block text-xs text-zinc-400 mb-1">Nama Supplier / PT</label>
                    <input type="text" name="nama_supplier" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white" placeholder="Contoh: PT. Sinar Abadi" required>
                </div>
                <div>
                    <label class="block text-xs text-zinc-400 mb-1">Nomor Telepon Kontak</label>
                    <input type="text" name="telepon" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white" placeholder="Contoh: 08123456789" required>
                </div>
                <div>
                    <label class="block text-xs text-zinc-400 mb-1">Alamat Kantor</label>
                    <textarea name="alamat" rows="3" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white resize-none" placeholder="Alamat lengkap instansi..." required></textarea>
                </div>
                <div class="pt-2 flex gap-3">
                    <button type="button" onclick="toggleModal('modalSupplier')" class="w-1/3 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 rounded-lg text-sm font-semibold transition">Batal</button>
                    <button type="submit" class="w-2/3 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg text-sm font-semibold transition">Simpan Mitra</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL: EDIT SUPPLIER -->
    <div id="modalEditSupplier" class="fixed inset-0 bg-black/70 backdrop-blur-sm flex items-center justify-center hidden z-50 p-4">
        <div class="bg-zinc-900 border border-zinc-800 w-full max-w-md rounded-xl shadow-2xl overflow-hidden">
            <div class="p-6 border-b border-zinc-800 flex justify-between items-center">
                <h3 class="text-lg font-bold text-white">✏️ Form Edit Supplier</h3>
                <button onclick="toggleModal('modalEditSupplier')" class="text-zinc-400 hover:text-white transition text-xl">&times;</button>
            </div>
            <form id="formEditSupplier" action="/supplier/edit" method="POST" class="p-6 space-y-4">
                <input type="hidden" name="id_supplier" id="edit_id_supplier">
                <div>
                    <label class="block text-xs text-zinc-400 mb-1">Nama Supplier / PT</label>
                    <input type="text" name="nama_supplier" id="edit_nama_supplier" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white" required>
                </div>
                <div>
                    <label class="block text-xs text-zinc-400 mb-1">Nomor Telepon Kontak</label>
                    <input type="text" name="telepon" id="edit_telepon" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white" required>
                </div>
                <div>
                    <label class="block text-xs text-zinc-400 mb-1">Alamat Kantor</label>
                    <textarea name="alamat" id="edit_alamat" rows="3" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white resize-none" required></textarea>
                </div>
                <div class="pt-2 flex gap-3">
                    <button type="button" onclick="toggleModal('modalEditSupplier')" class="w-1/3 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 rounded-lg text-sm font-semibold transition">Batal</button>
                    <button type="submit" class="w-2/3 py-2.5 bg-amber-600 hover:bg-amber-500 text-white rounded-lg text-sm font-semibold transition">Update Mitra</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function toggleModal(idModal) {
            document.getElementById(idModal).classList.toggle('hidden');
        }
        function bukaModalEditSupplier(id, nama, telp, alamat) {
            document.getElementById('edit_id_supplier').value = id;
            document.getElementById('edit_nama_supplier').value = nama;
            document.getElementById('edit_telepon').value = telp;
            document.getElementById('edit_alamat').value = alamat;
            document.getElementById('formEditSupplier').action = '/supplier/edit/' + id;
            toggleModal('modalEditSupplier');
        }
    </script>
</body>
</html>
