<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kelola Supplier - InvenioWeb</title>
    <link rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-white font-sans min-h-screen flex flex-col md:flex-row">

    <!-- Sidebar Desktop -->
    <div class="hidden md:flex w-64 bg-zinc-900 border-r border-zinc-800 p-6 flex-col justify-between shrink-0">
        <div>
            <div class="flex items-center gap-3 mb-8">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-indigo-500 to-pink-500 flex items-center justify-center font-bold">I</div>
                <span class="font-bold text-lg tracking-wider">InvenioWeb</span>
            </div>
            <nav class="space-y-2">
                <a href="/dashboard" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Dashboard</a>
                <a href="/barang" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Kelola Barang</a>
                <a href="/supplier" class="block px-4 py-2.5 bg-indigo-600 rounded-lg text-sm font-medium transition">Kelola Supplier</a>
                <a href="/transaksi" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Kelola Transaksi</a>
                <a href="/laporan" class="block px-4 py-2.5 text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg text-sm font-medium transition">Cetak Laporan</a>
            </nav>
        </div>
        
        <div class="border-t border-zinc-800 pt-4 flex items-center justify-between">
            <div>
                <p class="text-xs text-zinc-500">Masuk sebagai:</p>
                
                <!-- LOGIC PENYARINGAN NAMA & ROLE PETUGAS VS USER BARU (DESKTOP) -->
                <% if (user.username === 'admin' || user.username === 'gudang' || user.username === 'pimpinan') { %>
                    <p class="text-sm font-semibold text-zinc-200"><%= user.nama %> (<%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>)</p>
                    <div class="mt-1">
                        <span class="text-xs bg-indigo-500/20 text-indigo-400 px-2.5 py-0.5 rounded border border-indigo-500/30 font-medium"><%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %></span>
                    </div>
                <% } else { %>
                    <p class="text-sm font-semibold text-zinc-200"><%= user.nama %></p>
                <% } %>

                <% if (user.role === 'admin') { %>
                    <div class="mt-2">
                        <a href="/admin/users" class="inline-block text-xs bg-red-500/20 text-red-400 hover:bg-red-500/30 px-2 py-1 rounded border border-red-500/30 font-medium transition">Kelola User</a>
                    </div>
                <% } %>
            </div>
            <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition shrink-0 ml-2">Logout</a>
        </div>
    </div>

    <!-- Navbar Mobile -->
    <div class="md:hidden bg-zinc-900 border-b border-zinc-800 p-4">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-indigo-500 to-pink-500 flex items-center justify-center font-bold">I</div>
                <span class="font-bold text-lg tracking-wider">InvenioWeb</span>
            </div>
            <div class="flex items-center gap-3">
                <!-- LOGIC PENYARINGAN NAMA & ROLE PETUGAS VS USER BARU (MOBILE) -->
                <span class="text-xs text-zinc-400">
                    <%= user.nama %>
                    <% if (user.username === 'admin' || user.username === 'gudang' || user.username === 'pimpinan') { %>
                        ( <%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %> )
                    <% } %>
                </span>
                <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition">Logout</a>
            </div>
        </div>
        <nav class="flex flex-wrap gap-2">
            <a href="/dashboard" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Dashboard</a>
            <a href="/barang" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Barang</a>
            <a href="/supplier" class="px-3 py-1.5 bg-indigo-600 text-white rounded-lg text-xs font-medium">Supplier</a>
            <a href="/transaksi" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Transaksi</a>
            <a href="/laporan" class="px-3 py-1.5 bg-zinc-800 text-zinc-400 rounded-lg text-xs font-medium">Laporan</a>
            <% if (user.role === 'admin') { %>
                <a href="/admin/users" class="px-3 py-1.5 bg-red-900/50 text-red-400 rounded-lg text-xs font-medium border border-red-500/20">Kelola User</a>
            <% } %>
        </nav>
    </div>

    <!-- Main Content -->
    <div class="flex-grow p-4 md:p-10 overflow-y-auto w-full space-y-8">
        <header>
            <h1 class="text-2xl md:text-3xl font-bold tracking-tight">Kelola Mitra Supplier</h1>
            <p class="text-zinc-400 text-sm mt-1">Manajemen data produsen, distributor, dan pihak penyuplai pasokan barang toko.</p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
            <!-- Form Tambah Supplier -->
            <div class="bg-zinc-900/50 border border-zinc-800 p-6 rounded-xl shadow-xl lg:col-span-1">
                <div class="flex items-center gap-2 mb-4">
                    <span>🤝</span>
                    <h2 class="text-base font-bold text-indigo-400">Tambah Supplier Baru</h2>
                </div>
                <form action="/supplier/tambah" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-xs text-zinc-500 mb-1">Nama Supplier / PT</label>
                        <input type="text" name="nama_supplier" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white" placeholder="Contoh: PT. IndoFood" required>
                    </div>
                    <div>
                        <label class="block text-xs text-zinc-500 mb-1">Nomor Telepon Kontak</label>
                        <input type="text" name="telepon" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white" placeholder="Contoh: 08123456789" required>
                    </div>
                    <div>
                        <label class="block text-xs text-zinc-500 mb-1">Alamat Kantor</label>
                        <textarea name="alamat" rows="3" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-indigo-500 outline-none text-white resize-none" placeholder="Alamat lengkap instansi..." required></textarea>
                    </div>
                    <button type="submit" class="w-full py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-lg text-sm transition">
                        Simpan Mitra
                    </button>
                </form>
            </div>

            <!-- Form Edit Supplier (Hidden secara default) -->
            <div id="cardEditSupplier" class="bg-zinc-900/50 border border-amber-500/30 p-6 rounded-xl shadow-xl lg:col-span-1 hidden">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-2">
                        <span>✏️</span>
                        <h2 class="text-base font-bold text-amber-500">Form Ubah Data Supplier</h2>
                    </div>
                    <button type="button" onclick="tutupFormEdit()" class="text-zinc-500 hover:text-white transition text-sm">Batal</button>
                </div>
                <form id="formEditSupplier" method="POST" class="space-y-4">
                    <input type="hidden" name="id_supplier" id="edit_id_supplier">
                    <div>
                        <label class="block text-xs text-zinc-500 mb-1">Nama Supplier / PT</label>
                        <input type="text" name="nama_supplier" id="edit_nama_supplier" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-amber-500 outline-none text-white" required>
                    </div>
                    <div>
                        <label class="block text-xs text-zinc-500 mb-1">Nomor Telepon Kontak</label>
                        <input type="text" name="telepon" id="edit_telepon" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-amber-500 outline-none text-white" required>
                    </div>
                    <div>
                        <label class="block text-xs text-zinc-500 mb-1">Alamat Kantor</label>
                        <textarea name="alamat" id="edit_alamat" rows="3" class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2.5 text-sm focus:border-amber-500 outline-none text-white resize-none" required></textarea>
                    </div>
                    <div class="flex gap-2">
                        <button type="button" onclick="tutupFormEdit()" class="w-1/3 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-400 rounded-lg text-sm font-medium transition">Batal</button>
                        <button type="submit" class="w-2/3 py-2.5 bg-amber-600 hover:bg-amber-500 text-white font-semibold rounded-lg text-sm transition">Update Mitra</button>
                    </div>
                </form>
            </div>

            <!-- Tabel Data Supplier -->
            <div class="bg-zinc-900 border border-zinc-800 rounded-xl shadow-2xl overflow-hidden lg:col-span-2 w-full">
                <div class="overflow-x-auto w-full">
                    <table class="w-full text-left border-collapse min-w-[550px]">
                        <thead>
                            <tr class="border-b border-zinc-800 text-zinc-500 text-xs font-bold uppercase tracking-wider">
                                <th class="p-4">ID</th>
                                <th class="p-4">Nama Instansi</th>
                                <th class="p-4">Telepon</th>
                                <th class="p-4">Alamat</th>
                                <th class="p-4 text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-zinc-800/60 text-sm text-zinc-300">
                            <% if (supplier.length === 0) { %>
                                <tr>
                                    <td colspan="5" class="p-8 text-center text-zinc-600 italic">Belum ada data supplier.</td>
                                </tr>
                            <% } else { %>
                                <% supplier.forEach(s => { %>
                                    <tr class="hover:bg-zinc-800/20 transition">
                                        <td class="p-4 font-mono text-indigo-400 text-xs font-semibold"><%= s.id_supplier %></td>
                                        <td class="p-4 font-medium text-white"><%= s.nama_supplier %></td>
                                        
                                        <td class="p-4 font-mono text-xs text-zinc-400"><%= s.kontak || '-' %></td>
                                        
                                        <td class="p-4 text-zinc-300 max-w-[180px] truncate"><%= s.alamat || '-' %></td>
                                        
                                        <td class="p-4 text-center">
                                            <div class="flex items-center justify-center gap-2">
                                                <button onclick="tampilkanFormEdit('<%= s.id_supplier %>', '<%= s.nama_supplier %>', '<%= s.kontak %>', '<%= s.alamat %>')" class="bg-amber-500/10 hover:bg-amber-500/20 text-amber-400 px-2.5 py-1 rounded text-xs transition">✏️ Edit</button>
                                                <a href="/supplier/hapus/<%= s.id_supplier %>" onclick="return confirm('Hapus supplier?')" class="bg-rose-500/10 hover:bg-rose-500/20 text-rose-400 px-2.5 py-1 rounded text-xs transition">🗑️ Hapus</a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- JavaScript Handling -->
    <script>
        function tampilkanFormEdit(id, nama, telp, alamat) {
            document.getElementById('edit_id_supplier').value = id;
            document.getElementById('edit_nama_supplier').value = nama;
            document.getElementById('edit_telepon').value = telp;
            document.getElementById('edit_alamat').value = alamat;
            document.getElementById('formEditSupplier').action = '/supplier/edit/' + id;
            document.getElementById('cardEditSupplier').classList.remove('hidden');
            document.getElementById('cardEditSupplier').scrollIntoView({ behavior: 'smooth' });
        }
        
        function tutupFormEdit() {
            document.getElementById('cardEditSupplier').classList.add('hidden');
        }
    </script>
</body>
</html>
