<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kelola Supplier - InvenioWeb</title>
    <link class="no-print" rel="icon" href="https://i.postimg.cc/Fsgf4zWP/favicon.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0c1017;
            color: #c9d1d9;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col md:flex-row antialiased select-none">

    <div class="no-print hidden md:flex w-64 bg-[#12161f] border-r border-[#1f242e] p-4 flex-col justify-between shrink-0 min-h-screen sticky top-0">
        <div>
            <div class="flex items-center gap-3 px-2 py-4 border-b border-[#1f242e] mb-6">
                <div class="w-10 h-10 bg-cyan-500/10 border border-cyan-500/30 rounded-lg flex items-center justify-center p-1.5 shadow-lg shadow-cyan-500/10 overflow-hidden shrink-0">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-md">
                </div>
                <div>
                    <h1 class="text-white font-bold tracking-wide text-sm">InvenioWeb</h1>
                    <span class="text-[11px] text-cyan-400 font-semibold tracking-wider uppercase block">Market System</span>
                </div>
            </div>

            <nav class="space-y-1">
                <a href="/dashboard" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-chart-pie w-5 text-center"></i> <span>Dashboard</span>
                </a>
                <a href="/barang" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-box w-5 text-center"></i> <span>Kelola Barang</span>
                </a>
                <a href="/supplier" class="flex items-center gap-3 px-4 py-2.5 bg-[#1c212c] text-white border-l-4 border-cyan-500 rounded-r-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-truck w-5 text-center text-cyan-400"></i> <span>Kelola Supplier</span>
                </a>
                <a href="/transaksi" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-exchange-alt w-5 text-center"></i> <span>Kelola Transaksi</span>
                </a>
                <a href="/laporan" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-file-invoice-dollar w-5 text-center"></i> <span>Cetak Laporan</span>
                </a>
                <a href="/barang-terjual" class="flex items-center gap-3 px-4 py-2.5 text-slate-400 hover:bg-[#1c212c] hover:text-white rounded-lg text-sm font-medium transition duration-150">
                    <i class="fa-solid fa-receipt w-5 text-center"></i> <span>Barang Terjual</span>
                </a>
                
                <% if (user.role === 'admin') { %>
                    <a href="/admin/users" class="flex items-center gap-3 px-4 py-2.5 text-red-400 hover:bg-red-950/20 hover:text-red-300 rounded-lg text-sm font-medium transition duration-150 mt-4">
                        <i class="fa-solid fa-users-cog w-5 text-center"></i> <span>Kelola User</span>
                    </a>
                <% } %>
            </nav>      
        </div>

        <div class="bg-[#171b26] p-3 rounded-xl border border-[#222834] flex items-center justify-between">
            <div class="flex items-center gap-2.5">
                <div class="w-8 h-8 bg-purple-600 rounded-full flex items-center justify-center text-white text-xs font-bold uppercase">
                    <%= user.nama.substring(0,2) %>
                </div>
                <div class="leading-tight">
                    <p class="text-white text-xs font-semibold truncate max-w-[110px]"><%= user.nama %></p>
                    <span class="text-[10px] text-purple-400 font-medium capitalize block w-max mt-0.5"><%= user.role %></span>
                </div>
            </div>
            <a href="/logout" class="text-slate-500 hover:text-red-400 p-1.5 hover:bg-gray-800/30 rounded-lg transition-colors" title="Log Out">
                <i class="fa-solid fa-sign-out-alt"></i>
            </a>
        </div>
    </div>

    <div class="md:hidden bg-[#12161f] border-b border-[#1f242e] p-4 w-full">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-2">
                <div class="bg-cyan-500/10 border border-cyan-500/30 rounded-lg p-1 w-8 h-8 flex items-center justify-center overflow-hidden shrink-0">
                    <img src="https://i.postimg.cc/Fsgf4zWP/favicon.png" alt="Logo InvenioWeb" class="w-full h-full object-cover rounded-md">
                </div>
                <span class="font-bold text-sm tracking-tight text-white">InvenioWeb</span>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-xs text-slate-400 font-medium">
                    <%= user.nama %>
                    <% if (user.username === 'admin' || user.username === 'gudang' || user.username === 'pimpinan') { %>
                        (<%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>)
                    <% } %>
                </span>
                <a href="/logout" class="text-xs text-red-400 hover:text-red-300 font-medium transition">Logout</a>
            </div>
        </div>
        
        <nav class="flex flex-wrap gap-1.5">
            <a href="/dashboard" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Dashboard</a>
            <a href="/barang" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Barang</a>
            <a href="/supplier" class="px-3 py-1.5 bg-sky-500/20 text-sky-400 border border-sky-500/30 rounded-md text-xs font-medium">Supplier</a>
            <a href="/transaksi" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Transaksi</a>
            <a href="/laporan" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Laporan</a>
            <a href="/barang-terjual" class="px-3 py-1.5 bg-[#1c212c] text-slate-400 rounded-md text-xs font-medium">Barang Terjual</a>
        </nav>
    </div>

    <div class="flex-grow p-6 md:p-8 overflow-y-auto w-full bg-[#0c1017]">
        <header class="mb-6">
            <h1 class="text-xl md:text-2xl font-bold tracking-tight text-white">Kelola Mitra Supplier</h1>
            <p class="text-slate-400 text-xs mt-1">Manajemen data produsen, distributor, dan pihak penyuplai pasokan barang toko.</p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
            
            <div class="lg:col-span-1 space-y-6">
                <div class="bg-[#161b22] border border-[#30363d] p-5 rounded-xl shadow-md">
                    <div class="flex items-center gap-2 mb-4">
                        <i class="fa-solid fa-handshake text-cyan-400 text-sm"></i>
                        <h2 class="text-sm font-bold text-white">Tambah Supplier Baru</h2>
                    </div>
                    <form action="/supplier/tambah" method="POST" class="space-y-4 text-xs">
                        <div>
                            <label class="block text-slate-400 mb-1">Nama Supplier / PT</label>
                            <input type="text" name="nama_supplier" class="w-full bg-[#0c1017] border border-[#30363d] rounded-lg p-2.5 text-xs focus:border-cyan-500 outline-none text-white" placeholder="Contoh: PT. IndoFood" required>
                        </div>
                        <div>
                            <label class="block text-slate-400 mb-1">Nomor Telepon Kontak</label>
                            <input type="text" name="kontak" class="w-full bg-[#0c1017] border border-[#30363d] rounded-lg p-2.5 text-xs focus:border-cyan-500 outline-none text-white" placeholder="Contoh: 08123456789" required>
                        </div>
                        <div>
                            <label class="block text-slate-400 mb-1">Alamat Kantor</label>
                            <textarea name="alamat" rows="3" class="w-full bg-[#0c1017] border border-[#30363d] rounded-lg p-2.5 text-xs focus:border-cyan-500 outline-none text-white resize-none" placeholder="Alamat lengkap instansi..." required></textarea>
                        </div>
                        <button type="submit" class="w-full py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-lg text-xs transition shadow-md shadow-indigo-900/20">
                            <i class="fa-solid fa-floppy-disk mr-1.5"></i> Simpan Mitra
                        </button>
                    </form>
                </div>

                <div id="cardEditSupplier" class="bg-[#161b22] border border-amber-500/30 p-5 rounded-xl shadow-md hidden">
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center gap-2">
                            <i class="fa-solid fa-pen-to-square text-amber-400 text-sm"></i>
                            <h2 class="text-sm font-bold text-white">Form Ubah Data Supplier</h2>
                        </div>
                        <button type="button" onclick="tutupFormEdit()" class="text-slate-400 hover:text-white transition text-lg leading-none">&times;</button>
                    </div>
                    <form id="formEditSupplier" method="POST" class="space-y-4 text-xs">
                        <input type="hidden" name="id_supplier" id="edit_id_supplier">
                        <div>
                            <label class="block text-slate-400 mb-1">Nama Supplier / PT</label>
                            <input type="text" name="nama_supplier" id="edit_nama_supplier" class="w-full bg-[#0c1017] border border-[#30363d] rounded-lg p-2.5 text-xs focus:border-amber-500 outline-none text-white" required>
                        </div>
                        <div>
                            <label class="block text-slate-400 mb-1">Nomor Telepon Kontak</label>
                            <input type="text" name="kontak" id="edit_telepon" class="w-full bg-[#0c1017] border border-[#30363d] rounded-lg p-2.5 text-xs focus:border-amber-500 outline-none text-white" required>
                        </div>
                        <div>
                            <label class="block text-slate-400 mb-1">Alamat Kantor</label>
                            <textarea name="alamat" id="edit_alamat" rows="3" class="w-full bg-[#0c1017] border border-[#30363d] rounded-lg p-2.5 text-xs focus:border-amber-500 outline-none text-white resize-none" required></textarea>
                        </div>
                        <div class="flex gap-2">
                            <button type="button" onclick="tutupFormEdit()" class="w-1/3 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 rounded-lg font-medium transition">Batal</button>
                            <button type="submit" class="w-2/3 py-2.5 bg-amber-600 hover:bg-amber-500 text-white font-semibold rounded-lg transition shadow-md shadow-amber-900/20">Update Data</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="bg-[#161b22] border border-[#30363d] rounded-xl shadow-md overflow-hidden lg:col-span-2 w-full">
                <div class="overflow-x-auto w-full">
                    <table class="w-full text-left border-collapse min-w-[550px]">
                        <thead>
                            <tr class="border-b border-[#30363d] bg-[#12161f] text-slate-400 text-xs font-semibold uppercase tracking-wider">
                                <th class="p-4">ID</th>
                                <th class="p-4">Nama Instansi</th>
                                <th class="p-4">Telepon</th>
                                <th class="p-4">Alamat</th>
                                <th class="p-4 text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#30363d] text-xs text-slate-300">
                            <% if (supplier.length === 0) { %>
                                <tr>
                                    <td colspan="5" class="p-8 text-center text-slate-500 italic">Belum ada data supplier di database.</td>
                                </tr>
                            <% } else { %>
                                <% supplier.forEach(s => { %>
                                    <tr class="hover:bg-[#12161f]/40 transition">
                                        <td class="p-4 font-mono text-cyan-400 font-semibold"><%= s.id_supplier %></td>
                                        <td class="p-4 font-medium text-white"><%= s.nama_supplier %></td>
                                        <td class="p-4 font-mono text-slate-400"><%= s.kontak || '-' %></td>
                                        <td class="p-4 text-slate-300 max-w-[180px] truncate" title="<%= s.alamat %>"><%= s.alamat || '-' %></td>
                                        <td class="p-4 text-center">
                                            <div class="flex items-center justify-center gap-2">
                                                <button onclick="tampilkanFormEdit('<%= s.id_supplier %>', '<%= s.nama_supplier %>', '<%= s.kontak %>', '<%= s.alamat %>')" 
                                                        class="bg-amber-500/10 hover:bg-amber-500/20 border border-amber-500/20 text-amber-400 px-2.5 py-1.5 rounded-md font-semibold transition">
                                                    <i class="fa-solid fa-pen mr-1"></i> Edit
                                                </button>
                                                <a href="/supplier/hapus/<%= s.id_supplier %>" 
                                                   onclick="return confirm('⚠️ Hapus mitra supplier [ <%= s.nama_supplier %> ]?\nLangkah ini berpotensi memutus data relasi pada tabel barang.')" 
                                                   class="bg-rose-500/10 hover:bg-rose-500/20 border border-rose-500/20 text-rose-400 px-2.5 py-1.5 rounded-md font-semibold transition">
                                                    <i class="fa-solid fa-trash mr-1"></i> Hapus
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>

    <script>
        function tampilkanFormEdit(id, nama, telp, alamat) {
            document.getElementById('edit_id_supplier').value = id;
            document.getElementById('edit_nama_supplier').value = nama;
            document.getElementById('edit_telepon').value = telp;
            document.getElementById('edit_alamat').value = alamat;
            document.getElementById('formEditSupplier').action = '/supplier/edit/' + id;
            
            const cardEdit = document.getElementById('cardEditSupplier');
            cardEdit.classList.remove('hidden');
            cardEdit.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
        
        function tutupFormEdit() {
            document.getElementById('cardEditSupplier').classList.add('hidden');
        }
    </script>
</body>
</html>
