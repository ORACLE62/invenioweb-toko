<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Account - InvenioWeb</title>
    <style>
        /* --- RESET & BASE STYLE --- */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: #121214;
            color: #e1e1e6;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow: hidden;
            position: relative;
        }

        /* --- BACKGROUND KANVAS BINTANG BERGERAK --- */
        #starfield {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }

        /* --- BENTO CARD CONTAINER --- */
        .register-card {
            background: rgba(24, 24, 27, 0.75);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 40px 30px;
            border-radius: 24px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
            z-index: 10;
            text-align: center;
        }

        /* --- LOGO & TEXT --- */
        .logo-container {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 12px;
        }

        .logo-icon {
            background: linear-gradient(135deg, #a855f7, #ec4899);
            color: white;
            font-weight: bold;
            font-size: 18px;
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 0 15px rgba(168, 85, 247, 0.4);
        }

        .brand-name {
            font-size: 14px;
            color: #94a3b8;
            margin-top: 8px;
            letter-spacing: 0.5px;
        }

        h2 {
            font-size: 28px;
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 28px;
            letter-spacing: -0.5px;
        }

        /* --- FORM ELEMENTS --- */
        .form-group {
            margin-bottom: 18px;
            text-align: left;
            position: relative; /* Agar ikon mata bisa diposisikan absolut di kanan */
        }

        .form-group input {
            width: 100%;
            padding: 14px 16px;
            background: rgba(39, 39, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            color: #ffffff;
            font-size: 15px;
            transition: all 0.2s ease;
        }

        /* Tambahkan padding kanan khusus pada baris password supaya teks tidak tertutup mata */
        .form-group input[type="password"],
        .form-group input[type="text"]#password {
            padding-right: 48px;
        }

        .form-group input:focus {
            outline: none;
            border-color: rgba(236, 72, 153, 0.5);
            background: rgba(39, 39, 42, 0.9);
            box-shadow: 0 0 0 3px rgba(236, 72, 153, 0.15);
        }

        .form-group input::placeholder {
            color: #52525b;
        }

        /* --- TOMBOL MATA (PASSWORD TOGGLE) --- */
        .toggle-password {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #71717a;
            padding: 4px;
            transition: color 0.2s ease;
        }

        .toggle-password:hover {
            color: #a1a1aa;
        }

        .toggle-password:focus {
            outline: none;
        }

        /* --- BUTTONS --- */
        .btn-submit {
            width: 100%;
            padding: 14px;
            background: linear-gradient(90deg, #ff9ebb, #ec4899);
            color: #121214;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
            transition: all 0.2s ease;
        }

        .btn-submit:hover {
            opacity: 0.95;
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(236, 72, 153, 0.3);
        }

        /* --- FOOTER LINKS --- */
        .divider {
            height: 1px;
            background: rgba(255, 255, 255, 0.06);
            margin: 24px 0;
        }

        .footer-text {
            font-size: 14px;
            color: #71717a;
        }

        .footer-text a {
            color: #ff9ebb;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }

        .footer-text a:hover {
            color: #ec4899;
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <canvas id="starfield"></canvas>

    <div class="register-card">
        <div class="logo-container">
            <div class="logo-icon">I</div>
        </div>
        <div class="brand-name">InvenioWeb</div>
        <h2>Sign up to IWS</h2>
        
        <form action="/register" method="POST">
            <div class="form-group">
                <input type="text" name="nama" placeholder="Full Name" required autocomplete="off">
            </div>
            <div class="form-group">
                <input type="text" name="username" placeholder="Username" required autocomplete="off">
            </div>
            
            <div class="form-group">
                <input type="password" name="password" id="password" placeholder="Password" required>
                <button type="button" class="toggle-password" id="togglePasswordBtn">
                    <svg id="eyeOpenIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                    <svg id="eyeClosedIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
                        <line x1="1" y1="1" x2="23" y2="23"></line>
                    </svg>
                </button>
            </div>
            
            <input type="hidden" name="role" value="gudang">

            <button type="submit" class="btn-submit">Create Account</button>
        </form>

        <div class="divider"></div>

        <div class="footer-text">
            Already have an account? <a href="/login">Sign in</a>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('starfield');
        const ctx = canvas.getContext('2d');

        let width = canvas.width = window.innerWidth;
        let height = canvas.height = window.innerHeight;

        window.addEventListener('resize', () => {
            width = canvas.width = window.innerWidth;
            height = canvas.height = window.innerHeight;
            initStars();
        });

        const numStars = 120;
        let stars = [];

        function initStars() {
            stars = [];
            for (let i = 0; i < numStars; i++) {
                stars.push({
                    x: Math.random() * width,
                    y: Math.random() * height,
                    size: Math.random() * 1.5,
                    speedX: (Math.random() * -0.2) - 0.05,
                    speedY: (Math.random() * -0.2) - 0.05,
                    opacity: Math.random()
                });
            }
        }

        function animate() {
            ctx.clearRect(0, 0, width, height);
            
            stars.forEach(star => {
                ctx.fillStyle = `rgba(255, 255, 255, ${star.opacity})`;
                ctx.beginPath();
                ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
                ctx.fill();

                star.x += star.speedX;
                star.y += star.speedY;

                star.opacity += (Math.random() * 0.04) - 0.02;
                if (star.opacity < 0.2) star.opacity = 0.2;
                if (star.opacity > 0.8) star.opacity = 0.8;

                if (star.x < 0) star.x = width;
                if (star.y < 0) star.y = height;
            });

            requestAnimationFrame(animate);
        }

        initStars();
        animate();

        // --- LOGIKA TOGGLE MATA PASSWORD DI SINI ---
        const passwordInput = document.getElementById('password');
        const togglePasswordBtn = document.getElementById('togglePasswordBtn');
        const eyeOpenIcon = document.getElementById('eyeOpenIcon');
        const eyeClosedIcon = document.getElementById('eyeClosedIcon');

        togglePasswordBtn.addEventListener('click', function () {
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                eyeOpenIcon.style.display = 'none';
                eyeClosedIcon.style.display = 'block';
            } else {
                passwordInput.type = 'password';
                eyeOpenIcon.style.display = 'block';
                eyeClosedIcon.style.display = 'none';
            }
        });
    </script>
</body>
</html>
